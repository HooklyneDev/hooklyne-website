{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "hooklyne.com" }],
      "destination": "https://www.hooklyne.com/$1",
      "permanent": true
    },
    {
      "source": "/resources/news",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/nl/about",
      "destination": "/nl/over-ons",
      "permanent": true
    },
    {
      "source": "/nl/how-it-works",
      "destination": "/nl/hoe-het-werkt",
      "permanent": true
    },
    {
      "source": "/nl/pricing",
      "destination": "/nl/prijzen",
      "permanent": true
    },
    {
      "source": "/nl/apollo-alternative",
      "destination": "/nl/apollo-alternatief",
      "permanent": true
    },
    {
      "source": "/nl/cognism-alternative",
      "destination": "/nl/cognism-alternatief",
      "permanent": true
    },
    {
      "source": "/nl/lusha-alternative",
      "destination": "/nl/lusha-alternatief",
      "permanent": true
    },
    {
      "source": "/nl/gdpr-prospecting",
      "destination": "/nl/avg-prospecting",
      "permanent": true
    },
    {
      "source": "/disclaimer",
      "destination": "/terms-of-service",
      "permanent": true
    },
    {
      "source": "/nl/disclaimer",
      "destination": "/nl/terms-of-service",
      "permanent": true
    }
  ]
}
