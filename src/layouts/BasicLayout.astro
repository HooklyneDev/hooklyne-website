---
import BaseHead from "@/components/BaseHead.astro";
import { Footer } from "@/components/blocks/footer";
import { Navbar } from "@/components/blocks/navbar";

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('hooklyne-lang');
          var lang = stored === 'nl' || stored === 'en'
            ? stored
            : ((navigator.language || 'en').toLowerCase().startsWith('nl') ? 'nl' : 'en');
          document.documentElement.setAttribute('lang', lang);
          document.documentElement.setAttribute('data-lang', lang);
        } catch (e) {
          document.documentElement.setAttribute('data-lang', 'en');
        }
      })();
    </script>
    <BaseHead title={title} description={description} />
  </head>
  <body class={`h-screen antialiased`}>
    <Navbar client:only='react' />
    <main>
      <section class="mx-auto max-w-2xl px-4 py-28 lg:pt-44 lg:pb-32">
        <article class="prose prose-lg">
          <slot />
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
