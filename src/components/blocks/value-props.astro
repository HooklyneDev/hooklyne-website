---
const STEPS = [
  {
    n: "01",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Signal detected",
    body: "Funding, hiring, leadership, launches. Every prospect arrives with a reason to write today.",
  },
  {
    n: "02",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Contact verified",
    body: "20+ providers waterfalled. Four deliverability layers. If it can't be verified, it doesn't ship.",
  },
  {
    n: "03",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>`,
    title: "Message drafted",
    body: "Four reasoning passes. Hook, angle, voice, quality. Reads like your rep wrote it.",
  },
  {
    n: "04",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>`,
    title: "Dutch or English",
    body: "Native Dutch. Natural English. Toggle per prospect.",
  },
  {
    n: "05",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>`,
    title: "Review and send",
    body: "Open. Check. Send. Under 60 seconds per prospect.",
  },
];
---

<section class="container max-w-6xl pt-14 lg:pt-20 pb-4">
  <div
    class="relative rounded-3xl p-px"
    style="background: linear-gradient(135deg, rgba(52,76,163,0.18) 0%, rgba(52,76,163,0.04) 50%, rgba(52,76,163,0.12) 100%);"
  >
    <div class="rounded-3xl overflow-hidden" style="background: var(--card);">

      <div
        class="absolute top-0 left-0 right-0 h-px"
        style="background: linear-gradient(90deg, transparent 0%, rgba(52,76,163,0.5) 30%, rgba(52,76,163,0.8) 50%, rgba(52,76,163,0.5) 70%, transparent 100%);"
      ></div>

      <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-none lg:grid lg:grid-cols-5 lg:overflow-visible">
        {STEPS.map(({ n, icon, title, body }, i) => (
          <div data-fade data-delay={i + 1} class={`snap-start flex-shrink-0 w-[78vw] sm:w-[44vw] lg:w-auto relative flex flex-col gap-4 p-6 lg:p-7 ${i < STEPS.length - 1 ? 'border-r border-[var(--border)]' : ''}`}>

            {i < STEPS.length - 1 && (
              <div class="hidden lg:flex absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 z-10 size-5 items-center justify-center rounded-full bg-[var(--card)] border border-[var(--border)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-blue);"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            )}

            <div class="flex items-center justify-between">
              <span class="text-xs font-bold tracking-widest" style="color: var(--hooklyne-blue); opacity: 0.5;">{n}</span>
              <div
                class="size-9 rounded-lg flex items-center justify-center"
                style="background: rgba(52,76,163,0.08); color: var(--hooklyne-blue);"
                set:html={icon}
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <p class="text-sm font-semibold text-[var(--heading)] leading-snug">{title}</p>
              <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">{body}</p>
            </div>

          </div>
        ))}
      </div>

    </div>
  </div>
</section>
