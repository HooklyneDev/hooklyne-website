---
const isNL = Astro.url.pathname.startsWith("/nl");

type Stat = { n: string; label: string };

const statsEN: Stat[] = [
  { n: "21",    label: "data providers" },
  { n: "4",     label: "verification layers" },
  { n: "7",     label: "signal categories" },
  { n: "<60s",  label: "to review and send" },
];

const statsNL: Stat[] = [
  { n: "21",    label: "dataproviders" },
  { n: "4",     label: "verificatielagen" },
  { n: "7",     label: "signaalcategorieën" },
  { n: "<60s",  label: "beoordelen en versturen" },
];

const stats = isNL ? statsNL : statsEN;
---

<div class="py-5">
  <div class="container max-w-6xl">
    <dl class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 sm:gap-x-12">
      {stats.map((s, i) => (
        <div class="flex items-baseline gap-2">
          <dt
            class="text-[18px] sm:text-[20px] font-bold tabular-nums tracking-tight leading-none"
            style="color: var(--heading);"
          >
            {s.n}
          </dt>
          <dd class="text-[12px] sm:text-[13px] leading-snug" style="color: var(--muted-foreground);">
            {s.label}
          </dd>
          {i < stats.length - 1 && (
            <span class="hidden sm:inline ml-4 sm:ml-6 text-[var(--border)] select-none" aria-hidden="true">·</span>
          )}
        </div>
      ))}
    </dl>
  </div>
</div>
