---
// Illustrative signals - sector descriptors, no company names.
// Each line is a real-world buying-intent trigger a B2B rep would act on.
const isNL = Astro.url.pathname === "/nl" || Astro.url.pathname.startsWith("/nl/");

type Tone = "orange" | "teal" | "blue" | "emerald" | "rose" | "indigo" | "amber";
type IconKey = "funding" | "leadership" | "hiring" | "expansion" | "launch" | "sector" | "press";

// One distinct tone per category so the feed reads as seven colours,
// not three repeating ones.
const iconToTone: Record<IconKey, Tone> = {
  funding: "orange",
  leadership: "teal",
  hiring: "blue",
  expansion: "emerald",
  launch: "rose",
  sector: "indigo",
  press: "amber",
};

interface Signal {
  type: string;
  tone: Tone;
  icon: IconKey;
  sector: string;
  title: string;
  source: string;
  when: string;
}

const signalsEN: Signal[] = [
  { type: "Funding", tone: "orange", icon: "funding",
    sector: "Industrial SaaS · NL",
    title: "Closed €18M Series B, scaling EMEA sales team",
    source: "Funding tracker", when: "2h ago" },
  { type: "Leadership", tone: "teal", icon: "leadership",
    sector: "Logistics · UK",
    title: "Hired first VP RevOps, 90-day stack review likely",
    source: "Public profiles", when: "4h ago" },
  { type: "Hiring", tone: "blue", icon: "hiring",
    sector: "Fintech · Benelux",
    title: "Opened 6 senior AE roles, doubling outbound team",
    source: "Job boards", when: "1d ago" },
  { type: "Expansion", tone: "teal", icon: "expansion",
    sector: "Food processing · NL",
    title: "New Rotterdam plant announced, controls engineer gap",
    source: "Company news", when: "5h ago" },
  { type: "Leadership", tone: "teal", icon: "leadership",
    sector: "MedTech · DACH",
    title: "Head of Procurement stepped down, supplier review window",
    source: "Public profiles", when: "3h ago" },
  { type: "Launch", tone: "blue", icon: "launch",
    sector: "B2B SaaS · UK",
    title: "Launched EU product line, compliance partners needed",
    source: "Company blog", when: "7h ago" },
  { type: "Funding", tone: "orange", icon: "funding",
    sector: "Climate tech · NL",
    title: "€4.2M seed closed, first sales hire posted same week",
    source: "Funding tracker", when: "12h ago" },
  { type: "Sector", tone: "blue", icon: "sector",
    sector: "Freight · EMEA",
    title: "Diesel spot rates +18%, margin pressure on mid-market ops",
    source: "Industry trackers", when: "1d ago" },
  { type: "Hiring", tone: "blue", icon: "hiring",
    sector: "Manufacturing · BE",
    title: "Reopened 2 AE roles after a 6-month freeze",
    source: "Job boards", when: "6h ago" },
  { type: "Press", tone: "orange", icon: "press",
    sector: "Energy · NL",
    title: "Named in Dutch fast-growth 50, investor call next week",
    source: "Press wires", when: "9h ago" },
];

const signalsNL: Signal[] = [
  { type: "Funding", tone: "orange", icon: "funding",
    sector: "Industriële SaaS · NL",
    title: "€18M Series B rond. EMEA-salesteam wordt opgeschaald.",
    source: "Funding tracker", when: "2u geleden" },
  { type: "Leiderschap", tone: "teal", icon: "leadership",
    sector: "Logistiek · UK",
    title: "Eerste VP RevOps aangenomen. Stack-review binnen 90 dagen waarschijnlijk.",
    source: "LinkedIn-profielen", when: "4u geleden" },
  { type: "Hiring", tone: "blue", icon: "hiring",
    sector: "Fintech · Benelux",
    title: "6 senior AE-rollen open. Outbound-team verdubbelt.",
    source: "Vacaturesites", when: "1d geleden" },
  { type: "Expansie", tone: "teal", icon: "expansion",
    sector: "Voedingsmiddelen · NL",
    title: "Nieuwe Rotterdamse fabriek aangekondigd. Gat in controls engineering.",
    source: "Bedrijfsnieuws", when: "5u geleden" },
  { type: "Leiderschap", tone: "teal", icon: "leadership",
    sector: "MedTech · DACH",
    title: "Head of Procurement opgestapt. Leveranciersreview-window open.",
    source: "LinkedIn-profielen", when: "3u geleden" },
  { type: "Launch", tone: "blue", icon: "launch",
    sector: "B2B SaaS · UK",
    title: "EU-productlijn gelanceerd. Compliance-partners gezocht.",
    source: "Bedrijfsblog", when: "7u geleden" },
  { type: "Funding", tone: "orange", icon: "funding",
    sector: "Klimaattechniek · NL",
    title: "€4,2M seed rond. Eerste sales hire dezelfde week geplaatst.",
    source: "Funding tracker", when: "12u geleden" },
  { type: "Sector", tone: "blue", icon: "sector",
    sector: "Vracht · EMEA",
    title: "Dieselprijzen +18%. Marge-druk op mid-market operaties.",
    source: "Sectorbronnen", when: "1d geleden" },
  { type: "Hiring", tone: "blue", icon: "hiring",
    sector: "Maakindustrie · BE",
    title: "2 AE-rollen heropend. Na een vacature-stop van 6 maanden.",
    source: "Vacaturesites", when: "6u geleden" },
  { type: "Pers", tone: "orange", icon: "press",
    sector: "Energie · NL",
    title: "Genoemd in Nederlandse fast-growth 50. Investor-call volgende week.",
    source: "Persberichten", when: "9u geleden" },
];

const signals = isNL ? signalsNL : signalsEN;
const labels = isNL ? {
  feed: "Real-time signaalfeed",
  meta: "Zeven soorten signalen, gescoord op je ideaal klantprofiel",
  lookback: "14 dagen terug.",
  illustrative: "Voorbeelden, geanonimiseerd per sector.",
  source: "Bron:",
} : {
  feed: "Live signal feed",
  meta: "Seven signal categories, scored for your ICP",
  lookback: "14-day lookback.",
  illustrative: "Illustrative, anonymised by sector.",
  source: "Source:",
};

const toneMap: Record<Tone, string> = {
  orange:  "var(--hooklyne-orange)",
  teal:    "var(--hooklyne-teal)",
  blue:    "var(--hooklyne-blue)",
  emerald: "#059669",
  rose:    "#e11d48",
  indigo:  "#4f46e5",
  amber:   "#b45309",
};

const toneBg: Record<Tone, string> = {
  orange:  "rgba(255,140,66,0.12)",
  teal:    "rgba(13,148,136,0.10)",
  blue:    "rgba(52,76,163,0.10)",
  emerald: "rgba(5,150,105,0.10)",
  rose:    "rgba(225,29,72,0.10)",
  indigo:  "rgba(79,70,229,0.10)",
  amber:   "rgba(180,83,9,0.10)",
};

// Minimal inline SVGs so we don't pull in a dep for a handful of glyphs.
const iconPaths: Record<IconKey, string> = {
  funding: `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><polyline points="16 7 22 7 22 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
  leadership: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/><line x1="19" x2="19" y1="8" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="22" x2="16" y1="11" y2="11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`,
  hiring: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M22 21v-2a4 4 0 0 0-3-3.87" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3.13a4 4 0 0 1 0 7.75" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
  expansion: `<path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="1.8"/>`,
  launch: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
  sector: `<line x1="12" x2="12" y1="20" y2="10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="18" x2="18" y1="20" y2="4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="6" x2="6" y1="20" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`,
  press: `<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 14h-8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M15 18h-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M10 6h8v4h-8V6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>`,
};

// Duplicate for seamless loop
const track = [...signals, ...signals];
---

<section class="pt-10 pb-6 lg:pt-14 lg:pb-8 relative" data-fade>
  <div class="container max-w-6xl mb-6">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div class="flex items-center gap-3">
        <span class="relative flex size-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-70 animate-ping"></span>
          <span class="relative inline-flex size-2 rounded-full bg-emerald-500"></span>
        </span>
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)]">{labels.feed}</span>
      </div>
      <p class="text-xs text-[var(--muted-foreground)]/80">
        {labels.meta} &middot; {labels.lookback}
        <span class="text-[var(--muted-foreground)]/60">&nbsp;{labels.illustrative}</span>
      </p>
    </div>
  </div>

  <div class="signal-ticker-viewport group">
    <div class="signal-ticker-track">
      {track.map((s, i) => (
        <article
          class="signal-pill shrink-0 flex items-center gap-3 rounded-xl px-4 py-3"
          style={`border: 1px solid var(--border); background: var(--card); box-shadow: var(--shadow-xs);`}
          data-idx={i}
        >
          <span
            class="inline-flex items-center justify-center size-9 rounded-lg shrink-0"
            style={`background: ${toneBg[iconToTone[s.icon]]}; color: ${toneMap[iconToTone[s.icon]]};`}
            aria-hidden="true"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" set:html={iconPaths[s.icon]} />
          </span>
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span
                class="text-[9px] font-bold uppercase tracking-[0.18em] px-1.5 py-0.5 rounded"
                style={`background: ${toneBg[iconToTone[s.icon]]}; color: ${toneMap[iconToTone[s.icon]]};`}
              >
                {s.type}
              </span>
              <span class="text-[10px] font-mono text-[var(--muted-foreground)]">{s.when}</span>
              <span class="text-[10px] text-[var(--muted-foreground)]/60">&middot;</span>
              <span class="text-[10px] text-[var(--muted-foreground)]/80 truncate">{s.sector}</span>
            </div>
            <div class="text-[13px] font-semibold text-[var(--heading)] leading-snug whitespace-nowrap">
              {s.title}
            </div>
            <div class="text-[10px] text-[var(--muted-foreground)]/70 mt-0.5">{labels.source} {s.source}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signal-ticker-viewport {
    position: relative;
    overflow: hidden;
    /* Generous vertical padding so card shadows aren't clipped by
       the viewport's overflow:hidden — that clipped shadow edge
       was rendering as a faint horizontal line below the cards. */
    padding-block: 1.75rem;
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
  }

  .signal-ticker-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: signal-ticker-scroll 60s linear infinite;
    will-change: transform;
  }

  .signal-ticker-viewport:hover .signal-ticker-track {
    animation-play-state: paused;
  }

  .signal-pill {
    min-width: 340px;
  }

  @media (min-width: 640px) {
    .signal-pill {
      min-width: 380px;
    }
  }

  @keyframes signal-ticker-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .signal-ticker-track { animation: none; }
  }
</style>
