---
// Fictional companies for demo. Sources are Hooklyne's own signal taxonomy,
// not named outlets, to keep this legally clean.
// `mark` = ID of an inline SVG logo rendered below.
const signals = [
 { type: "Funding", tone: "orange", company: "Acme B.V.", mark: "acme", title: "Raised €12M Series B", source: "Funding tracker", when: "2h ago" },
 { type: "Hiring", tone: "blue", company: "Globex Labs", mark: "globex", title: "Hiring senior AEs across EMEA", source: "Job boards", when: "1d ago" },
 { type: "Leadership", tone: "teal", company: "Initech Nordics", mark: "initech", title: "New CRO announced", source: "Public profiles", when: "3h ago" },
 { type: "Launch", tone: "blue", company: "Umbra Systems", mark: "umbra", title: "Launched a platform revamp", source: "Company blog", when: "5h ago" },
 { type: "Expansion", tone: "teal", company: "Vertex Goods", mark: "vertex", title: "Opened a UK office", source: "Company news", when: "1d ago" },
 { type: "Press", tone: "orange", company: "Pinnacle Retail", mark: "pinnacle", title: "Featured as a fast-growth SME", source: "Press wires", when: "6h ago" },
 { type: "Sector", tone: "blue", company: "NorthPort Freight", mark: "northport",title: "Sector freight rates moved +18%", source: "Industry trackers", when: "2d ago" },
 { type: "Funding", tone: "orange", company: "Lumen Industries", mark: "lumen", title: "Closed a €4.2M seed round", source: "Funding tracker", when: "4h ago" },
 { type: "Hiring", tone: "blue", company: "Cresta Foods", mark: "cresta", title: "Opened 3 AE roles in Benelux", source: "Job boards", when: "7h ago" },
 { type: "Leadership", tone: "teal", company: "Orion Services", mark: "orion", title: "Head of Sales transition", source: "Public profiles", when: "1d ago" },
];

// Each mark is a set of paletted tiles - gradient base + monogram-style inner shape.
// Tweaked to feel like real B2B SME / startup logos without reading as a letter.
const marks: Record<string, { bg: string; fg: string; svg: string }> = {
 acme: {
 bg: "linear-gradient(135deg, #1e3a8a 0%, #2b4fb3 100%)",
 fg: "#fff",
 svg: `<path d="M6 22 L12 6 L18 22 M9 16 H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
 },
 globex: {
 bg: "linear-gradient(135deg, #0f766e 0%, #14b8a6 100%)",
 fg: "#fff",
 svg: `<rect x="5" y="13" width="3.2" height="6" rx="1" fill="currentColor"/><rect x="10.4" y="9" width="3.2" height="10" rx="1" fill="currentColor"/><rect x="15.8" y="5" width="3.2" height="14" rx="1" fill="currentColor"/>`,
 },
 initech: {
 bg: "linear-gradient(135deg, #1a2a52 0%, #344ca3 100%)",
 fg: "#fff",
 svg: `<circle cx="9" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8" fill="none"/><circle cx="15" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8" fill="none"/>`,
 },
 umbra: {
 bg: "linear-gradient(135deg, #0b1220 0%, #1e293b 100%)",
 fg: "#fff",
 svg: `<path d="M5 15 a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/><circle cx="12" cy="15" r="1.4" fill="currentColor"/>`,
 },
 vertex: {
 bg: "linear-gradient(135deg, #064e3b 0%, #0d9488 100%)",
 fg: "#fff",
 svg: `<path d="M5 18 L12 6 L19 18 Z" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linejoin="round"/><path d="M8 14 H16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
 },
 pinnacle: {
 bg: "linear-gradient(135deg, #b4530a 0%, #ff8c42 100%)",
 fg: "#fff",
 svg: `<path d="M4 19 L9 9 L12 14 L15 7 L20 19 Z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/>`,
 },
 northport: {
 bg: "linear-gradient(135deg, #0e2a4a 0%, #344ca3 100%)",
 fg: "#fff",
 svg: `<path d="M7 6 V18 L17 6 V18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
 },
 lumen: {
 bg: "linear-gradient(135deg, #9a3412 0%, #f59e0b 100%)",
 fg: "#fff",
 svg: `<circle cx="12" cy="12" r="4" fill="currentColor"/><path d="M12 3v3 M12 18v3 M3 12h3 M18 12h3 M6 6l2 2 M16 16l2 2 M6 18l2-2 M16 8l2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
 },
 cresta: {
 bg: "linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%)",
 fg: "#fff",
 svg: `<path d="M4 16 Q9 6 12 12 T20 8" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>`,
 },
 orion: {
 bg: "linear-gradient(135deg, #134e4a 0%, #0d9488 100%)",
 fg: "#fff",
 svg: `<circle cx="7" cy="7" r="1.8" fill="currentColor"/><circle cx="17" cy="10" r="1.8" fill="currentColor"/><circle cx="10" cy="17" r="1.8" fill="currentColor"/><path d="M7 7 L17 10 L10 17" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" opacity="0.6"/>`,
 },
};

const toneMap = {
 blue: "var(--hooklyne-blue)",
 teal: "var(--hooklyne-teal)",
 orange: "var(--hooklyne-orange)",
};

// Duplicate for seamless loop
const track = [...signals, ...signals];
---

<section class="pt-10 pb-6 lg:pt-14 lg:pb-8 relative" data-fade>
 <div class="container max-w-6xl mb-6">
 <div class="flex items-center justify-between flex-wrap gap-3">
 <div class="flex items-center gap-3">
 <span class="relative flex size-2">
 <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-70 animate-ping"></span>
 <span class="relative inline-flex size-2 rounded-full bg-emerald-500"></span>
 </span>
 <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)]">Live signal feed</span>
 </div>
 <p class="text-xs text-[var(--muted-foreground)]/80">
 Seven signal categories, scored for your ICP &middot; 14-day lookback.
 <span class="text-[var(--muted-foreground)]/60">&nbsp;Example output &middot; fictional companies.</span>
 </p>
 </div>
 </div>

 <div class="signal-ticker-viewport group">
 <div class="signal-ticker-track">
 {track.map((s, i) => (
 <article
 class="signal-pill shrink-0 flex items-center gap-3 rounded-xl px-4 py-3"
 style={`border: 1px solid var(--border); background: var(--card); box-shadow: var(--shadow-xs);`}
 data-idx={i}
 >
 <span
 class="inline-flex items-center justify-center size-9 rounded-lg shrink-0 relative overflow-hidden"
 style={`background: ${marks[s.mark].bg}; color: ${marks[s.mark].fg}; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08), inset 0 -8px 12px rgba(0,0,0,0.08);`}
 aria-hidden="true"
 >
 <svg width="24" height="24" viewBox="0 0 24 24" fill="none" set:html={marks[s.mark].svg} />
 </span>
 <div class="min-w-0">
 <div class="flex items-center gap-2 mb-0.5">
 <span
 class="text-[9px] font-bold uppercase tracking-[0.18em] px-1.5 py-0.5 rounded"
 style={`background: ${toneMap[s.tone as keyof typeof toneMap]}1a; color: ${toneMap[s.tone as keyof typeof toneMap]};`}
 >
 {s.type}
 </span>
 <span class="text-[10px] font-mono text-[var(--muted-foreground)]">{s.when}</span>
 </div>
 <div class="text-[13px] font-semibold text-[var(--heading)] leading-tight whitespace-nowrap">
 {s.company} &middot; <span class="font-normal text-[var(--muted-foreground)]">{s.title}</span>
 </div>
 <div class="text-[10px] text-[var(--muted-foreground)]/70 mt-0.5">Source: {s.source}</div>
 </div>
 </article>
 ))}
 </div>
 </div>
</section>

<style>
 .signal-ticker-viewport {
 position: relative;
 overflow: hidden;
 padding-block: 0.5rem;
 -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
 mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
 }

 .signal-ticker-track {
 display: flex;
 gap: 0.75rem;
 width: max-content;
 animation: signal-ticker-scroll 60s linear infinite;
 will-change: transform;
 }

 .signal-ticker-viewport:hover .signal-ticker-track {
 animation-play-state: paused;
 }

 .signal-pill {
 min-width: 280px;
 }

 @media (min-width: 640px) {
 .signal-pill {
 min-width: 320px;
 }
 }

 @keyframes signal-ticker-scroll {
 from { transform: translateX(0); }
 to { transform: translateX(-50%); }
 }

 @media (prefers-reduced-motion: reduce) {
 .signal-ticker-track { animation: none; }
 }
</style>
