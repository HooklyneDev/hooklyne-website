---
// Fictional companies used for demo. Sources are category labels matching
// Hooklyne's own signal taxonomy, not named outlets, to keep this legally clean.
const signals = [
  { type: "Funding",    tone: "orange", company: "Acme B.V.",       mono: "A", title: "Raised €12M Series B",                 source: "Funding tracker",     when: "2h ago" },
  { type: "Hiring",     tone: "blue",   company: "Globex Labs",     mono: "G", title: "Hiring senior AEs across EMEA",        source: "Job boards",          when: "1d ago" },
  { type: "Leadership", tone: "teal",   company: "Initech Nordics", mono: "I", title: "New CRO announced",                    source: "Public profiles",     when: "3h ago" },
  { type: "Launch",     tone: "blue",   company: "Umbra Systems",   mono: "U", title: "Launched a platform revamp",           source: "Company blog",        when: "5h ago" },
  { type: "Expansion",  tone: "teal",   company: "Vertex Goods",    mono: "V", title: "Opened a UK office",                   source: "Company news",        when: "1d ago" },
  { type: "Press",      tone: "orange", company: "Pinnacle Retail", mono: "P", title: "Featured as a fast-growth SME",        source: "Press wires",         when: "6h ago" },
  { type: "Sector",     tone: "blue",   company: "NorthPort Freight", mono: "N", title: "Sector freight rates moved +18%",    source: "Industry trackers",   when: "2d ago" },
  { type: "Funding",    tone: "orange", company: "Lumen Industries", mono: "L", title: "Closed a €4.2M seed round",           source: "Funding tracker",     when: "4h ago" },
  { type: "Hiring",     tone: "blue",   company: "Cresta Foods",    mono: "C", title: "Opened 3 AE roles in Benelux",         source: "Job boards",          when: "7h ago" },
  { type: "Leadership", tone: "teal",   company: "Orion Services",  mono: "O", title: "Head of Sales transition",             source: "Public profiles",     when: "1d ago" },
];

const toneMap = {
  blue: "var(--hooklyne-blue)",
  teal: "var(--hooklyne-teal)",
  orange: "var(--hooklyne-orange)",
};

// Duplicate for seamless loop
const track = [...signals, ...signals];
---

<section class="py-10 lg:py-14 relative" data-fade>
  <div class="container max-w-6xl mb-6">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div class="flex items-center gap-3">
        <span class="relative flex size-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-70 animate-ping"></span>
          <span class="relative inline-flex size-2 rounded-full bg-emerald-500"></span>
        </span>
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--muted-foreground)]">Live signal feed</span>
      </div>
      <p class="text-xs text-[var(--muted-foreground)]/80">
        Seven signal categories, scored for your ICP.
        <span class="text-[var(--muted-foreground)]/60">&nbsp;Example output &middot; fictional companies.</span>
      </p>
    </div>
  </div>

  <div class="signal-ticker-viewport group">
    <div class="signal-ticker-track">
      {track.map((s, i) => (
        <article
          class="signal-pill shrink-0 flex items-center gap-3 rounded-xl px-4 py-3"
          style={`border: 1px solid var(--border); background: var(--card); box-shadow: var(--shadow-xs);`}
          data-idx={i}
        >
          <span
            class="inline-flex items-center justify-center size-9 rounded-lg text-sm font-semibold text-white shrink-0"
            style={`background: ${toneMap[s.tone as keyof typeof toneMap]};`}
          >
            {s.mono}
          </span>
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span
                class="text-[9px] font-bold uppercase tracking-[0.18em] px-1.5 py-0.5 rounded"
                style={`background: ${toneMap[s.tone as keyof typeof toneMap]}1a; color: ${toneMap[s.tone as keyof typeof toneMap]};`}
              >
                {s.type}
              </span>
              <span class="text-[10px] font-mono text-[var(--muted-foreground)]">{s.when}</span>
            </div>
            <div class="text-[13px] font-semibold text-[var(--heading)] leading-tight whitespace-nowrap">
              {s.company} &middot; <span class="font-normal text-[var(--muted-foreground)]">{s.title}</span>
            </div>
            <div class="text-[10px] text-[var(--muted-foreground)]/70 mt-0.5">Source: {s.source}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signal-ticker-viewport {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
  }

  .signal-ticker-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: signal-ticker-scroll 60s linear infinite;
    will-change: transform;
  }

  .signal-ticker-viewport:hover .signal-ticker-track {
    animation-play-state: paused;
  }

  .signal-pill {
    min-width: 320px;
  }

  @keyframes signal-ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .signal-ticker-track { animation: none; }
  }
</style>
