---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import {
  SITE_TITLE,
  SITE_TITLE_NL,
  SITE_DESCRIPTION,
  SITE_DESCRIPTION_NL,
  SITE_METADATA,
  SITE_URL,
  altLangPath,
} from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: 'en' | 'nl';
}

const { title, description, image, lang = 'en' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const defaultTitle = lang === 'nl' ? SITE_TITLE_NL : SITE_TITLE;
const defaultDescription = lang === 'nl' ? SITE_DESCRIPTION_NL : SITE_DESCRIPTION;

const finalTitle = title || defaultTitle;
const finalDescription = description || defaultDescription;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.url);

// hreflang alternates for bilingual pages.
// Only emit the NL alternate on pages that have a real NL counterpart.
// For now that's only the root (/ and /nl). Add paths here as translations ship.
const currentPath = Astro.url.pathname;
// Normalise for the build: strip trailing .html and trailing slash.
const normalisedPath = currentPath.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const BILINGUAL_PATHS = new Set(['/', '/nl']);
const hasBilingualPair = BILINGUAL_PATHS.has(normalisedPath);
const enPath = altLangPath(normalisedPath, 'en');
const nlPath = altLangPath(normalisedPath, 'nl');
const enUrl = new URL(enPath, Astro.site).toString();
const nlUrl = new URL(nlPath, Astro.site).toString();
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<!-- Preconnect to Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Load Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

<!-- Preload local fonts -->
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Regular.ttf"
  as="font"
  type="font/ttf"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Bold.ttf"
  as="font"
  type="font/ttf"
  crossorigin="anonymous"
/>

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="robots" content={`${SITE_METADATA.robots.index ? 'index' : 'noindex'}, ${SITE_METADATA.robots.follow ? 'follow' : 'nofollow'}`} />
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="creator" content={SITE_METADATA.creator} />
<meta name="publisher" content={SITE_METADATA.publisher} />

<!-- Theme Script -->
<script is:inline>
  const savedTheme = localStorage.getItem('theme');
  const initialTheme = savedTheme || 'light';
  document.documentElement.classList.toggle('dark', initialTheme === 'dark');
</script>

<!-- Favicon -->
{SITE_METADATA.icons.icon.map((icon) => (
  <link
    rel="icon"
    type={icon.type}
    sizes={icon.sizes}
    href={icon.url}
  />
))}
{SITE_METADATA.icons.apple.map((icon) => (
  <link
    rel="apple-touch-icon"
    sizes={icon.sizes}
    href={icon.url}
  />
))}
{SITE_METADATA.icons.shortcut.map((icon) => (
  <link
    rel="shortcut icon"
    href={icon.url}
  />
))}

<link rel="sitemap" href="/sitemap-index.xml" />
<link
    rel="alternate"
    type="application/rss+xml"
    title="Hooklyne"
    href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical + hreflang alternates -->
<link rel="canonical" href={canonicalURL} />
{hasBilingualPair && (
  <>
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="nl" href={nlUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
  </>
)}

<!-- Primary Meta Tags -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:locale" content={lang === 'nl' ? 'nl_NL' : 'en_GB'} />
<meta property="og:locale:alternate" content={lang === 'nl' ? 'en_GB' : 'nl_NL'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content={SITE_METADATA.openGraph.images[0].width.toString()} />
<meta property="og:image:height" content={SITE_METADATA.openGraph.images[0].height.toString()} />
<meta property="og:image:alt" content={SITE_METADATA.openGraph.images[0].alt} />

<!-- Twitter -->
<meta property="twitter:card" content={SITE_METADATA.twitter.card} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={finalTitle} />
<meta property="twitter:description" content={finalDescription} />
<meta property="twitter:image" content={imageURL} />
<meta property="twitter:creator" content={SITE_METADATA.twitter.creator} />

<!-- Structured data: Organization -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Hooklyne",
  "url": SITE_URL,
  "logo": `${SITE_URL}/logo.svg`,
  "description": "B2B prospect research for Benelux and UK SMEs.",
  "foundingLocation": {
    "@type": "Place",
    "address": { "@type": "PostalAddress", "addressCountry": "NL" }
  },
  "sameAs": ["https://github.com/HooklyneDev"],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "hello@hooklyne.com",
    "contactType": "customer support",
    "areaServed": ["NL", "BE", "GB", "LU"],
    "availableLanguage": ["en", "nl"]
  }
})} />

<!-- Structured data: WebSite -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Hooklyne",
  "url": SITE_URL,
  "description": finalDescription,
  "inLanguage": lang === 'nl' ? ["nl", "en"] : ["en", "nl"],
  "publisher": { "@type": "Organization", "name": "Hooklyne", "url": SITE_URL }
})} />
