---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_METADATA,
  SITE_URL,
} from '../consts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, image, ogType = "website", publishedTime, modifiedTime } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const finalTitle = title || SITE_TITLE;
const finalDescription = description || SITE_DESCRIPTION;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.url);
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<!-- Preload self-hosted DM Sans (WOFF2 - all 4 weights used above the fold) -->
<link rel="preload" href="/fonts/dm-sans/DMSans-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/dm-sans/DMSans-Medium.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/dm-sans/DMSans-SemiBold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/dm-sans/DMSans-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

{/* Preload the hero video poster on home pages so the LCP image is discovered immediately */}
{(Astro.url.pathname === "/" || Astro.url.pathname === "/nl" || Astro.url.pathname === "/nl/") && (
  <link
    rel="preload"
    as="image"
    href="/home/hooklyne-research-layer-b2b-prospecting.webp"
    fetchpriority="high"
    type="image/webp"
  />
)}

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#022f51" />
<meta name="format-detection" content="telephone=no" />
<meta name="robots" content={`${SITE_METADATA.robots.index ? 'index' : 'noindex'}, ${SITE_METADATA.robots.follow ? 'follow' : 'nofollow'}, max-image-preview:large, max-snippet:-1, max-video-preview:-1`} />
<meta name="keywords" content={SITE_METADATA.keywords.join(', ')} />
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="creator" content={SITE_METADATA.creator} />
<meta name="publisher" content={SITE_METADATA.publisher} />

<!-- Theme Script -->
<script is:inline>
  const savedTheme = localStorage.getItem('theme');
  const initialTheme = savedTheme || 'light';
  document.documentElement.classList.toggle('dark', initialTheme === 'dark');
</script>

<!-- Favicon -->
{SITE_METADATA.icons.icon.map((icon) => (
  <link
    rel="icon"
    type={icon.type}
    sizes={icon.sizes}
    href={icon.url}
  />
))}
{SITE_METADATA.icons.apple.map((icon) => (
  <link
    rel="apple-touch-icon"
    sizes={icon.sizes}
    href={icon.url}
  />
))}
{SITE_METADATA.icons.shortcut.map((icon) => (
  <link
    rel="shortcut icon"
    href={icon.url}
  />
))}

<link rel="sitemap" href="/sitemap-index.xml" />
<link
    rel="alternate"
    type="application/rss+xml"
    title="Hooklyne"
    href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang: tell Google which pages are NL alternates of EN.
     Only emit for pages that have a real NL counterpart. -->
{(() => {
  const path = Astro.url.pathname.replace(/\/$/, "") || "/";
  const isNL = path === "/nl" || path.startsWith("/nl/");
  // Resolve mapped slugs (e.g. /apollo-alternative <-> /nl/apollo-alternatief)
  // before falling back to the simple /nl prefix scheme.
  const SLUG_EN_TO_NL = {
    "/about": "/nl/over-ons",
    "/how-it-works": "/nl/hoe-het-werkt",
    "/pricing": "/nl/prijzen",
    "/apollo-alternative": "/nl/apollo-alternatief",
    "/cognism-alternative": "/nl/cognism-alternatief",
    "/lusha-alternative": "/nl/lusha-alternatief",
    "/gdpr-prospecting": "/nl/avg-prospecting",
    "/compare": "/nl/vergelijken",
    "/logistics-prospecting": "/nl/logistiek-prospecting",
    "/agency-prospecting": "/nl/bureau-prospecting",
    "/industrial-prospecting": "/nl/industrie-prospecting",
  };
  const SLUG_NL_TO_EN = Object.fromEntries(
    Object.entries(SLUG_EN_TO_NL).map(([en, nl]) => [nl, en])
  );
  const enPath = isNL
    ? (SLUG_NL_TO_EN[path] ?? (path.replace(/^\/nl(\/|$)/, "/").replace(/\/$/, "") || "/"))
    : path;
  const nlPath = isNL
    ? path
    : (SLUG_EN_TO_NL[path] ?? (path === "/" ? "/nl" : `/nl${path}`));
  const NL_AVAILABLE = new Set([
    "/nl",
    "/nl/faq",
    "/nl/prijzen",
    "/nl/hoe-het-werkt",
    "/nl/product",
    "/nl/over-ons",
    "/nl/contact",
    "/nl/privacy",
    "/nl/cookies",
    "/nl/disclaimer",
    "/nl/resources",
    "/nl/resources/support",
    "/nl/blog",
    "/nl/apollo-alternatief",
    "/nl/cognism-alternatief",
    "/nl/lusha-alternatief",
    "/nl/avg-prospecting",
    "/nl/vergelijken",
    "/nl/guides",
    "/nl/compliance",
    "/nl/industries",
    "/nl/saas-prospecting",
    "/nl/logistiek-prospecting",
    "/nl/bureau-prospecting",
    "/nl/fintech-prospecting",
    "/nl/industrie-prospecting",
  ]);
  if (!NL_AVAILABLE.has(nlPath)) return null;
  const enUrl = new URL(enPath, Astro.site).toString();
  const nlUrl = new URL(nlPath, Astro.site).toString();
  return [
    <link rel="alternate" hreflang="en" href={enUrl} />,
    <link rel="alternate" hreflang="nl" href={nlUrl} />,
    <link rel="alternate" hreflang="x-default" href={enUrl} />,
  ];
})()}

<!-- Primary Meta Tags -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:locale" content="en_GB" />
<meta property="og:locale:alternate" content="nl_NL" />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content={SITE_METADATA.openGraph.images[0].width.toString()} />
<meta property="og:image:height" content={SITE_METADATA.openGraph.images[0].height.toString()} />
<meta property="og:image:alt" content={image ? finalTitle : SITE_METADATA.openGraph.images[0].alt} />
{ogType === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}

<!-- Twitter -->
<meta name="twitter:card" content={SITE_METADATA.twitter.card} />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={image ? finalTitle : SITE_METADATA.openGraph.images[0].alt} />

<!-- Structured data: Organization -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Hooklyne",
  "url": SITE_URL,
  "logo": `${SITE_URL}/logo.svg`,
  "description": "B2B prospect research for Dutch and UK SMEs, with EMEA coverage.",
  "foundingLocation": {
    "@type": "Place",
    "address": { "@type": "PostalAddress", "addressCountry": "NL" }
  },
  "sameAs": [
    "https://www.linkedin.com/company/hooklyne",
    "https://x.com/Hooklyne",
    "https://github.com/HooklyneDev"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "contact@hooklyne.com",
    "contactType": "customer support",
    "areaServed": ["NL", "BE", "GB", "LU"],
    "availableLanguage": ["en", "nl"]
  }
})} />

<!-- Structured data: WebSite -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Hooklyne",
  "url": SITE_URL,
  "description": finalDescription,
  "inLanguage": ["en"],
  "publisher": { "@type": "Organization", "name": "Hooklyne", "url": SITE_URL }
})} />
