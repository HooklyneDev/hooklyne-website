---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { PortalShot } from '@/components/portal-shot';
import { FinalCTA } from '@/components/blocks/final-cta';

// Section 2 - Prospect package blocks
const packageBlocks = [
  {
    tag: "THE COMPANY",
    title: "Why it fits your ICP",
    body: "What they do, in plain language. What's changed recently and why it's worth an hour of your time. Not a scrape of the homepage - live web research pulled at the moment you need it.",
    icon: "building",
  },
  {
    tag: "THE DECISION-MAKER",
    title: "Verified across 20+ providers",
    body: "Name, role, verified business email, direct number where available. Checked across 20+ data providers with regional selection, then run through four layers of email verification. If we can't verify, we don't ship.",
    icon: "shield",
  },
  {
    tag: "THE HOOK",
    title: "A live reason to reach out",
    body: "A live buying signal from the last 14 days. Funding, hire, product launch, press mention, leadership change, expansion. Scored twice - once for importance to the prospect, once for relevance to what you sell.",
    icon: "radar",
  },
  {
    tag: "THE MESSAGE",
    title: "Drafted in your rep's voice",
    body: "A first email and a LinkedIn invite, anchored to the signal. Every message goes through hook, angle, voice, and quality check before it's delivered. Ready to send, not ready to rewrite.",
    icon: "edit",
  },
];

// Section 5 - Prospecting modes
const prospectingModes = [
  {
    n: "01",
    title: "Find me companies",
    body: "Describe your ideal customer in plain language - the industry, the size, the situation, the signals you'd want to see. Semantic search runs across billions of web pages and returns ranked companies that match the meaning of what you described, regardless of how they label themselves. Each comes with three decision-makers surfaced.",
  },
  {
    n: "02",
    title: "I know the company",
    body: "Already have a target in mind? Enter the company name and domain. The system finds three matched decision-makers and surfaces the best angle for each.",
  },
  {
    n: "03",
    title: "I know who to reach",
    body: "Paste a name or LinkedIn URL. The system verifies the email, pulls fresh context on the company, and generates ready-to-send outreach anchored to what's currently happening.",
  },
  {
    n: "04",
    title: "Find similar companies",
    soon: true,
    body: "Upload your best customers. Get lookalike companies that share the meaningful traits, not just the industry code. Semantic matching finds patterns in who you're already winning with, and surfaces the next 50 companies that fit the same shape.",
  },
];

// Section 7 - Signal sources
const signalSources = [
  "Funding rounds",
  "Leadership changes",
  "Hiring sprees",
  "Product launches",
  "Press mentions",
  "Expansions",
  "Sector-specific news",
];

// Section 10 - Profile tabs
const profileTabs = [
  { n: "1", title: "Company and value prop", body: "What you do, what makes you different, who your ideal customer is, which regions you sell into." },
  { n: "2", title: "Voice and tone", body: "How your rep communicates. Tone keywords, style notes, signature elements." },
  { n: "3", title: "Example emails", body: "Up to five past emails that capture your rep's voice. One is required, more is better. This is what we calibrate against." },
  { n: "4", title: "Products and services", body: "The full list with descriptions, so messages can reference the right product for the right signal." },
  { n: "5", title: "Rules and context", body: "Anything off-limits, anything extra we should know. Do-not-mention rules. Specific tone preferences by segment." },
];
---

<DefaultLayout
  title="Product - Hooklyne"
  description="Inside Hooklyne: verified prospect packages, signals, meeting prep briefs, and sector intelligence - all in one portal. See what you get."
>
  <Background>
    <!-- Section 1 - Hero -->
    <section class="pt-28 pb-12 lg:pt-44 lg:pb-16">
      <div class="container max-w-4xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4" data-fade>Product</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-6" data-fade data-delay="1">
          Every prospect, fully packaged.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed" data-fade data-delay="2">
          A name is not a prospect. A prospect is a verified decision-maker, a live reason to reach out, and a first message that reads like your rep wrote it. That's what Hooklyne ships - every time.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4" data-fade data-delay="3">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 h-11 px-6 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine group"
            style="background: var(--hooklyne-navy)"
          >
            Start your free pilot
            <svg class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/how-it-works"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--muted-foreground)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See how it works
            <svg class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Hero shot -->
        <div class="mt-16 lg:mt-20" data-fade data-delay="4">
          <PortalShot
            client:load
            label="Prospect package card"
            describe="Full-width screenshot: one prospect card opened in the portal. Company header with fit score, decision-maker with verified email badge, signal pill (e.g. 'Series B - 4d ago'), draft email in the right pane, LinkedIn invite collapsed below. This single shot carries the product page hero."
            ratio="16/9"
            overlays={[
              { x: 18, y: 22, tag: "SIGNAL", title: "Series B, €12M", body: "Raised 4 days ago", tone: "orange", pulse: true },
              { x: 82, y: 32, tag: "CONTACT", title: "Verified deliverable", body: "Checked across 20+ providers", tone: "teal" },
              { x: 74, y: 74, tag: "VOICE", title: "Drafted in Tim's voice", body: "4 reasoning passes", tone: "blue" },
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Section 2 - Prospect package -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-2xl mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">The package</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            What's in a prospect package
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Every company has passed your ICP filter. Every contact has been verified across 20+ providers. Every message has been reasoned through multiple passes before it reaches you. Here's what arrives in the portal.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {packageBlocks.map((b) => (
            <div class="rounded-2xl bg-[var(--card)] p-6 flex flex-col" style="box-shadow: var(--shadow-xs)">
              <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)]">{b.tag}</p>
                <div class="flex items-center justify-center size-9 rounded-lg" style="background: rgba(52,76,163,0.08)">
                  {b.icon === "building" && <svg class="size-4 text-[var(--hooklyne-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>}
                  {b.icon === "shield" && <svg class="size-4 text-[var(--hooklyne-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>}
                  {b.icon === "radar" && <svg class="size-4 text-[var(--hooklyne-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19.07 4.93A10 10 0 0 0 6.99 3.34"/><path d="M4 6h.01"/><path d="M2.29 9.62A10 10 0 1 0 21.31 8.35"/><path d="M16.24 7.76A6 6 0 1 0 17.92 12"/><path d="M12 18h.01"/><path d="M17.99 11.66A6 6 0 0 1 15.77 16.67"/><circle cx="12" cy="12" r="2"/><path d="m13.41 10.59 5.66-5.66"/></svg>}
                  {b.icon === "edit" && <svg class="size-4 text-[var(--hooklyne-blue)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>}
                </div>
              </div>
              <h3 class="text-lg font-semibold text-[var(--heading)] mb-2 leading-tight">{b.title}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{b.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3 - Portal at a glance -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">The portal</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Review and send in under 60 seconds
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            The portal is built for one moment - getting from "this prospect arrived" to "this message is sent" as fast as possible. Every feature exists to serve that moment.
          </p>
        </div>

        <PortalShot
          client:load
          label="Portal dashboard, full width"
          describe="Full-width dashboard screenshot: left sidebar nav (Dashboard / Prospecting / My Leads / Signals / Intelligence / Meeting Prep / Profile), 'Daily focus' card top-centre with 2 priority actions, Signal heat top-5 list with rising/cooling arrows, credit meter top-right."
          ratio="16/9"
          overlays={[
            { x: 22, y: 20, tag: "DAILY FOCUS", title: "2 actions ready", body: "Prioritised for you, not your inbox", tone: "orange", pulse: true },
            { x: 80, y: 30, tag: "CREDITS", title: "312 / 400 remaining", body: "Resets in 11 days", tone: "blue" },
            { x: 70, y: 74, tag: "SIGNAL HEAT", title: "Top 5, ranked", body: "3 rising, 1 stable, 1 cooling", tone: "teal" },
          ]}
        />

        <ul class="grid md:grid-cols-2 gap-3 mt-12 max-w-4xl mx-auto">
          {[
            "Every prospect reviewable on one screen - no digging through tabs",
            "Edit the message in place, or accept it as drafted",
            "Copy to your sequencing tool, or send from your own inbox",
            "Dutch or English, toggled per prospect",
            "Your ICP, your voice, your signals - configured once, tuned over time",
          ].map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-[var(--foreground)]">
              <svg class="size-4 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Section 4 - Dashboard -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Dashboard</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
              Start every day knowing what to do
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-8">
              The dashboard is the first thing you see. It's not a blank wall of data - it tells you what to act on today.
            </p>

            <div class="space-y-5">
              {[
                { t: "Daily focus", b: "1-2 priority actions ranked for you, with sales angle and urgency level shown. Start here, not in your inbox." },
                { t: "Signal heat", b: "Your top 5 hottest tracked prospects, ranked by heat score. Each shows whether it's rising, stable, or cooling." },
                { t: "Market intelligence", b: "Top 6 news items from your sector, ranked for a salesperson who needs to know what to say in the next meeting." },
                { t: "Pipeline stats", b: "Active leads, ready leads, completed briefs, hottest prospect - at a glance." },
                { t: "Credit usage", b: "What you've used, what's left, when it resets." },
                { t: "Recent activity", b: "Latest leads added, latest briefs completed, so you always know where you left off." },
              ].map((f) => (
                <div class="flex gap-3">
                  <div class="size-1.5 rounded-full bg-[var(--hooklyne-orange)] mt-2 shrink-0"></div>
                  <div>
                    <p class="text-sm font-semibold text-[var(--heading)]">{f.t}</p>
                    <p class="text-sm text-[var(--muted-foreground)] mt-1 leading-relaxed">{f.b}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:sticky lg:top-28">
            <PortalShot
              client:load
              label="Dashboard detail"
              describe="Close-up of the Daily focus + Signal heat cards. Top card shows 2 actions with priority dots and sales angles. Right card lists top 5 hottest prospects with heat score bars and up/down trend chips."
              ratio="3/2"
              overlays={[
                { x: 28, y: 18, tag: "PRIORITY 1", title: "High - act today", tone: "orange", pulse: true },
                { x: 75, y: 58, tag: "HEAT", title: "Rising", body: "+12 since Friday", tone: "teal" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5 - Prospecting -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Prospecting</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Four ways to find your next customer
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Different starting points call for different tools. Whether you're describing an ideal target from scratch or chasing a specific company you saw in the news, there's a direct way in.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {prospectingModes.map((m) => (
            <div class="rounded-2xl bg-[var(--card)] p-6 flex flex-col" style="box-shadow: var(--shadow-xs)">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold tracking-widest text-[var(--hooklyne-blue)]/60">{m.n}</span>
                <h3 class="text-base font-semibold text-[var(--heading)]">{m.title}</h3>
                {m.soon && (
                  <span class="text-[10px] font-semibold uppercase tracking-widest px-2 py-0.5 rounded-full" style="background: rgba(255,140,66,0.12); color: var(--hooklyne-orange)">Soon</span>
                )}
              </div>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{m.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 rounded-2xl p-6 lg:p-8" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-2">Search history</p>
          <h3 class="text-lg font-semibold text-[var(--heading)] mb-2">Everything you find stays searchable</h3>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed max-w-3xl">
            Every company ever surfaced through Prospecting lives in your Search History. Filter by status (Found, Selected, Dismissed, Submitted), country, company size, or date. Ship any of them back into the flow, single or bulk, whenever the timing is right.
          </p>
        </div>
      </div>
    </section>

    <!-- Section 6 - My Leads -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="lg:order-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">My Leads</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
              Your pipeline, properly tracked
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6">
              Once you submit a prospect, it lives in My Leads. Every state tracked, every step visible, always one click away from your next action.
            </p>
            <ul class="space-y-3">
              {[
                "Full list: company, role, domain, status, date added, contact details",
                "Status tracking: Ready, Processing, Pending, Tracking, Rejected, Approved - colour-coded so state is visible at a glance",
                "Expand any row for full prospect details, brief links, contact info, and outreach angle",
                "Filter, search, sort, paginate - pipeline hygiene without a spreadsheet",
                "One-click jump to Meeting Prep, pre-filled with that prospect's data",
              ].map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--foreground)]">
                  <svg class="size-4 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="lg:order-1">
            <PortalShot
              client:load
              label="My Leads, expanded row view"
              describe="Screenshot: data table of prospects with columns for company, role, domain, status pill, date added. One row expanded in place to show the full prospect drawer - brief link, contact details, outreach angle preview."
              ratio="3/2"
              overlays={[
                { x: 20, y: 28, tag: "STATUS", title: "Ready", tone: "teal" },
                { x: 76, y: 68, tag: "JUMP TO", title: "Meeting Prep", body: "Pre-filled from this row", tone: "blue" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 7 - Signals -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Signals</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Signals that actually mean something
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Most "signal" tools fire on everything - every hire, every post, every press release. That's noise. Every signal is scored two ways: relevance to the prospect's business, and relevance to what you sell. Only signals that pass both checks reach you.
          </p>
        </div>

        <PortalShot
          client:load
          label="Signals feed"
          describe="Screenshot: Signals feed grouped by company. Each group header shows the company + fit score. Under it, 2-3 signal rows with type icon, headline, date, and a relevance score bar. Right sidebar shows filters (type, recency) and grouped counts."
          ratio="16/9"
          overlays={[
            { x: 22, y: 24, tag: "FUNDING", title: "Scored 9/10", body: "Live 2 hours ago", tone: "orange", pulse: true },
            { x: 78, y: 30, tag: "FILTER", title: "7 signal types", tone: "blue" },
            { x: 72, y: 78, tag: "ACTIONS", title: "Move to leads", body: "Or dismiss / keep tracking", tone: "teal" },
          ]}
        />

        <div class="mt-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4 text-center">What we watch</p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            {signalSources.map((s) => (
              <span class="text-sm font-medium px-4 py-2 rounded-full" style="background: var(--card); border: 1px solid var(--border); color: var(--foreground)">{s}</span>
            ))}
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-5 mt-12">
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Continuous, not weekly.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Signals are monitored in real time. When something moves, you know fast enough to act on it - not next Monday.</p>
          </div>
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Not just news polling.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Profile and company pages are monitored for changes too. A new role on a team page, a product line quietly launched, a location expansion that hasn't made the press yet.</p>
          </div>
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Alerts come to you.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Grouped by company, ranked by heat, filterable by type and recency. From the feed: move to leads, dismiss, or keep tracking.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 8 - Intelligence -->
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-2xl mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Intelligence</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Turn sector news into real outreach
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Intelligence has two jobs: keep you informed about what's moving in your market, and make sure you act on it when a story actually matches a prospect in your pipeline.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <div class="rounded-2xl p-7" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-2">Sector news</p>
            <h3 class="text-lg font-semibold text-[var(--heading)] mb-2">What's moving in your market</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              Weekly news curated for your sector, ranked by relevance. Filter by region. Browse previous weeks. Written for a salesperson who needs to know what to say in their next meeting - not a market analyst writing a report.
            </p>
          </div>
          <div class="rounded-2xl p-7" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-2">Match to prospects</p>
            <h3 class="text-lg font-semibold text-[var(--heading)] mb-2">News matched to your leads</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              Select up to 25 of your own leads. For each, the most relevant news item is matched with a short "why it matters" paragraph and a ready-to-use outreach angle. One click to copy. One click to send.
            </p>
          </div>
        </div>

