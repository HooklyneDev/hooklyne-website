---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { PortalShot } from '@/components/portal-shot';

const packageBlocks = [
  {
    step: "01",
    tag: "The company",
    title: "A fit. Not a guess.",
    body: "What they do, what just changed, why it's worth your time. Fresh from the live web, not a scraped homepage.",
  },
  {
    step: "02",
    tag: "The decision-maker",
    title: "Verified, or not shipped.",
    body: "Name, role, email, phone where we have it. Checked across 20+ providers, four deliverability layers. If it's not clean, it doesn't land.",
  },
  {
    step: "03",
    tag: "The hook",
    title: "A real reason to write today.",
    body: "A live signal from the last 14 days. Scored for their business and for what you sell. Only the real ones come through.",
  },
  {
    step: "04",
    tag: "The message",
    title: "In your voice. Ready to send.",
    body: "An email and a LinkedIn invite, anchored to the signal. Drafted across four reasoning passes. Nothing templated.",
  },
];

const prospectingModes = [
  {
    n: "01",
    title: "Find me companies",
    body: "Describe your ICP. Get ranked fits with three decision-makers each.",
  },
  {
    n: "02",
    title: "I know the company",
    body: "Paste the domain. Get three matched decision-makers and the angle for each.",
  },
  {
    n: "03",
    title: "I know who to reach",
    body: "Paste a name or LinkedIn URL. Get verified email, fresh context, draft outreach.",
  },
  {
    n: "04",
    title: "Find similar",
    soon: true,
    body: "Upload your best customers. Get the next 50 that share the shape, not the label.",
  },
];

const signalSources = [
  "Funding",
  "Leadership",
  "Hiring",
  "Launches",
  "Press",
  "Expansion",
  "Sector news",
];

const profileTabs = [
  { n: "1", title: "Company", body: "What you do, who you sell to, where." },
  { n: "2", title: "Voice", body: "Tone, cadence, signature moves." },
  { n: "3", title: "Examples", body: "Up to five past emails. The calibration fuel." },
  { n: "4", title: "Products", body: "So the right product meets the right signal." },
  { n: "5", title: "Rules", body: "Off-limits topics. Segment-specific tone. House style." },
];
---

<DefaultLayout
  title="Product - Hooklyne"
  description="Verified prospect packages, live signals, meeting prep briefs, and sector intelligence. All in one portal."
  ctaVariant="product"
>
  <Background>
    <section class="pt-28 pb-12 lg:pt-44 lg:pb-16 relative">
      <HeroGlow client:load />
      <div class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4" data-fade>Product</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-6" data-fade data-delay="1">
          Every prospect. Fully packaged.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-xl mx-auto leading-relaxed" data-fade data-delay="2">
          A verified contact, a live reason to reach out, and a first message in your voice. Every time.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4" data-fade data-delay="3">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 h-11 px-6 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine group"
            style="background: var(--hooklyne-navy)"
          >
            Start your free pilot
            <svg class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/how-it-works"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--muted-foreground)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See how it works
            <svg class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="mt-16 lg:mt-20" data-fade data-delay="4">
          <PortalShot
            client:load
            label="Prospect package"
            describe="The full card: company header + fit score, decision-maker + verified email badge, live signal pill, draft email in the right pane, LinkedIn invite below."
            ratio="16/9"
            overlays={[
              { x: 18, y: 22, tag: "SIGNAL", title: "Series B, €12M", body: "4 days ago", tone: "orange", pulse: true },
              { x: 82, y: 32, tag: "CONTACT", title: "Verified deliverable", tone: "teal" },
              { x: 74, y: 74, tag: "VOICE", title: "In your cadence", body: "4 reasoning passes", tone: "blue" },
            ]}
          />
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-2xl mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">The package</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Four parts. One screen. Ready to send.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Company, contact, hook, message. Everything verified before it reaches you.
          </p>
        </div>

        <div class="rounded-3xl overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
          {packageBlocks.map((b, i) => (
            <div class={`grid md:grid-cols-[auto_1fr] gap-6 md:gap-10 p-7 md:p-9 ${i < packageBlocks.length - 1 ? 'border-b border-[var(--border)]' : ''}`}>
              <div class="flex md:block items-baseline gap-3">
                <span class="text-4xl md:text-5xl font-semibold tracking-tight text-[var(--hooklyne-blue)]/20 tabular-nums">{b.step}</span>
                <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--muted-foreground)] md:hidden">{b.tag}</span>
              </div>
              <div>
                <span class="hidden md:inline-block text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--muted-foreground)] mb-2">{b.tag}</span>
                <h3 class="text-xl md:text-2xl font-semibold text-[var(--heading)] mb-2 leading-tight tracking-tight">{b.title}</h3>
                <p class="text-base text-[var(--muted-foreground)] leading-relaxed max-w-2xl">{b.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">The portal</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Open it. Send it. Close it.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Built for one moment: prospect in, message out. Under a minute.
          </p>
        </div>

        <PortalShot
          client:load
          label="Portal dashboard"
          describe="Full dashboard: sidebar nav, Daily focus card top-centre, Signal heat top-5 list, pipeline stats top-right."
          ratio="16/9"
          overlays={[
            { x: 22, y: 20, tag: "DAILY FOCUS", title: "2 actions ready", body: "Ranked, not dumped", tone: "orange", pulse: true },
            { x: 80, y: 30, tag: "CREDITS", title: "312 / 400", body: "Resets in 11 days", tone: "blue" },
            { x: 70, y: 74, tag: "SIGNAL HEAT", title: "Top 5 prospects", body: "3 rising · 1 cooling", tone: "teal" },
          ]}
        />

        <ul class="grid md:grid-cols-2 gap-3 mt-12 max-w-4xl mx-auto">
          {[
            "Every prospect on one screen. No digging.",
            "Edit in place, or accept as drafted.",
            "Send from your inbox, or paste into your sequencer.",
            "Dutch or English, picked automatically from the prospect.",
            "Tuned once. Sharper every week.",
          ].map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-[var(--foreground)]">
              <svg class="size-4 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Dashboard</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
              Start the day knowing where to go.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-8">
              Not a blank wall of numbers. A clear instruction for today.
            </p>

            <div class="space-y-4">
              {[
                { t: "Daily focus", b: "Two priority actions, ranked and angled. Start here." },
                { t: "Signal heat", b: "Your hottest five prospects. Rising, stable, cooling." },
                { t: "Market intel", b: "Six headlines you can use in today's meeting." },
                { t: "Pipeline stats", b: "Active, ready, completed, hottest. At a glance." },
                { t: "Recent activity", b: "Where you left off. So you don't lose momentum." },
              ].map((f) => (
                <div class="flex gap-3">
                  <div class="size-1.5 rounded-full bg-[var(--hooklyne-orange)] mt-2 shrink-0"></div>
                  <div>
                    <p class="text-sm font-semibold text-[var(--heading)]">{f.t}</p>
                    <p class="text-sm text-[var(--muted-foreground)] mt-0.5 leading-relaxed">{f.b}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:sticky lg:top-28">
            <PortalShot
              client:load
              label="Dashboard detail"
              describe="Close-up of Daily focus + Signal heat cards with priority dots, angles, and heat bars."
              ratio="3/2"
              overlays={[
                { x: 28, y: 18, tag: "PRIORITY 1", title: "Act today", tone: "orange", pulse: true },
                { x: 75, y: 58, tag: "HEAT", title: "Rising", body: "+12 since Friday", tone: "teal" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Prospecting</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Four ways in. Same package out.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Start from an ICP, a domain, a name, or your best customers. Every path lands on a ready-to-send card.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {prospectingModes.map((m) => (
            <div class="rounded-2xl bg-[var(--card)] p-6 flex flex-col" style="box-shadow: var(--shadow-xs)">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold tracking-widest text-[var(--hooklyne-blue)]/60">{m.n}</span>
                <h3 class="text-base font-semibold text-[var(--heading)]">{m.title}</h3>
                {m.soon && (
                  <span class="text-[10px] font-semibold uppercase tracking-widest px-2 py-0.5 rounded-full" style="background: rgba(255,140,66,0.12); color: var(--hooklyne-orange)">Soon</span>
                )}
              </div>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{m.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="lg:order-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">My Leads</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
              Your pipeline. Without the spreadsheet.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6">
              Every prospect tracked, every state visible, one click from your next action.
            </p>
            <ul class="space-y-3">
              {[
                "Company, role, domain, status, date - all in one row.",
                "Colour-coded status: Ready, Processing, Tracking, Approved.",
                "Expand for brief, contact, outreach angle.",
                "Filter and sort. No CSV needed.",
                "One click to Meeting Prep, pre-filled.",
              ].map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--foreground)]">
                  <svg class="size-4 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="lg:order-1">
            <PortalShot
              client:load
              label="My Leads"
              describe="Table of prospects with columns and one expanded row showing brief link + contact details."
              ratio="3/2"
              overlays={[
                { x: 20, y: 28, tag: "STATUS", title: "Ready", tone: "teal" },
                { x: 76, y: 68, tag: "JUMP TO", title: "Meeting Prep", body: "Pre-filled", tone: "blue" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Signals</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            The right moment. Not every moment.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Every signal scored twice: matters to them, matters to you. Only the ones that pass both land in your inbox.
          </p>
        </div>

        <PortalShot
          client:load
          label="Signals feed"
          describe="Feed grouped by company, with twin scores and filter sidebar."
          ratio="16/9"
          overlays={[
            { x: 22, y: 24, tag: "FUNDING", title: "9/10 fit", body: "2 hours ago", tone: "orange", pulse: true },
            { x: 78, y: 30, tag: "FILTERS", title: "7 signal types", tone: "blue" },
            { x: 72, y: 78, tag: "ACTIONS", title: "Move · Dismiss · Track", tone: "teal" },
          ]}
        />

        <div class="mt-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4 text-center">What we watch</p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            {signalSources.map((s) => (
              <span class="text-sm font-medium px-4 py-2 rounded-full" style="background: var(--card); border: 1px solid var(--border); color: var(--foreground)">{s}</span>
            ))}
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-5 mt-12">
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Live. Not weekly.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">When something moves, you know. Not next Monday.</p>
          </div>
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Deeper than news.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Company pages watched directly. New roles, quiet launches, careers-page expansions - before the press catches up.</p>
          </div>
          <div class="rounded-2xl p-6" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-sm font-semibold text-[var(--heading)] mb-2">Signal, not noise.</p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Grouped by company, ranked by heat. Move to leads, dismiss, keep tracking.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-2xl mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Intelligence</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Read the news. Then act on it.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Sector stories curated for your market, matched to prospects in your pipeline.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <div class="rounded-2xl p-7" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-2">Sector news</p>
            <h3 class="text-lg font-semibold text-[var(--heading)] mb-2">What's moving this week.</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              Curated for your sector. Ranked for relevance. Written for a salesperson, not an analyst.
            </p>
          </div>
          <div class="rounded-2xl p-7" style="background: var(--card); box-shadow: var(--shadow-xs)">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-2">Match to leads</p>
            <h3 class="text-lg font-semibold text-[var(--heading)] mb-2">News with a name on it.</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              Pick up to 25 leads. Each one gets the most relevant story with a ready outreach angle. Copy, send.
            </p>
          </div>
        </div>

        <p class="text-center text-sm italic text-[var(--muted-foreground)] mt-8">
          The gap between reading news and doing something with it.
        </p>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Meeting Prep</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
              Walk in knowing more than they expected.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6">
              Full brief in about five minutes. Live sources. Every fact traceable.
            </p>

            <div class="space-y-5">
              <div>
                <p class="text-sm font-semibold text-[var(--heading)] mb-2">How to run it</p>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">Fill company, contact, meeting type. Hit generate. Brief in your inbox in ~5 minutes.</p>
              </div>

              <div>
                <p class="text-sm font-semibold text-[var(--heading)] mb-2">Meeting types</p>
                <div class="flex flex-wrap gap-1.5">
                  {["Cold outreach", "Warm intro", "Inbound", "Follow-up", "Conference", "Post-conference", "Pitch"].map((t) => (
                    <span class="text-xs px-2.5 py-1 rounded-full" style="background: rgba(52,76,163,0.06); color: var(--hooklyne-blue)">{t}</span>
                  ))}
                </div>
              </div>

              <div>
                <p class="text-sm font-semibold text-[var(--heading)] mb-2">In the brief</p>
                <ul class="space-y-2">
                  {[
                    "Recent moves: news, hires, funding, launches",
                    "What the contact said publicly in the last 90 days",
                    "How their business actually works",
                    "Angles your pitch should lean on",
                    "Every claim sourced and clickable",
                  ].map((b) => (
                    <li class="flex items-start gap-2.5 text-sm text-[var(--muted-foreground)]">
                      <svg class="size-3.5 shrink-0 mt-1 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <div class="lg:sticky lg:top-28">
            <PortalShot
              client:load
              label="Meeting brief"
              describe="Brief rendered as a document: summary, recent moves, contact context, pitch angles, citations on the margin."
              ratio="3/2"
              overlays={[
                { x: 22, y: 20, tag: "READY", title: "Generated in 4m 38s", tone: "teal" },
                { x: 78, y: 58, tag: "SOURCED", title: "12 citations", body: "Every claim clickable", tone: "blue" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Sender Profile</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Set it once. Sound like you forever.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            The five tabs that turn a generic draft into something your rep would actually send.
          </p>
        </div>

        <div class="rounded-2xl overflow-hidden mb-10" style="background: var(--card); box-shadow: var(--shadow-md)">
          <div class="flex border-b border-[var(--border)] overflow-x-auto">
            {profileTabs.map((t, i) => (
              <div class:list={[
                "flex items-center gap-2 px-5 py-3 text-xs font-semibold whitespace-nowrap",
                i === 0 ? "text-[var(--hooklyne-blue)] border-b-2 border-[var(--hooklyne-blue)]" : "text-[var(--muted-foreground)]"
              ]}>
                <span class="size-5 rounded-md flex items-center justify-center text-[10px]" style={i === 0 ? "background: rgba(52,76,163,0.10)" : "background: var(--background)"}>{t.n}</span>
                {t.title}
              </div>
            ))}
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 p-7">
            {profileTabs.map((t) => (
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-[var(--hooklyne-blue)]/60 mb-2">Tab {t.n}</p>
                <p class="text-sm font-semibold text-[var(--heading)] mb-1.5">{t.title}</p>
                <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">{t.body}</p>
              </div>
            ))}
          </div>
        </div>

        <p class="text-center text-sm italic text-[var(--muted-foreground)] max-w-2xl mx-auto">
          A completion bar keeps you honest. Fill every tab once. Every message inherits your voice from that moment.
        </p>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-4xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Bilingual</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-tight">
          Native Dutch. Natural English.
        </h2>
        <p class="text-base text-[var(--muted-foreground)] leading-relaxed max-w-xl mx-auto">
          Not translated. Written. Language is picked automatically from the company domain and the contact's location, then locked for that prospect. Dutch-to-Dutch reads differently than Dutch-to-UK, and the output knows it.
        </p>
      </div>
    </section>

  </Background>
</DefaultLayout>
