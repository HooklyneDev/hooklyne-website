---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Fintech and financial services prospecting", path: "/fintech-prospecting" },
]);

const pains = [
  "A CCO at a regulated firm asking 'how did you get my details?' is not a small problem.",
  "Fintech buyers have a shorter fuse for irrelevance than almost any other sector.",
  "Regulatory milestones are your best timing signals - and you're tracking them manually.",
  "The CFO changed. You found out when the email bounced.",
];

const signals = [
  {
    title: "Regulatory authorisations and compliance milestones.",
    body: "FCA authorisation, DNB registration, PSD2 compliance, DORA readiness deadlines, NIS2 - each creates a procurement window. A fintech company that just received regulatory approval is in rapid scale mode with fresh budget and a mandate to build infrastructure. One approaching a compliance deadline is a motivated buyer with a date. Both are higher-signal than 'they match the ICP' - because they indicate a decision that has already been made to spend, not just a company that could theoretically benefit from your product.",
  },
  {
    title: "Funding rounds and product launches.",
    body: "Series A through C in fintech typically come with aggressive hiring plans, new market entry, and infrastructure build-out timelines set by board expectations. A product launch - a new payment rail, a new lending product, an embedded finance feature - usually brings fresh supplier decisions alongside it. The buying that follows a product launch is often compressed: teams move quickly when there's a commercial deadline attached to a new capability. The window is short and the shortlist forms fast.",
  },
  {
    title: "Compliance role openings.",
    body: "A new Head of Compliance, Chief Risk Officer, or MLRO hire signals that a firm is either scaling, responding to regulatory pressure, or both. The incoming person will review supplier relationships early - before existing relationships get locked in and before the new compliance framework becomes business as usual. That review typically happens in the first 60 to 90 days. It is also the moment when a firm is most open to switching providers that were grandfathered in under previous leadership.",
  },
  {
    title: "Expansion into new markets or payment corridors.",
    body: "A fintech expanding from the Netherlands to Germany, or adding a new payment corridor, is buying new things: compliance infrastructure, local data providers, new banking relationships, and often new tooling for the expanded scope. Market expansion announcements are public and the procurement that follows is immediate. The team leading the expansion usually makes these decisions independently of the core product team - which means the right contact is different from the one you'd target for a core-product sale.",
  },
];

const faq = [
  {
    q: "Fintech compliance teams are very sensitive about data. Can Hooklyne actually operate here?",
    a: "Yes - and it's where Hooklyne's provenance approach matters most. Every contact has a documented source. No scraped session data, no lookalike audiences, no 'our database' as the only answer. For fintech companies that run their own GDPR audits, Hooklyne's contact sourcing is documentable and defensible.",
  },
  {
    q: "We sell to very specific fintech sub-segments. Does coverage work at that level?",
    a: "Depends on the segment. Established payments, lending, and wealthtech firms are well-covered in European provider databases. Earlier-stage fintechs and niche embedded finance players can be thinner. A free trial will tell you - ten prospects from your exact ICP, fully built, before any commitment.",
  },
  {
    q: "Fintech sales cycles are long and involve multiple stakeholders. Is Hooklyne still useful?",
    a: "The first conversation still has to start somewhere. Hooklyne gets you to the right first contact at the right moment with a reason that earns a reply. What happens after that is your process. Most teams using Hooklyne in fintech use it to open the top of the funnel - not to replace the relationship.",
  },
  {
    q: "What if Hooklyne doesn't work for our fintech ICP?",
    a: "Try first. Ten prospects from your actual fintech target list, fully built, no card required. If the output doesn't open conversations you wouldn't have had, you stop. Fintech is a segment where the sourcing and timing approach either resonates quickly or it doesn't - a free trial makes that clear.",
  },
];
---

<DefaultLayout
  title="Prospecting into fintech and financial services | Hooklyne"
  description="How to reach buyers in fintech and financial services: the regulatory signals that open buying windows, why data provenance matters in regulated sectors, and how to earn a reply from a CCO."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Fintech and financial services prospecting guide",
    "description": "How to prospect into fintech and financial services: signals, compliance, and timing.",
    "url": "https://www.hooklyne.com/fintech-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-24 sm:pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Fintech and financial services prospecting</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Fintech buyers have a shorter fuse for irrelevance than most.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Regulated buyers read cold outreach critically. The wrong message isn't just ignored - it creates a negative impression that follows your company. This guide covers the signals that open a real window in financial services, why data provenance matters more here than anywhere else, and how to arrive at exactly the right moment.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Try for free
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free trial, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real fintech prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your fintech ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Try for free <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How fintech companies buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open a buying window in financial services.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Fintech buying is event-driven: regulatory milestones, funding, product launches, market expansion. Outside those windows, the door is mostly closed. These are the signals that tell you when it's open.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for buyers who will scrutinise how you found them.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>In regulated sectors, 'how did you get my details?' carries legal weight. Every Hooklyne contact ships with its documented source - public profile, registered provider, company website. Hooklyne is built and hosted in the Netherlands, uses no scraped behavioural data, and waterfall-verifies across 21 registered providers. For fintech buyers in regulated environments, that provenance matters - especially if your own compliance team ever asks how you source contacts.</p>
          <p>Fintech buying decisions cluster around regulatory deadlines, funding events, and product launches. Hooklyne scores prospects against those signals and prepares outreach to arrive at the event - not to a sequence day. A message that references the DORA readiness timeline and connects it to a real infrastructure implication gets read. The same message on a Tuesday drip does not.</p>
          <p>The right contact in fintech depends on what you're selling. A payments infrastructure tool routes to the CTO or Head of Engineering. A compliance platform goes to the Head of Compliance or the incoming MLRO. Hooklyne identifies the correct seniority at each company and verifies the contact before it reaches your rep - rather than surfacing a generic list and leaving the judgement call to someone who has twenty other prospects to work through.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/saas-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">B2B SaaS</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Fintech prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
