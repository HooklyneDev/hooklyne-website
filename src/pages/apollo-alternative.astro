---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { HeadToHead } from '@/components/blocks/head-to-head';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, AlertCircle, Gift } from 'lucide-react';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Apollo alternative", path: "/apollo-alternative" },
]);

const breakdowns = [
  {
    title: "Built to research, not to send.",
    body: "Apollo is a sending engine on top of a US-first contact database. Hooklyne is a research workflow that produces the prospect package before anything goes out. If your bottleneck is volume, Apollo is fine. If your bottleneck is reply rate, the volume tool is the problem.",
  },
  {
    title: "European coverage, four-layer verification.",
    body: "Apollo's NL, BE, and DACH coverage runs thinner than its US numbers because the source mix is wrong for European SMEs. We waterfall across 21 providers and run four deliverability checks (SMTP, catch-all, role, deliverable) before a contact ships, so the cold email actually clears the bar.",
  },
  {
    title: "A signal layer Apollo doesn't have.",
    body: "Funding, hiring, leadership change, expansion, launch, sector and press signals scored against your ICP. Each prospect arrives with a why-now reason that an Apollo CSV can't tell you, sourced and citable so the email writes itself in the rep's voice.",
  },
];

const pains = [
  "Bounce rates are eating your sender domain.",
  "Sequences read generic, response rates show it.",
  "The signal you needed last week is in a different tab.",
  "You're researching prospects yourself instead of selling.",
];

const faq = [
  {
    q: "What if Hooklyne doesn't work for our team?",
    a: "Pilot first, contract second. Ten prospects fully built, no card, no commitment. If the output doesn't earn replies you wouldn't have got otherwise, you walk. We'd rather have honest feedback than a customer who isn't a fit.",
  },
  {
    q: "I already pay for Apollo. Why would I add another tool?",
    a: "You wouldn't add. Most pilots replace Apollo entirely on the small mid-market side, where Apollo's density is weakest and where Hooklyne's research-first model has the most lift. Pilots run on ten prospects, free, before any switch.",
  },
  {
    q: "Is Apollo's data better than Hooklyne's?",
    a: "Apollo has more rows. Hooklyne has fewer rows, scored harder. For US enterprise, Apollo wins on coverage. For Dutch and UK SMEs, Apollo's verification fail-rate runs roughly 12-25% on cold lists; ours is closer to 3-5% because we waterfall across 21 providers instead of relying on a single database.",
  },
  {
    q: "Does Hooklyne send the email or just write it?",
    a: "Hooklyne stops at the drafted message in your inbox. You send from your own sender, your own domain, your own warmed reputation. We don't run the sending layer on purpose - that's where bulk tools chew up your domain.",
  },
  {
    q: "What about GDPR?",
    a: "We're built in the Netherlands, no scraping, every claim sourced and citable. Contacts come from public profiles and verified provider data, not behavioural data harvested from logged-in sessions. No dark patterns, no lookalike audiences.",
  },
  {
    q: "Apollo is cheap per row. Is Hooklyne the same?",
    a: "No. Apollo is priced for volume, Hooklyne is priced for outcome. One Hooklyne credit produces a fully researched, verified, message-ready prospect. Most teams replace Apollo and a separate ChatGPT or agency line item with one Hooklyne plan and come out lower total cost.",
  },
];
---

<DefaultLayout
  title="Apollo alternative for European SMEs | Hooklyne"
  description="Hooklyne is a research-grade Apollo alternative built for Dutch and UK SMEs. Verified contacts across 21 providers, signal-driven outreach, drafted in your rep's voice. No spray, no scraping."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Apollo alternative for European SMEs",
    "description": "Hooklyne is the research-grade Apollo alternative for Dutch and UK B2B SMEs.",
    "url": "https://www.hooklyne.com/apollo-alternative",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Apollo alternative</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          An Apollo alternative built for European SMEs.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Hooklyne is a research-grade prospect workflow built for European B2B SMEs. Each prospect ships as one package - a verified contact, a scored buying signal, and a drafted message in your rep's voice - ready to review and send in under a minute. Apollo is a sending engine; Hooklyne is the research layer underneath.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#compare"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the comparison
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <AlertCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>

          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages. No payment, no contract. We ask twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot
              <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Where Apollo breaks for SMEs</p>
          <h2 class="text-2xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Three things Apollo wasn't built for.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Apollo is a fine fit for US enterprise teams running high-volume outbound on a wide TAM. Below 50 FTE in NL, BE, DACH and UK, the model leaks where it counts.
          </p>
        </div>

        <div class="space-y-8">
          {breakdowns.map((b, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{b.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{b.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div id="compare">
      <HeadToHead competitor="apollo" lang="en" />
    </div>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">Switching FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Common questions about leaving Apollo.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
