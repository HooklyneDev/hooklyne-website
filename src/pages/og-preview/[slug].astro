---
export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { slug: "home" }, props: { tagline: "B2B prospect research for SME sales teams.", sub: "Not more. Smarter." } },
    { params: { slug: "product" }, props: { tagline: "Every prospect, fully packaged.", sub: "Verified contact. Live signal. First message in your voice." } },
    { params: { slug: "how-it-works" }, props: { tagline: "Six stages. One prospect package.", sub: "Discovery, verification, signals, research, drafting, delivery." } },
    { params: { slug: "pricing" }, props: { tagline: "Pay for what you use.", sub: "From €39 a month. Every credit is a clear deliverable." } },
    { params: { slug: "about" }, props: { tagline: "The research layer most B2B teams can't staff.", sub: "So we built it." } },
    { params: { slug: "faq" }, props: { tagline: "Honest answers, not marketing.", sub: "How verification works, what we charge, what's in your inbox." } },
    { params: { slug: "contact" }, props: { tagline: "Try free.", sub: "Ten fully built prospect packages. No card, no commitment." } },
    { params: { slug: "blog" }, props: { tagline: "Field notes from the team.", sub: "Founder notes, product updates, B2B prospect research takes." } },
    { params: { slug: "blog-build-your-own-ai-lead-generation-agent" }, props: { tagline: "Building your own AI lead-gen agent?", sub: "What breaks at month six, and what you actually pay for at scale." } },
    { params: { slug: "blog-how-to-find-b2b-prospects-netherlands" }, props: { tagline: "Find Dutch B2B prospects without paid tools.", sub: "KvK, LinkedIn, Google operators. Where each route stops scaling." } },
    { params: { slug: "blog-apollo-vs-cognism-vs-lusha" }, props: { tagline: "Apollo vs Cognism vs Lusha for SMEs.", sub: "An honest breakdown for Dutch and UK B2B teams of 10 to 100." } },
  ];
}

const { tagline, sub } = Astro.props as { tagline: string; sub: string };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <title>OG: {tagline}</title>
    <style>
      @font-face { font-family: "DM Sans"; src: url("/fonts/dm-sans/DMSans-Regular.ttf") format("truetype"); font-weight: 400; font-display: block; }
      @font-face { font-family: "DM Sans"; src: url("/fonts/dm-sans/DMSans-Medium.ttf") format("truetype"); font-weight: 500; font-display: block; }
      @font-face { font-family: "DM Sans"; src: url("/fonts/dm-sans/DMSans-SemiBold.ttf") format("truetype"); font-weight: 600; font-display: block; }
      @font-face { font-family: "DM Sans"; src: url("/fonts/dm-sans/DMSans-Bold.ttf") format("truetype"); font-weight: 700; font-display: block; }
      html, body { margin: 0; padding: 0; }
      body { font-family: "DM Sans", system-ui, sans-serif; background: #022f51; }
      .canvas {
        width: 1200px;
        height: 630px;
        position: relative;
        overflow: hidden;
        background:
          radial-gradient(ellipse 900px 600px at 50% 50%, #0a3f6b 0%, #022f51 55%, #011d33 100%);
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        padding: 80px;
      }
      /* concentric rings, very subtle */
      .rings {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 1100px;
        height: 1100px;
        transform: translate(-50%, -50%);
        opacity: 0.08;
        pointer-events: none;
      }
      .rings::before, .rings::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        border: 1px solid rgba(255,255,255,0.6);
        border-radius: 50%;
        transform: translate(-50%, -50%);
      }
      .ring-1 { width: 380px; height: 380px; }
      .ring-2 { width: 620px; height: 620px; }
      .ring-3 { width: 880px; height: 880px; }
      .ring-4 { width: 1140px; height: 1140px; }
      .ring {
        position: absolute;
        top: 50%; left: 50%;
        border: 1px solid rgba(255,255,255,0.5);
        border-radius: 50%;
        transform: translate(-50%, -50%);
      }
      .logo {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 36px;
      }
      .logo svg { height: 96px; width: auto; display: block; }
      .tagline {
        position: relative;
        z-index: 2;
        font-size: 52px;
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -1.5px;
        text-align: center;
        margin: 0 0 20px 0;
        max-width: 1000px;
        color: #ffffff;
      }
      .sub {
        position: relative;
        z-index: 2;
        font-size: 24px;
        font-weight: 400;
        line-height: 1.4;
        letter-spacing: -0.2px;
        text-align: center;
        margin: 0;
        max-width: 880px;
        color: rgba(255,255,255,0.72);
      }
      .url {
        position: absolute;
        bottom: 48px;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
        z-index: 2;
      }
    </style>
  </head>
  <body>
    <div class="canvas">
      <div class="rings">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <div class="ring ring-4"></div>
      </div>
      <div class="logo">
