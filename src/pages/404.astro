---
import { ArrowLeft, ArrowRight, Compass, FileText, Tag, BookOpen, ChatCircle } from "@phosphor-icons/react";

import { Background } from "@/components/background";
import { Button } from "@/components/ui/button";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const isNL = Astro.url.pathname.startsWith("/nl");
const t = isNL ? {
  title: "404: Niet gevonden | Hooklyne",
  desc: "Sorry, de pagina die je zoekt bestaat niet.",
  eyebrow: "404",
  headline: "Deze pagina bestaat niet.",
  body: "Verhuisd, hernoemd of nooit gebouwd. Geen zorgen, hier zijn een paar plekken die wel bestaan.",
  back: "Terug naar home",
  contact: "Contact opnemen",
  popularEyebrow: "Misschien zocht je dit",
  popular: [
    { icon: Compass, label: "Hoe het werkt", href: "/nl/hoe-het-werkt", desc: "Zes fases, een prospectkaart." },
    { icon: FileText, label: "Product",        href: "/nl/product",      desc: "Bekijk de hele workflow." },
    { icon: Tag, label: "Prijzen",        href: "/nl/prijzen",      desc: "Een credit-systeem, vier abonnementen." },
    { icon: BookOpen, label: "Blog",           label2: "Over ons",       href: "/nl/blog",         desc: "Founder-notities en gidsen." },
    { icon: ChatCircle, label: "FAQ",       href: "/nl/faq",          desc: "Vijf veelgestelde vragen." },
    { icon: ArrowRight, label: "Contact",      href: "/nl/contact",      desc: "Boek een demo of pilot." },
  ],
  homeHref: "/nl",
  contactHref: "/nl/contact",
} : {
  title: "404: Not Found | Hooklyne",
  desc: "Sorry, the page you're looking for doesn't exist.",
  eyebrow: "404",
  headline: "This page doesn't exist.",
  body: "Moved, renamed or never built. No worries — here are a few that do.",
  back: "Back to home",
  contact: "Contact support",
  popularEyebrow: "Maybe you were after",
  popular: [
    { icon: Compass, label: "How it works", href: "/how-it-works", desc: "Six stages, one prospect card." },
    { icon: FileText, label: "Product",     href: "/product",      desc: "See the whole workflow." },
    { icon: Tag, label: "Pricing",     href: "/pricing",      desc: "One credit system, four plans." },
    { icon: BookOpen, label: "Blog",        href: "/blog",         desc: "Founder notes and guides." },
    { icon: ChatCircle, label: "FAQ",    href: "/faq",          desc: "Five common questions." },
    { icon: ArrowRight, label: "Contact",   href: "/contact",      desc: "Book a demo or pilot." },
  ],
  homeHref: "/",
  contactHref: "/contact",
};
---

<DefaultLayout title={t.title} description={t.desc}>
  <Background>
    <section class="pt-32 lg:pt-40 pb-12">
      <div class="container max-w-4xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">{t.eyebrow}</p>
        <h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4">{t.headline}</h1>
        <p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-10">
          {t.body}
        </p>

        <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center mb-16">
          <a href={t.homeHref}>
            <Button
              className="text-sm font-semibold rounded-lg px-5 py-2.5 h-auto btn-shine"
              style={{ backgroundColor: "var(--hooklyne-navy)", color: "#ffffff" }}
            >
              <ArrowLeft className="size-4 mr-1.5" />
              {t.back}
            </Button>
          </a>
          <a
            href={t.contactHref}
            class="inline-flex items-center gap-1.5 h-10 px-5 rounded-lg border border-[var(--border)] bg-[var(--card)] text-sm font-medium text-[var(--foreground)] hover:bg-[var(--card-hover)] hover:border-[var(--border-strong)] transition-colors"
          >
            {t.contact}
          </a>
        </div>
      </div>
    </section>

    <section class="pb-24">
      <div class="container max-w-5xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-5 text-center">{t.popularEyebrow}</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {t.popular.map((p) => (
            <a
              href={p.href}
              class="group rounded-xl p-5 flex flex-col gap-2 transition-all hover:-translate-y-0.5"
              style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs);"
            >
              <div class="flex items-center justify-between gap-2">
                <div style="color: var(--hooklyne-blue);">
                  <p.icon className="size-5" />
                </div>
                <ArrowRight className="size-4 text-[var(--muted-foreground)] transition-transform group-hover:translate-x-0.5 group-hover:text-[var(--hooklyne-blue)]" />
              </div>
              <p class="text-[15px] font-semibold text-[var(--heading)] tracking-tight group-hover:text-[var(--hooklyne-blue)] transition-colors">{p.label}</p>
              <p class="text-[13px] text-[var(--muted-foreground)] leading-relaxed">{p.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
