---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HeadToHead } from '@/components/blocks/head-to-head';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Lusha alternative", path: "/lusha-alternative" },
]);

const pains = [
  "You've outgrown the LinkedIn-extension workflow.",
  "Lusha gives you a contact, but you still write the email yourself.",
  "Your reply rate is flat because the personalisation is generic.",
  "You're juggling Lusha plus a separate signals tab plus a separate AI chat.",
];

const breakdowns = [
  {
    title: "A workflow, not a browser extension.",
    body: "Lusha lives inside the LinkedIn page you happen to be looking at. That's fast for one-off enrichment and great for solo prospecting. Once outbound becomes a team motion - one rep or eight, hitting numbers every week - the click-by-click model breaks. Hooklyne is a research workflow that produces the prospect package end-to-end, so the rep reviews and sends instead of clicking, copying, pasting, and writing.",
  },
  {
    title: "Signal and message included, not added on.",
    body: "Lusha's job ends with the contact. The why-now signal and the message you actually send are not its job - that's left to your rep, your CRM tabs, and your ChatGPT window. Hooklyne ships the same package every time: verified contact, scored buying signal, and a drafted message in your rep's voice. One screen instead of four.",
  },
  {
    title: "Verification across 21 sources, not single-source.",
    body: "Lusha verifies against its own database. That's fine for the contacts that database knows well. On Dutch and UK SME prospects where coverage is patchy, single-source verification means you find out the address was wrong only after the bounce. Hooklyne waterfalls across 21 providers and runs four deliverability layers before a contact ever ships.",
  },
];

const faq = [
  {
    q: "What if Hooklyne doesn't work for our team?",
    a: "Pilot first, contract second. Ten prospects fully built, no card, no commitment. If the output doesn't earn replies you wouldn't have got otherwise, you walk. We'd rather have honest feedback than a customer who isn't a fit.",
  },
  {
    q: "Lusha is cheap. Is Hooklyne worth the upgrade?",
    a: "If you're a solo SDR doing 5-10 prospects a week, Lusha is fine. If you're a sales team running outbound as a real channel, Lusha's contact-only output makes everyone do the same research-and-write work in parallel. Hooklyne replaces that hour-per-prospect with ≈90s of review per prospect. The math flips around 20-30 prospects a week.",
  },
  {
    q: "Does Hooklyne work as a Chrome extension like Lusha?",
    a: "No, and that's deliberate. The extension model captures one prospect at a time and asks you to decide before any research has happened. Hooklyne flips that: research runs in the background, prospects show up in My Leads with a signal already attached, and you decide based on the package - not the row.",
  },
  {
    q: "We use Lusha for mobile numbers. Do you do that?",
    a: "No. Email and LinkedIn URL are our primary path. If your motion is heavy phone outbound, Lusha's mobile dataset is a real edge. If it's email-led, you're paying for Lusha's mobile coverage and not using most of it.",
  },
  {
    q: "We're a solo founder. Should we just stay on Lusha?",
    a: "Probably yes for now. Lusha's free tier and click-by-click flow fit a founder doing 2-3 prospects a week. The moment outbound becomes a function someone owns - even one full-time rep - the workflow shape stops fitting and the tab-juggling starts. Talk to us when you hit that point.",
  },
];
---

<DefaultLayout
  title="Lusha alternative for B2B sales teams | Hooklyne"
  description="Hooklyne is the workflow-grade Lusha alternative. Verified contact, scored signal, and drafted message shipped per prospect - not just enrichment. Built for SME sales teams running real outbound."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lusha alternative for B2B sales teams",
    "description": "Hooklyne is the full-workflow Lusha alternative for European B2B SME sales teams.",
    "url": "https://www.hooklyne.com/lusha-alternative",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Lusha alternative</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          The Lusha alternative for teams that have outgrown the extension.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Hooklyne is a research-grade prospect workflow built for European B2B SMEs. Each prospect ships as one package - a verified contact, a scored buying signal, and a drafted message in your rep's voice - ready to review and send in under a minute. Lusha gives you a contact. Hooklyne gives you the prospect, packaged.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/contact" class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine">
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a href="#compare" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group">
            See the comparison
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>

          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages. No payment, no contract. We ask twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot
              <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Where Lusha stops</p>
          <h2 class="text-2xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Three things Lusha leaves to you.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Lusha is excellent at one thing: enriching a contact you're already looking at on LinkedIn. The work that comes after - finding the why-now, writing the message, verifying the address holds up at scale - is your team's problem. For solo prospecting that's fine. For team outbound, it leaks at the seams.
          </p>
        </div>

        <div class="space-y-8">
          {breakdowns.map((b, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{b.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{b.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div id="compare">
      <HeadToHead competitor="lusha" lang="en" />
    </div>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">Switching FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">Common questions about leaving Lusha.</h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
