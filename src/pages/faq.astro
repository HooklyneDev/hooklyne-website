---
import { Background } from '@/components/background';
import { FAQ } from '@/components/blocks/faq';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { faqGroups } from '@/data/faq';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqGroups.flatMap((g) =>
    g.items.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    }))
  ),
};
---
<DefaultLayout title="FAQ - Hooklyne" description="Answers to common questions about Hooklyne, the research workflow, credits, signals, and what's included in each plan." ctaVariant="faq">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <Background>
    <div class="pt-32 lg:pt-40">
      <FAQ client:visible />
    </div>
  </Background>
</DefaultLayout>
