---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";
import { livByCategory } from "@/data/guides";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Guides", path: "/guides" },
  { name: "Compare", path: "/compare" },
]);

const alternatives = livByCategory("alternative");
---

<DefaultLayout
  title="Hooklyne compared — Apollo, Cognism, Lusha | Hooklyne"
  description="Hooklyne compared to Apollo, Cognism, Lusha and other B2B prospecting tools. Honest side-by-side breakdowns for European SMEs. Where Hooklyne wins and where it doesn't."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Hooklyne compared — Apollo, Cognism, Lusha",
    "description": "Honest side-by-side comparisons of Hooklyne vs the B2B prospecting tools European SME sales teams use most.",
    "url": "https://www.hooklyne.com/compare",
    "inLanguage": "en"
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">
          <a href="/guides" class="hover:underline">Guides</a> / Compare
        </p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          How Hooklyne <span class="text-accent">stacks up</span>.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Honest comparisons with the B2B prospecting tools European sales teams use most. Where Hooklyne wins, where it doesn't, and who each tool is built for.
        </p>
      </div>
    </section>

    <section class="pb-24 lg:pb-32">
      <div class="container max-w-5xl">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {alternatives.map((item) => (
            <a
              href={item.en.slug}
              class="group block rounded-2xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
              style="background: var(--card); border: 1px solid var(--border);"
            >
              <span class="inline-block text-[10px] font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-3">Alternative</span>
              <h3 class="text-base font-semibold text-[var(--heading)] mb-2 group-hover:text-[var(--hooklyne-blue)] transition-colors">{item.en.label}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">{item.en.description}</p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-[var(--hooklyne-blue)]">
                {item.en.cta}
                <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
