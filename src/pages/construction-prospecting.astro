---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, AlertCircle, Gift } from 'lucide-react';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Construction and real estate prospecting", path: "/construction-prospecting" },
]);

const pains = [
  "The project director you need is on-site, not on LinkedIn.",
  "Planning permissions are your best lead signal - and you're finding them after groundbreaking.",
  "Construction procurement happens in stages. You're arriving at the wrong one.",
  "Developer contacts change with every project. You're working from a list that's already out of date.",
];

const signals = [
  {
    title: "Planning applications and building permits.",
    body: "A planning application is the earliest possible signal that a construction or development project is real and funded. It precedes contractor appointments, material procurement, and equipment orders by months. Planning applications are filed publicly with local authorities and accessible through national planning portals. In the Netherlands, this means omgevingsvergunning filings through Omgevingsloket. In the UK, planning portal submissions. Most sellers find out about projects from trade press coverage of groundbreakings - at which point the procurement decisions have already been made.",
  },
  {
    title: "Developer and contractor tender publications.",
    body: "Public and semi-public tenders in construction are listed in procurement portals, sector databases, and trade publications before they close. TenderNed in the Netherlands, Tenders Electronic Daily for EU-threshold projects. Being on the tender list is much easier if you've made contact before the tender is drafted. Procurement managers write specifications around suppliers they've already spoken to. Arriving cold at a tender stage is starting from behind.",
  },
  {
    title: "Real estate acquisition and portfolio announcements.",
    body: "A property developer that just acquired a site or announced a new scheme is entering a procurement cycle for professional services, construction management, materials, and technology. Commercial real estate acquisitions are registered in public land registries and often announced in trade press within days. The procurement that follows is both predictable and time-compressed - developers move quickly once planning is secured.",
  },
  {
    title: "Sustainability certification and ESG compliance requirements.",
    body: "BREEAM, LEED, WELL, and energy performance requirements are increasingly mandatory for commercial development - either by regulation, by investor covenant, or by occupier demand. A developer who has committed to BREEAM Excellent on a scheme is actively procuring the systems, materials, and consultants that make the rating achievable. These commitments appear in planning applications, investment announcements, and company ESG reports before they show up in any database.",
  },
];

const faq = [
  {
    q: "Construction decisions involve a lot of subcontractors and intermediaries. Who do I actually reach?",
    a: "It depends on what you sell. For materials and equipment: procurement director or project manager. For professional services: the lead developer or development director. For technology and software: the digital/BIM manager or operations director. Hooklyne identifies the right seniority for your offer at each company rather than surfacing a generic list - construction has more distinct contact types than most sectors.",
  },
  {
    q: "Construction cycles are long and relationships-driven. Is cold outreach effective?",
    a: "Cold outreach at the wrong moment is ineffective. Cold outreach at planning stage - before the shortlist forms - is very effective. The goal is to be a known quantity by the time procurement formally opens. That requires reaching the right person before the project is in active procurement, not during it.",
  },
  {
    q: "We focus on residential developers specifically. Does Hooklyne cover that segment?",
    a: "Yes. Residential developers and housebuilders are covered through company registries, planning databases, and sector sources. Both large volume housebuilders and SME residential developers are in scope. The signal sources differ slightly - residential planning applications tend to be filed through local authority portals, commercial through national databases - but both are monitored.",
  },
  {
    q: "What if Hooklyne doesn't work for our construction ICP?",
    a: "Pilot first. Ten prospects from your actual target list, fully built, no card required. Construction is a segment where the planning database signal approach either immediately makes sense for your offer or it doesn't - the pilot will show you that quickly.",
  },
];
---

<DefaultLayout
  title="Prospecting into construction and real estate | Hooklyne"
  description="How to reach buyers in construction and real estate development: where planning signals are, how to identify active procurement phases, and how to get in before the shortlist closes."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Construction and real estate prospecting guide",
    "description": "How to prospect into construction and real estate: planning signals, contacts, and buying phases.",
    "url": "https://www.hooklyne.com/construction-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Construction and real estate prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Construction procurement is decided before the signs go up.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          By the time a construction project appears in trade press, the supplier shortlist is largely formed. The buyers who matter - project developers, procurement directors, development managers - are reachable months earlier, when the planning application is filed and the procurement hasn't started yet. This guide covers how to find those signals and what to do with them.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <AlertCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real construction prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your construction ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How construction and real estate companies buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open a construction buying window.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Construction procurement is predictable if you know where to look. The signals are in planning databases and registries - not in press releases that arrive after the decisions are made.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for procurement that starts before the project is public.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Construction and real estate procurement is front-loaded. The decisions that matter - who gets on the shortlist, who writes the specification, who gets invited to tender - happen at planning stage, not at construction stage. Hooklyne monitors planning portals, land registries, and procurement databases to surface the signal at the point where contact still makes a difference.</p>
          <p>The right contact varies significantly by project stage and company type. A developer at pre-planning stage is different from a contractor at tender stage. Hooklyne identifies the correct role at each company based on your offer and verifies the contact across 21 providers - rather than returning a generic list and leaving the targeting decision to your rep.</p>
          <p>The first message is drafted in your rep's writing style and references the specific project or filing that makes this company relevant right now. A development director who receives a message that references their recent planning application and connects it to a real procurement need reads it. A generic 'we help construction companies' message does not.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/industrial-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrial and manufacturing</a>
          <a href="/energy-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Energy and utilities</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Construction prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
