---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';
import { WhatYouGet } from '@/components/blocks/what-you-get';
import { WaysToStart } from '@/components/blocks/ways-to-start';
import { BuiltFor } from '@/components/blocks/built-for';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION} image="/og/home.jpg">
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Hooklyne",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Research-grade B2B prospect packages in your rep's voice. Find the right contact, draft outreach, send in under a minute.",
    "url": "https://www.hooklyne.com",
    "offers": {
      "@type": "Offer",
      "price": "39",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "39",
        "priceCurrency": "EUR",
        "billingIncrement": 1,
        "unitText": "MONTH"
      }
    },
    "featureList": [
      "B2B prospect research",
      "Signal-driven outreach",
      "Email verification",
      "Company discovery",
      "Personalised drafting in Dutch and English"
    ]
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Hooklyne product walkthrough",
    "description": "A 30-second walkthrough of the Hooklyne portal: prospect packages with verified contacts, live signals, and a first message in your voice.",
    "thumbnailUrl": "https://www.hooklyne.com/home/hooklyne-research-layer-b2b-prospecting.webp",
    "contentUrl": "https://www.hooklyne.com/home/hooklyne-intro.mp4",
    "uploadDate": "2026-02-01",
    "duration": "PT30S",
    "publisher": {
      "@type": "Organization",
      "name": "Hooklyne",
      "logo": { "@type": "ImageObject", "url": "https://www.hooklyne.com/logo.svg" }
    }
  })} />
  <Background>
    <Hero client:load />
    <SignalTicker />
    <DIYCompare client:visible />
  </Background>

  <Background variant="bottom">
    <section class="pt-4 pb-8 sm:pt-6 lg:pt-10 lg:pb-12" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-10 px-2">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Verification</p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
            20+ providers. Four layers. One verdict.
          </h2>
          <p class="text-sm sm:text-base text-[var(--muted-foreground)] leading-relaxed">
            No single database covers more than ~40% of any market. We waterfall across 20+, then run four deliverability checks. If it can't clear the bar, it doesn't ship.
          </p>
        </div>
        <VerificationWaterfall client:visible ratio="5/2" tabletRatio="2/1" mobileRatio="1/1" />
      </div>
    </section>

    <WhatYouGet />
    <WaysToStart client:visible />
    <BuiltFor client:visible />
    <HomePricing client:visible />
  </Background>
</DefaultLayout>
