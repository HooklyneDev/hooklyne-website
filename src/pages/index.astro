---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { BuiltFor } from '@/components/blocks/built-for';
import { PositioningBar } from '@/components/blocks/positioning-bar';
import { FounderSplit } from '@/components/blocks/founder-split';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Background>
    <Hero client:load />
    <SignalTicker />
    <DIYCompare client:visible />
  </Background>

  <Background variant="bottom">
    <BuiltFor client:visible />
    <PositioningBar client:visible />
    <FounderSplit />
    <HomePricing client:load />
  </Background>
</DefaultLayout>
