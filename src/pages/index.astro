---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import ValueProps from '@/components/blocks/value-props.astro';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { FeatureCarousel } from '@/components/blocks/feature-carousel';
import { FeatureShowcase } from '@/components/blocks/feature-showcase';
import { FounderQuote } from '@/components/blocks/founder-quote';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Background>
    <Hero client:load />
    <SignalTicker />
    <ValueProps />
  </Background>

  <Background variant="bottom">
    <FeatureCarousel client:load />
    <FeatureShowcase />
    <FounderQuote />
    <HomePricing client:load />
  </Background>
</DefaultLayout>
