---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';
import { WhatYouGet } from '@/components/blocks/what-you-get';
import { WaysToStart } from '@/components/blocks/ways-to-start';
import { BuiltFor } from '@/components/blocks/built-for';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION} image="/og/EN/home.jpg">
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Hooklyne",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Research-grade B2B prospect packages in your rep's voice. Find the right contact, draft outreach, send in under a minute.",
    "url": "https://www.hooklyne.com",
    "offers": {
      "@type": "Offer",
      "price": "39",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "39",
        "priceCurrency": "EUR",
        "billingIncrement": 1,
        "unitText": "MONTH"
      }
    },
    "featureList": [
      "B2B prospect research",
      "Signal-driven outreach",
      "Email verification",
      "Company discovery",
      "Personalised drafting in Dutch and English"
    ]
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Hooklyne product walkthrough",
    "description": "A 30-second walkthrough of the Hooklyne portal: prospect packages with verified contacts, live signals, and a first message in your voice.",
    "thumbnailUrl": "https://www.hooklyne.com/home/hooklyne-research-layer-b2b-prospecting.webp",
    "contentUrl": "https://www.hooklyne.com/home/hooklyne-intro.mp4",
    "uploadDate": "2026-02-01",
    "duration": "PT30S",
    "publisher": {
      "@type": "Organization",
      "name": "Hooklyne",
      "logo": { "@type": "ImageObject", "url": "https://www.hooklyne.com/logo.svg" }
    }
  })} />
  <Background>
    <Hero client:load />
    <SignalTicker />
    <DIYCompare hideCompare client:visible />

    <section class="pb-14 lg:pb-20" data-fade>
      <div class="container max-w-6xl">
        <div class="flex flex-col lg:flex-row lg:items-center gap-10 lg:gap-16">
          <div class="lg:w-2/5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Verification</p>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-tight mb-4">
              21 providers. Four layers. One verdict.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
              No single contact database covers your full market. We run 21 in parallel, then put every result through four deliverability checks. You only see what's safe to send.
            </p>
          </div>
          <div class="w-full lg:w-3/5">
            <VerificationWaterfall client:visible ratio="16/9" tabletRatio="16/9" mobileRatio="4/3" />
          </div>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <WhatYouGet />
    <WaysToStart client:visible />
    <BuiltFor client:visible />
    <HomePricing client:visible />
  </Background>
</DefaultLayout>
