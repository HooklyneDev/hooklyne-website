---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { breadcrumbList } from '@/lib/seo';
import { SITE_URL } from '@/consts';

const breadcrumb = breadcrumbList([
  { name: 'Home', path: '/' },
  { name: 'Pricing', path: '/pricing' },
]);

const offerCatalog = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Hooklyne",
  serviceType: "B2B prospect research",
  provider: { "@type": "Organization", name: "Hooklyne", url: SITE_URL },
  areaServed: ["NL", "BE", "GB", "LU", "DE", "FR", "IE", "DK", "SE", "NO", "FI"],
  audience: { "@type": "BusinessAudience", audienceType: "B2B SME sales teams (10-100 people)" },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Hooklyne plans",
    itemListElement: [
      { "@type": "Offer", name: "Start", price: "39", priceCurrency: "EUR", url: `${SITE_URL}/pricing`, category: "annual billing" },
      { "@type": "Offer", name: "Growth", price: "129", priceCurrency: "EUR", url: `${SITE_URL}/pricing`, category: "annual billing" },
      { "@type": "Offer", name: "Scale", price: "239", priceCurrency: "EUR", url: `${SITE_URL}/pricing`, category: "annual billing" },
      { "@type": "Offer", name: "Enterprise", url: `${SITE_URL}/contact`, category: "custom" },
    ],
  },
};
---

<DefaultLayout title="Pricing | Hooklyne" description="Pay for what you use. Every credit is a clear deliverable. Start, Growth, Scale, and Enterprise plans." image="/og/EN/pricing.jpg" ctaVariant="pricing">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(offerCatalog)} />
  <Background>
  <section class="pt-24 sm:pt-32 lg:pt-44 pb-10 relative">
    <HeroGlow client:idle signals={false} />
    <div id="hero-content" class="container max-w-6xl relative z-10">

      <!-- Header -->
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Pricing</p>
        <h1 class="hero-headline text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">Simple pricing with <span class="text-accent">transparent credits</span>.</h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">One credit system. Every action priced the same across plans. No per-seat fees on Start and Growth. Switch plans or cancel anytime.</p>
      </div>

      <!-- Free pilot banner (kept inside the hero section so the glow reaches behind it) -->
      <div class="mt-14 rounded-2xl overflow-hidden" style="background: var(--card); box-shadow: var(--shadow-xs); border: 1px solid var(--border)">
        <div class="grid md:grid-cols-[auto_1fr_auto] gap-6 items-center p-6">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center size-10 rounded-xl" style="background: rgba(13,148,136,0.12)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hooklyne-teal)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 7l8 5 8-5-8-5Z"/><path d="m4 12 8 5 8-5"/><path d="m4 17 8 5 8-5"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)]">Free pilot</p>
              <p class="text-base font-semibold text-[var(--heading)]">Try it before you pay.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 text-sm md:border-l md:border-r md:border-[var(--border)] md:px-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">You get</p>
              <p class="text-[var(--foreground)] leading-relaxed">10 prospect packages, fully built. Portal access. Two weeks of sector news.</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">We ask</p>
              <p class="text-[var(--foreground)] leading-relaxed">20 minutes of honest feedback. Permission to mention you if it works.</p>
            </div>
          </div>

          <a href="/contact" class="inline-flex items-center justify-center gap-1.5 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine whitespace-nowrap" style="background: var(--hooklyne-teal)">
            Start pilot
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container max-w-6xl">

      <!-- Toggle -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <span class="text-sm font-medium transition-colors" id="label-monthly" style="color: var(--muted-foreground)">Monthly</span>
        <button
          id="toggle-btn"
          class="relative w-12 h-6 rounded-full transition-colors cursor-pointer btn-shine"
          style="background: var(--hooklyne-navy)"
          onclick="toggleBilling()"
          aria-label="Toggle billing period"
        >
          <span id="toggle-knob" class="absolute top-0.5 left-0.5 size-5 rounded-full bg-white transition-transform duration-200 shadow-sm" style="transform: translateX(24px)"></span>
        </button>
        <span class="text-sm font-medium flex items-center gap-2 transition-colors" id="label-annual" style="color: var(--heading)">
          Annual
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal)">Save up to €60/mo</span>
        </span>
      </div>

      <!-- Plan cards -->
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-12">

        <!-- Start -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Start</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="49" data-annual="39">€39</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mo</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Save €10/mo on annual</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Solo rep. Test and validate your outbound. Self-serve.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">100</span>
              <span class="text-xs text-[var(--muted-foreground)]">credits / month</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">≈ 25 ready-to-send prospects, 10 tracked companies, 5 meeting briefs</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["1 seat", "Find companies + contacts", "Outreach in NL + EN", "Weekly market briefing", "Meeting prep briefs", "Signal tracking: up to 10 companies"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0.85/cr</p>
          <a href="/contact" data-tier="start" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Get started
          </a>
        </div>

        <!-- Growth (featured) -->
        <div class="rounded-2xl p-5 flex flex-col relative text-white" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-xl)">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-white text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap" style="background: var(--hooklyne-orange)">
            Recommended
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-3 mt-1">Growth</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-white price-display" data-monthly="159" data-annual="129">€129</span>
            <span class="text-sm text-white/40 ml-1">/mo</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-green-300">Save €30/mo on annual</span>
          </div>
          <p class="text-xs leading-relaxed text-white/50 mb-4">1-2 reps. Full pipeline. Setup call included.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: rgba(255,255,255,0.08)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-blue-300">400</span>
              <span class="text-xs text-white/40">credits / month</span>
            </div>
            <p class="text-[10.5px] text-white/55 leading-snug mt-1.5">≈ 90 ready-to-send prospects, 30 tracked companies, 10 meeting briefs</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["2 seats", "Find companies + contacts", "Outreach in NL + EN", "Weekly market briefing", "Meeting prep briefs", "Signal tracking: up to 40 companies", "45-min setup + strategy call", "ICP configured with you", "Monthly check-in (first 3 months)"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-white/70">
                <svg class="size-3.5 shrink-0 mt-0.5 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-white/30 mb-4">Top-up: €0.85/cr</p>
          <a href="/contact" data-tier="growth" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine bg-white/14 text-white border border-white/22 hover:bg-white/24">
            Get started
          </a>
        </div>

        <!-- Scale -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Scale</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="299" data-annual="239">€239</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mo</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Save €60/mo on annual</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Small sales team. Volume outbound. Up to 5 reps.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">800</span>
              <span class="text-xs text-[var(--muted-foreground)]">credits / month</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">≈ 190 ready-to-send prospects, 60 tracked companies, 20 meeting briefs</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["5 seats", "Find companies + contacts", "Outreach in NL + EN", "Weekly market briefing", "Meeting prep briefs", "Signal tracking: up to 100 companies", "Full setup + team training", "Dedicated Slack or WhatsApp", "Bi-weekly check-in calls", "Monthly playbook iteration"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0.85/cr</p>
          <a href="/contact" data-tier="scale" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Get started
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Enterprise</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)]">Custom</span>
          </div>
          <div class="h-5 mb-2"></div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Sales departments. Multi-market. Custom volumes.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">Custom</span>
              <span class="text-xs text-[var(--muted-foreground)]">credit volume</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">Negotiated to your team's outbound volume</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["Unlimited seats", "Find companies + contacts", "Outreach in NL + EN", "Weekly market briefing", "Meeting prep briefs", "Signal tracking: negotiated", "Full setup + team training", "Dedicated account manager"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: Custom rate</p>
          <a href="/contact" data-tier="enterprise" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Talk to us
          </a>
        </div>

      </div>

      <!-- Subnote under plan cards -->
      <p class="text-center text-xs text-[var(--muted-foreground)] leading-relaxed max-w-3xl mx-auto mb-4 -mt-6">
        Annual plans billed upfront. Credits valid 12 months. Unused credits roll 1 month forward (max balance 2× your monthly quota). Top-up at €0.85/cr on all plans. Signal tracking cap is per workspace, not per user.
      </p>

      <!-- Why Growth is worth it callout -->
      <div class="rounded-xl px-5 py-4 mb-16 max-w-3xl mx-auto" style="background: rgba(52,76,163,0.06); border: 1px solid rgba(52,76,163,0.18)">
        <p class="text-sm font-semibold text-[var(--heading)] mb-1.5">Why Growth is worth it</p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          Topping up 100 extra credits on Start costs €85. Growth gives you 400 credits (4× more than Start), 2 seats, 4× higher signal tracking, and a real setup call - for €90 more than Start. Every credit on Growth is cheaper than on Start, and the per-credit rate keeps dropping as you scale up.
        </p>
      </div>

      <!-- ===========================================================
           HOW CREDITS WORK - lifecycle structure
           =========================================================== -->
      <div class="mb-16">
        <div class="max-w-3xl mb-10">
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-3">How credits work</h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Credits are spent when you produce something - a prospect, a contact, a brief. Browsing, reading signals, viewing intel, and exporting are always free. The flow below mirrors how prospects move through your pipeline.
          </p>
        </div>

        <!-- ─── STAGE 1 ─── -->
        <div class="flex items-center gap-3.5 mb-5">
          <span class="flex items-center justify-center size-9 rounded-full text-base font-bold text-white shrink-0" style="background: var(--hooklyne-navy)">1</span>
          <div>
            <p class="text-[15px] font-semibold text-[var(--heading)] leading-tight">Get prospects into My Leads</p>
            <p class="text-[12.5px] text-[var(--muted-foreground)] leading-snug mt-0.5">Pick the path that matches what you already know. Every path ends in a ready-to-send prospect package in My Leads.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-5">
          {[
            { n: "1", title: "Find me companies", featured: true, desc: "Describe your ICP. Hooklyne returns up to 20 ranked companies with up to 3 matched roles each.", lines: [["Discovery (up to 20 companies)", "1cr"], ["Prospect package", "1cr"], ["Contact (email + phone)", "2cr"]], total: "4cr", soon: false },
            { n: "2", title: "I know the company", featured: false, desc: "Enter a company name and domain. We surface up to 3 matched roles for you to pick from.", lines: [["View matched roles", "Free"], ["Prospect package", "1cr"], ["Contact (email + phone)", "2cr"]], total: "3cr", soon: false },
            { n: "3", title: "I know who to reach", featured: false, desc: "You have a name and LinkedIn URL. We verify the email and write outreach in your voice.", lines: [["Prospect package", "1cr"], ["Contact (email + phone)", "2cr"]], total: "3cr", soon: false },
            { n: "4", title: "Find similar companies", featured: false, desc: "Upload your best customers. Hooklyne finds companies that look just like them - same size, sector, and signals.", lines: [["ICP modelling", "TBA"], ["Prospect package", "TBA"], ["Contact (email + phone)", "TBA"]], total: "TBA", soon: true },
          ].map((c) => (
            <div class:list={["relative rounded-2xl p-5 flex flex-col", c.featured ? "border-2" : "border", c.soon && "border-dashed"]} style={c.featured ? "background: var(--card); border-color: var(--hooklyne-blue); box-shadow: var(--shadow-sm)" : c.soon ? "background: #f8fafc; border-color: var(--border-strong)" : "background: var(--card); border-color: var(--border); box-shadow: var(--shadow-xs)"}>
              {c.soon && <span class="absolute top-3 right-3 text-[9.5px] font-semibold uppercase tracking-[0.12em] text-[var(--muted-foreground)] px-2 py-0.5 rounded-full bg-white border border-[var(--border)]">Coming soon</span>}
              <div class="flex items-center gap-2.5 mb-3">
                <span class:list={["flex items-center justify-center size-6 rounded-full text-[11px] font-bold text-white shrink-0"]} style={c.featured ? "background: var(--hooklyne-blue)" : c.soon ? "background: #cbd5e1" : "background: var(--muted-foreground)"}>
                  {c.n}
                </span>
                <span class="text-[13px] font-semibold text-[var(--heading)]">{c.title}</span>
              </div>
              <p class="text-[12px] text-[var(--muted-foreground)] leading-relaxed mb-4 min-h-[58px]">{c.desc}</p>
              <div class="border-t border-[var(--border)] pt-2.5 mt-auto space-y-1">
                {c.lines.map(([k, v]) => (
                  <div class="flex items-baseline justify-between text-[11.5px]">
                    <span class="text-[var(--muted-foreground)]">{k}</span>
                    <span class:list={[v === "Free" ? "text-[var(--hooklyne-teal)] italic" : v === "TBA" ? "text-[var(--muted-foreground)] italic" : "text-[var(--hooklyne-blue)] font-semibold"]}>{v}</span>
                  </div>
                ))}
                <div class="flex items-baseline justify-between pt-1.5 mt-1.5 border-t border-[var(--hooklyne-navy)]/15">
                  <span class="text-[11.5px] font-semibold text-[var(--heading)]">Per prospect</span>
                  <span class:list={["text-[14px] font-semibold", c.total === "TBA" ? "text-[var(--muted-foreground)]" : "text-[var(--hooklyne-navy)]"]}>{c.total}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="rounded-xl px-5 py-4 mb-12" style="background: rgba(13,148,136,0.08); border: 1px solid rgba(13,148,136,0.22)">
          <p class="text-sm font-semibold mb-1.5" style="color: #0F6E56">How Route 1 works in practice</p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            One discovery (1cr) returns up to 20 ranked companies. You decide which to convert. Build the 5 best fits: 1cr discovery + 5 × 3cr packages = <strong class="text-[var(--heading)]">16cr for 5 ready-to-send prospects</strong>. Build all 20: 61cr. Skip a company that does not fit: no extra cost. The discovery credit pays for itself the moment you convert a second company from the same list.
          </p>
        </div>

        <!-- ─── STAGE 2 ─── -->
        <div class="flex items-center gap-3.5 mb-5">
          <span class="flex items-center justify-center size-9 rounded-full text-base font-bold text-white shrink-0" style="background: var(--hooklyne-navy)">2</span>
          <div>
            <p class="text-[15px] font-semibold text-[var(--heading)] leading-tight">Work prospects in My Leads</p>
            <p class="text-[12.5px] text-[var(--muted-foreground)] leading-snug mt-0.5">Once a prospect is in your pipeline, you can track buying signals on them and request a meeting prep brief before any conversation.</p>
          </div>
        </div>

        <div class="grid gap-3 md:grid-cols-2 mb-12">
          <div class="rounded-2xl p-5 flex gap-4 items-start" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs)">
            <span class="inline-flex items-center justify-center min-w-12 h-11 rounded-lg text-base font-semibold shrink-0" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue)">2cr</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <span class="text-[13.5px] font-semibold text-[var(--heading)]">Signal tracking</span>
                <span class="text-[10.5px] text-[var(--muted-foreground)] whitespace-nowrap">per company / month</span>
              </div>
              <p class="text-[12px] text-[var(--muted-foreground)] leading-relaxed mb-3">Toggle on any prospect in My Leads. We sweep job posts, news, LinkedIn activity, and funding daily - scored and ranked. When a hot signal fires, the outreach is already drafted.</p>
              <div class="text-[11px] text-[var(--muted-foreground)] pt-2 border-t border-[var(--border)] flex flex-wrap gap-x-4 gap-y-1">
                <span><strong class="text-[var(--heading)] font-semibold">Start</strong> up to 10</span>
                <span><strong class="text-[var(--heading)] font-semibold">Growth</strong> up to 40</span>
                <span><strong class="text-[var(--heading)] font-semibold">Scale</strong> up to 100</span>
              </div>
            </div>
          </div>
