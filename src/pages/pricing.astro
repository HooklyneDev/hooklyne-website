---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title="Pricing - Hooklyne" description="Pay for what you use. Every credit is a clear deliverable. Start, Growth Smarter, Scale, and Enterprise plans.">
  <section class="py-28 lg:py-32 lg:pt-44">
    <div class="container max-w-5xl">

      {/* Header */}
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#344ca3] mb-3">Pricing</p>
        <h1 class="text-[#022f51] text-4xl tracking-tight md:text-5xl mb-4">Pay for what you use.</h1>
        <p class="text-[#64748b] text-lg max-w-xl mx-auto">Every credit is a clear deliverable. No hidden consumption. No failed lookups charged. Switch anytime.</p>
      </div>

      {/* Free pilot banner */}
      <div class="rounded-2xl border-l-4 border-[#0d9488] bg-[#0d9488]/5 border border-[#0d9488]/20 p-5 mb-10">
        <p class="text-sm font-semibold text-[#0d9488] mb-1">Free pilot</p>
        <p class="text-sm text-[#64748b] leading-relaxed">10 full prospect packages. 1 seat configured. Sector news for 2 weeks. Portal access. Signals, discovery, and meeting prep visible but locked. You commit to: 20-min feedback call + case study permission. Our cost: ~€6. This is the entry point for every customer.</p>
        <a href="/contact" class="inline-flex items-center gap-1.5 mt-3 text-sm font-semibold text-[#0d9488] hover:opacity-80 transition-opacity">
          Start your free pilot →
        </a>
      </div>

      {/* Toggle */}
      <div class="flex items-center justify-center gap-3 mb-10" id="billing-toggle">
        <span class="text-sm font-medium text-[#0f172a]" id="label-monthly">Monthly</span>
        <button
          id="toggle-btn"
          class="relative w-12 h-6 rounded-full bg-[#022f51] transition-colors cursor-pointer"
          onclick="toggleBilling()"
          aria-label="Toggle billing period"
        >
          <span id="toggle-knob" class="absolute top-0.5 left-0.5 size-5 rounded-full bg-white transition-transform duration-200"></span>
        </button>
        <span class="text-sm font-medium text-[#64748b]" id="label-annual">Annual <span class="text-xs font-semibold text-[#0d9488] bg-[#0d9488]/10 px-1.5 py-0.5 rounded-full ml-1">Save 10%</span></span>
      </div>

      {/* Plan cards */}
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-12">
        {/* Start */}
        <div class="rounded-2xl border border-[#e2e8f0] bg-white p-5 flex flex-col">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#64748b] mb-3">Start</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[#022f51]">€</span>
            <span class="text-3xl font-bold text-[#022f51] monthly-price">59</span>
            <span class="text-3xl font-bold text-[#022f51] annual-price hidden">53</span>
            <span class="text-sm text-[#64748b]">/mo</span>
          </div>
          <p class="text-xs text-[#64748b] mb-5">Validate before you commit</p>
          <div class="space-y-2.5 flex-1 text-sm">
            {[
              ["Credits", "75/mo"],
              ["Seats", "1"],
              ["News", "Weekly"],
              ["Signals", "Email digest"],
              ["Discovery", "-"],
              ["Overage", "€1.50/cr"],
              ["Onboarding", "Self-serve"],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between">
                <span class="text-[#64748b]">{k}</span>
                <span class="font-medium text-[#0f172a]">{v}</span>
              </div>
            ))}
          </div>
          <a href="/contact" class="mt-6 block text-center rounded-lg border border-[#022f51] text-[#022f51] text-sm font-semibold py-2.5 hover:bg-[#022f51] hover:text-white transition-colors">
            Get started
          </a>
        </div>

        {/* Growth Smarter */}
        <div class="rounded-2xl border-2 border-[#022f51] bg-white p-5 flex flex-col relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-[#022f51] text-white text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">Growth Smarter</span>
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-[#344ca3] mb-3 mt-1">Recommended</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[#022f51]">€</span>
            <span class="text-3xl font-bold text-[#022f51] monthly-price">149</span>
            <span class="text-3xl font-bold text-[#022f51] annual-price hidden">134</span>
            <span class="text-sm text-[#64748b]">/mo</span>
          </div>
          <p class="text-xs text-[#64748b] mb-5">Teams with consistent outbound</p>
          <div class="space-y-2.5 flex-1 text-sm">
            {[
              ["Credits", "150/mo"],
              ["Seats", "2"],
              ["News", "Weekly"],
              ["Signals", "Real-time"],
              ["Discovery", "10/mo"],
              ["Overage", "€1.20/cr"],
              ["Onboarding", "Call"],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between">
                <span class="text-[#64748b]">{k}</span>
                <span class="font-medium text-[#0f172a]">{v}</span>
              </div>
            ))}
          </div>
          <a href="/contact" class="mt-6 block text-center rounded-lg bg-[#022f51] text-white text-sm font-semibold py-2.5 hover:opacity-90 transition-opacity">
            Get started
          </a>
        </div>

        {/* Scale */}
        <div class="rounded-2xl border border-[#e2e8f0] bg-white p-5 flex flex-col">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#64748b] mb-3">Scale</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[#022f51]">€</span>
            <span class="text-3xl font-bold text-[#022f51] monthly-price">349</span>
            <span class="text-3xl font-bold text-[#022f51] annual-price hidden">314</span>
            <span class="text-sm text-[#64748b]">/mo</span>
          </div>
          <p class="text-xs text-[#64748b] mb-5">Full teams, volume</p>
          <div class="space-y-2.5 flex-1 text-sm">
            {[
              ["Credits", "500/mo"],
              ["Seats", "5"],
              ["News", "Weekly"],
              ["Signals", "Real-time"],
              ["Discovery", "Unlimited"],
              ["Overage", "€0.90/cr"],
              ["Onboarding", "Full setup"],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between">
                <span class="text-[#64748b]">{k}</span>
                <span class="font-medium text-[#0f172a]">{v}</span>
              </div>
            ))}
          </div>
          <a href="/contact" class="mt-6 block text-center rounded-lg border border-[#022f51] text-[#022f51] text-sm font-semibold py-2.5 hover:bg-[#022f51] hover:text-white transition-colors">
            Get started
          </a>
        </div>

        {/* Enterprise */}
        <div class="rounded-2xl border border-[#e2e8f0] bg-[#f8fafc] p-5 flex flex-col">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#64748b] mb-3">Enterprise</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[#022f51]">Custom</span>
          </div>
          <p class="text-xs text-[#64748b] mb-5">Sales departments, multi-market</p>
          <div class="space-y-2.5 flex-1 text-sm">
            {[
              ["Credits", "Custom volume"],
              ["Seats", "Unlimited"],
              ["News", "Weekly"],
              ["Signals", "Real-time"],
              ["Discovery", "Unlimited"],
              ["Overage", "Custom rate"],
              ["Onboarding", "Full setup + training"],
            ].map(([k, v]) => (
              <div class="flex items-center justify-between">
                <span class="text-[#64748b]">{k}</span>
                <span class="font-medium text-[#0f172a] text-xs">{v}</span>
              </div>
            ))}
          </div>
          <a href="/contact" class="mt-6 block text-center rounded-lg border border-[#022f51] text-[#022f51] text-sm font-semibold py-2.5 hover:bg-[#022f51] hover:text-white transition-colors">
            Talk to sales
          </a>
        </div>
      </div>

      {/* Credit table */}
      <div class="rounded-2xl border border-[#e2e8f0] bg-white overflow-hidden mb-12">
        <div class="px-6 py-5 border-b border-[#e2e8f0]">
          <h2 class="text-lg font-semibold text-[#022f51]">What credits get you</h2>
          <p class="text-sm text-[#64748b] mt-1">Every credit maps to a clear deliverable. No hidden consumption. No failed lookups charged.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[#e2e8f0]">
                <th class="text-left px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[#64748b]">Action</th>
                <th class="text-left px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[#64748b]">What you get</th>
                <th class="text-right px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[#344ca3]">Credits</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#e2e8f0]">
              {[
                ["Prospect package", "News hook (scored, cited) + buying signal + personalized email + LinkedIn invite + outreach rationale", "1"],
                ["Contact finding", "Verified email + role + company from 20+ sources, triple verified", "2"],
                ["Full prospect", "Everything above combined: contact + research + outreach in one", "3"],
                ["Signal call script", "When a signal fires: opening line, 30-sec pitch, discovery questions, objection handlers. Based on the specific signal.", "1"],
                ["Meeting prep brief", "Deep company research + talking points + key people + recent news. Real-time: ready in under 5 minutes.", "1"],
                ["Company discovery", "Describe a company type, get matching companies back", "1"],
              ].map(([action, desc, credits]) => (
                <tr class="hover:bg-[#f8fafc] transition-colors">
                  <td class="px-6 py-4 font-semibold text-[#0f172a] whitespace-nowrap">{action}</td>
                  <td class="px-6 py-4 text-[#64748b] max-w-md">{desc}</td>
                  <td class="px-6 py-4 text-right">
                    <span class="font-bold text-[#344ca3]">{credits}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Final CTA */}
      <div class="rounded-2xl bg-[#022f51] p-8 text-center text-white">
        <h2 class="text-2xl font-semibold mb-2">Start your free pilot</h2>
        <p class="text-white/70 text-sm mb-6 max-w-md mx-auto">10 full prospect packages. All features. No payment needed. In exchange for a feedback call and case study rights.</p>
        <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-white text-[#022f51] px-6 py-3 text-sm font-semibold hover:opacity-90 transition-opacity">
          Book a demo call
        </a>
      </div>

    </div>
  </section>
</DefaultLayout>

<script>
  let isAnnual = false;

  function toggleBilling() {
    isAnnual = !isAnnual;
    const knob = document.getElementById('toggle-knob');
    const monthly = document.querySelectorAll('.monthly-price');
    const annual = document.querySelectorAll('.annual-price');
    const labelMonthly = document.getElementById('label-monthly');
    const labelAnnual = document.getElementById('label-annual');

    if (isAnnual) {
      knob.style.transform = 'translateX(24px)';
      monthly.forEach(el => el.classList.add('hidden'));
      annual.forEach(el => el.classList.remove('hidden'));
      labelMonthly.classList.add('text-[#64748b]');
      labelMonthly.classList.remove('text-[#0f172a]');
      labelAnnual.classList.add('text-[#0f172a]');
      labelAnnual.classList.remove('text-[#64748b]');
    } else {
      knob.style.transform = 'translateX(0)';
      monthly.forEach(el => el.classList.remove('hidden'));
      annual.forEach(el => el.classList.add('hidden'));
      labelMonthly.classList.remove('text-[#64748b]');
      labelMonthly.classList.add('text-[#0f172a]');
      labelAnnual.classList.remove('text-[#0f172a]');
      labelAnnual.classList.add('text-[#64748b]');
    }
  }

  (window as any).toggleBilling = toggleBilling;
</script>
