---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight } from 'lucide-react';

const values = [
  {
    title: "Quality over volume.",
    body: "Fifty real hooks beat five hundred weak ones. Every time.",
  },
  {
    title: "Built for SME sales teams.",
    body: "One rep or eight, scaling with or without research support. That's the shape we design for. Not enterprise sold down-market.",
  },
  {
    title: "Outreach you'd sign your name to.",
    body: "Generic outreach tools burn sender reputation. We hold a higher bar. Four reasoning passes, a quality check, and if it's not ready, it doesn't ship.",
  },
];
---

<DefaultLayout
  title="About - Hooklyne"
  description="Why we built Hooklyne, who's behind it, and how we think about B2B prospecting research."
  ctaVariant="about"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Hooklyne",
    "url": "https://www.hooklyne.com/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "Hooklyne",
      "url": "https://www.hooklyne.com",
      "foundingLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "NL" } },
      "areaServed": ["NL", "BE", "GB", "LU"],
      "founder": {
        "@type": "Person",
        "name": "Tim",
        "jobTitle": "Founder",
        "worksFor": { "@type": "Organization", "name": "Hooklyne" }
      },
      "identifier": { "@type": "PropertyValue", "propertyID": "KVK", "value": "99990512" }
    }
  })} />
  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:load signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">About</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Proper research, without cutting outreach volume.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          The research layer most B2B teams can't afford to staff. Delivered as software.
        </p>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Why we built this</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-8 leading-tight">
          Nothing fit an SME sales team that still wanted to do outbound right.
        </h2>
        <div class="space-y-5 text-base text-[var(--muted-foreground)] leading-relaxed">
          <p>
            SME sales teams have two bad options. A database that hands you yesterday's news, or an agency that costs more than a junior rep. Neither fits a 10 to 100 person company trying to grow.
          </p>
          <p>
            So we built the third option. Not another database. Not another email writer. The output a dedicated researcher would give you, if you could justify hiring one.
          </p>
          <p class="text-[var(--heading)] font-medium text-lg">
            Six stages. One prospect package. Under a minute to review and send.
          </p>
        </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Founder</p>
            <figure class="relative rounded-2xl overflow-hidden aspect-[4/5]" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-lg);">
              <img
                src="/about/tim-wissink.jpg"
                alt="Tim, founder of Hooklyne"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <div
                class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
                style="background: linear-gradient(180deg, transparent 0%, rgba(2,47,81,0.0) 20%, rgba(2,47,81,0.85) 85%, rgba(2,47,81,0.95) 100%);"
              ></div>
              <figcaption class="absolute left-6 right-6 bottom-6 text-white">
                <div class="text-2xl font-semibold tracking-tight leading-none">Tim Wissink</div>
                <div class="text-sm text-white/75 mt-2">Founder, Hooklyne</div>
              </figcaption>
            </figure>
          </div>

          <div class="lg:col-span-8 lg:pt-12">
            <p class="text-3xl md:text-4xl lg:text-[2.75rem] text-[var(--heading)] leading-[1.25] tracking-tight font-medium">
              "I spent years trying to do proper outbound without a research team behind me. The tool I kept wishing existed didn't. So I built it."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-px flex-1 bg-[var(--border)]"></div>
              <div class="text-xs uppercase tracking-[0.25em] text-[var(--muted-foreground)]">Tim, founder</div>
            </div>
            <div class="mt-8 grid grid-cols-3 gap-6 text-sm">
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Background</div>
                <div class="text-[var(--heading)] font-medium">B2B sales, EMEA</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Focus</div>
                <div class="text-[var(--heading)] font-medium">B2B outbound</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Shipping since</div>
                <div class="text-[var(--heading)] font-medium">2025</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">What we care about</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-12 leading-[1.1] max-w-2xl">
          Three rules we write down and keep.
        </h2>
        <div class="divide-y divide-[var(--border)]">
          {values.map((v, i) => (
            <div class="grid grid-cols-[auto_1fr] gap-6 md:gap-12 py-8 first:pt-0 last:pb-0">
              <div class="font-mono text-sm text-[var(--muted-foreground)] pt-1">0{i + 1}</div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold text-[var(--heading)] mb-2 leading-tight tracking-tight">{v.title}</h3>
                <p class="text-base text-[var(--muted-foreground)] leading-relaxed max-w-2xl">{v.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-6 pb-16 lg:pt-8 lg:pb-24" data-fade>
      <div class="container max-w-4xl">
        <div
          class="relative rounded-3xl p-8 md:p-12 overflow-hidden text-center"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Who we serve</p>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Dutch and UK SMEs first. EN across EMEA.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-7 max-w-2xl mx-auto">
            We start close to home because we speak both languages natively and know the buyers. English-speaking teams elsewhere in EMEA are welcome. GDPR-compliant by design.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href="/contact"
              class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
            >
              Start your free pilot
              <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
            <a
              href="/how-it-works"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
            >
              See how it works
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </Background>
</DefaultLayout>

<style>
  .shape-dot {
    box-shadow: 0 0 0 0 currentColor;
    animation: shape-dot-pulse 6s ease-in-out infinite;
  }
  .shape-dot-0 { animation-delay: 0s; }
  .shape-dot-1 { animation-delay: 1.5s; }
  .shape-dot-2 { animation-delay: 3s; }
  .shape-dot-3 { animation-delay: 4.5s; }

  @keyframes shape-dot-pulse {
    0%, 80%, 100% { transform: scale(1); opacity: 1; }
    5% { transform: scale(1.6); opacity: 0.8; }
    10% { transform: scale(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shape-dot { animation: none; }
  }
</style>
