---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight } from 'lucide-react';

const values = [
  {
    title: "Quality over volume.",
    body: "Fifty real hooks beat five hundred weak ones. Every time.",
  },
  {
    title: "Built for SME sales teams.",
    body: "One rep or eight, scaling with or without research support. That's the shape we design for. Not enterprise sold down-market.",
  },
  {
    title: "Outreach you'd sign your name to.",
    body: "Generic outreach tools burn sender reputation. We hold a higher bar. Four reasoning passes, a quality check, and if it's not ready, it doesn't ship.",
  },
];
---

<DefaultLayout
  title="About - Hooklyne"
  description="Why we built Hooklyne, who's behind it, and how we think about B2B prospecting research."
  ctaVariant="about"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Hooklyne",
    "url": "https://www.hooklyne.com/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "Hooklyne",
      "url": "https://www.hooklyne.com",
      "foundingLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "NL" } },
      "areaServed": ["NL", "BE", "GB", "LU"],
      "founder": {
        "@type": "Person",
        "name": "Tim",
        "jobTitle": "Founder",
        "worksFor": { "@type": "Organization", "name": "Hooklyne" }
      },
      "identifier": { "@type": "PropertyValue", "propertyID": "KVK", "value": "99990512" }
    }
  })} />
  <Background>
    <section class="pt-32 lg:pt-44 pb-14 lg:pb-20 relative" data-fade>
      <HeroGlow client:load />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">About</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Proper research, without cutting outreach volume.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          The research layer most B2B teams can't afford to staff. Delivered as software.
        </p>
      </div>
    </section>

    <section class="pb-16 lg:pb-24 relative">
      <div class="container max-w-5xl">
        <div class="about-shape rounded-2xl p-5 md:p-7 relative overflow-hidden" style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-2">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--hooklyne-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[var(--hooklyne-blue)]">What we do</span>
            </div>
            <span class="text-[10px] font-mono text-[var(--muted-foreground)] hidden sm:block">EMEA B2B</span>
          </div>

          <div class="shape-grid grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-3">
            {[
              { label: "Built for", value: "SME sales teams", sub: "10 to 100 person companies", tone: "orange" },
              { label: "Languages", value: "Dutch and English", sub: "Native, not translated", tone: "teal" },
              { label: "Coverage", value: "EMEA", sub: "NL and UK first, DACH and Nordics", tone: "blue" },
              { label: "Compliance", value: "GDPR-first", sub: "EU data, EU providers", tone: "blue" },
            ].map((s, i) => (
              <div class="shape-cell relative flex flex-col gap-1.5 md:px-4 md:border-l md:border-[var(--border)] md:first:border-l-0 md:first:pl-0">
                <div class="flex items-center gap-1.5">
                  <span class={`shape-dot size-1.5 rounded-full shape-dot-${i}`} style={`background: var(--hooklyne-${s.tone});`}></span>
                  <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[var(--muted-foreground)]">{s.label}</span>
                </div>
                <div class="text-base md:text-lg font-semibold text-[var(--heading)] tracking-tight leading-none">{s.value}</div>
                <div class="text-[11px] text-[var(--muted-foreground)]">{s.sub}</div>
              </div>
            ))}
          </div>

          <div class="mt-6 pt-4 border-t border-[var(--border)] flex items-center justify-end flex-wrap gap-2">
            <span class="text-[11px] text-[var(--muted-foreground)]">KVK 99990512</span>
          </div>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Why we built this</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-8 leading-tight">
          Nothing fit an SME sales team that still wanted to do outbound right.
        </h2>
        <div class="space-y-5 text-base text-[var(--muted-foreground)] leading-relaxed">
          <p>
            SME sales teams have two bad options. A database that hands you yesterday's news, or an agency that costs more than a junior rep. Neither fits a 10 to 100 person company trying to grow.
          </p>
          <p>
            So we built the third option. Not another database. Not another email writer. The output a dedicated researcher would give you, if you could justify hiring one.
          </p>
          <p class="text-[var(--heading)] font-medium text-lg">
            Six stages. One prospect package. Under a minute to review and send.
          </p>
        </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Founder</p>
            <figure class="relative rounded-2xl overflow-hidden aspect-[4/5]" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-lg);">
              <img
                src="/about/tim-wissink.jpg"
                alt="Tim, founder of Hooklyne"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <div
                class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
                style="background: linear-gradient(180deg, transparent 0%, rgba(2,47,81,0.0) 20%, rgba(2,47,81,0.85) 85%, rgba(2,47,81,0.95) 100%);"
              ></div>
              <figcaption class="absolute left-6 right-6 bottom-6 text-white">
                <div class="text-2xl font-semibold tracking-tight leading-none">Tim Wissink</div>
                <div class="text-sm text-white/75 mt-2">Founder, Hooklyne</div>
              </figcaption>
            </figure>
          </div>

          <div class="lg:col-span-8 lg:pt-12">
            <p class="text-3xl md:text-4xl lg:text-[2.75rem] text-[var(--heading)] leading-[1.25] tracking-tight font-medium">
              "I spent years trying to do proper outbound without a research team behind me. The tool I kept wishing existed didn't. So I built it."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-px flex-1 bg-[var(--border)]"></div>
              <div class="text-xs uppercase tracking-[0.25em] text-[var(--muted-foreground)]">Tim, founder</div>
            </div>
            <div class="mt-8 grid grid-cols-3 gap-6 text-sm">
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Background</div>
                <div class="text-[var(--heading)] font-medium">B2B sales, EMEA</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Focus</div>
                <div class="text-[var(--heading)] font-medium">B2B outbound</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Shipping since</div>
                <div class="text-[var(--heading)] font-medium">2025</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-5xl">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">What it looks like</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            One prospect. One screen. Ready to send.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Verified contact, live signal, drafted message. Everything a researcher would hand you, without hiring one.
          </p>
        </div>

        <div class="relative rounded-2xl overflow-hidden" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xl);">
          <div class="grid md:grid-cols-5 gap-0">
            <div class="md:col-span-2 p-6 md:p-7" style="background: linear-gradient(180deg, var(--background) 0%, var(--card) 100%); border-right: 1px solid var(--border);">
              <div class="flex items-center justify-between mb-4">
                <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[var(--hooklyne-blue)]">Company</span>
                <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-0.5 rounded-full" style="background: rgba(13,148,136,0.12); color: var(--hooklyne-teal);">
                  <span class="size-1 rounded-full bg-[var(--hooklyne-teal)]"></span>
                  9/10 fit
                </span>
              </div>
              <div class="flex items-center gap-3 mb-4">
                <div class="size-10 rounded-lg flex items-center justify-center text-white text-sm font-bold" style="background: linear-gradient(135deg, #1e3a8a 0%, #2b4fb3 100%);">AB</div>
                <div>
                  <div class="text-sm font-semibold text-[var(--heading)]">Acme B.V.</div>
                  <div class="text-[11px] text-[var(--muted-foreground)]">Industrial OEM · NL · 85 staff</div>
                </div>
              </div>
              <div class="rounded-lg p-3 mb-4" style="background: rgba(255,140,66,0.08); border: 1px solid rgba(255,140,66,0.22);">
                <div class="flex items-center gap-1.5 mb-1">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--hooklyne-orange)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m4.93 4.93 2.83 2.83"/><path d="M2 12h4"/></svg>
                  <span class="text-[9px] font-bold uppercase tracking-[0.18em]" style="color: var(--hooklyne-orange);">Signal · 2h ago</span>
                </div>
                <p class="text-[12px] font-semibold text-[var(--heading)] leading-snug">Raised €12M Series B</p>
                <p class="text-[11px] text-[var(--muted-foreground)] mt-0.5">Expansion plans named in release</p>
              </div>
              <div class="flex items-center gap-2.5">
                <div class="size-8 rounded-full flex items-center justify-center text-[11px] font-semibold text-white" style="background: var(--hooklyne-navy);">MJ</div>
                <div class="min-w-0 flex-1">
                  <div class="text-[12px] font-semibold text-[var(--heading)] truncate">Marieke Jansen</div>
                  <div class="text-[10px] text-[var(--muted-foreground)]">VP Operations</div>
                </div>
                <span class="inline-flex items-center gap-1 text-[9px] font-semibold px-1.5 py-0.5 rounded" style="background: rgba(13,148,136,0.12); color: var(--hooklyne-teal);">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Verified
                </span>
              </div>
            </div>

            <div class="md:col-span-3 p-6 md:p-7">
              <div class="flex items-center justify-between mb-4">
                <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[var(--hooklyne-blue)]">Draft · in your voice</span>
                <span class="text-[10px] font-mono text-[var(--muted-foreground)]">4 passes · QC</span>
              </div>
              <div class="space-y-2.5 text-[13px] text-[var(--foreground)] leading-relaxed">
                <p><span class="text-[var(--muted-foreground)]">Subject:</span> Operations scale-up after the Series B</p>
                <p class="pt-2 border-t border-[var(--border)]">Hi Marieke,</p>
                <p>Saw the Series B news. Scaling ops after a raise that size usually means process debt surfaces fast.</p>
                <p>We help Dutch OEMs find and brief the right decision-makers at companies on the edge of their ICP, in about a minute per prospect. Worth a short call?</p>
                <p class="text-[var(--muted-foreground)]">- Tim</p>
              </div>
              <div class="flex items-center justify-end gap-2 mt-5 pt-4 border-t border-[var(--border)]">
                <button class="text-[11px] font-semibold px-3 py-1.5 rounded-md text-[var(--muted-foreground)] hover:bg-[var(--card-hover)]" disabled>Edit</button>
                <button class="text-[11px] font-semibold px-3 py-1.5 rounded-md text-white btn-shine" style="background: var(--hooklyne-navy);" disabled>Send</button>
              </div>
            </div>
          </div>
        </div>

        <p class="text-center text-xs italic text-[var(--muted-foreground)] mt-6">Example output. Fictional prospect.</p>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">What we care about</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-12 leading-[1.1] max-w-2xl">
          Three rules we write down and keep.
        </h2>
        <div class="divide-y divide-[var(--border)]">
          {values.map((v, i) => (
            <div class="grid grid-cols-[auto_1fr] gap-6 md:gap-12 py-8 first:pt-0 last:pb-0">
              <div class="font-mono text-sm text-[var(--muted-foreground)] pt-1">0{i + 1}</div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold text-[var(--heading)] mb-2 leading-tight tracking-tight">{v.title}</h3>
                <p class="text-base text-[var(--muted-foreground)] leading-relaxed max-w-2xl">{v.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-6xl">
        <div
          class="rounded-3xl p-10 lg:p-14"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Who we serve</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-tight">
            Dutch and UK SMEs first. EN across EMEA.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6 max-w-2xl">
            We start close to home because we speak both languages natively and know the buyers. English-speaking teams elsewhere in EMEA are welcome. GDPR-compliant by design.
          </p>
          <div class="inline-flex items-center gap-2 text-sm" style="color: var(--muted-foreground);">
            <span class="text-xs font-semibold uppercase tracking-widest">KVK</span>
            <span class="font-mono text-sm text-[var(--heading)]">99990512</span>
          </div>
        </div>
      </div>
    </section>

    {/* Directional, not committed roadmap. If pilots plan or Q3 integration dates shift, update these three lines. */}
    <section class="pt-4 pb-20 lg:pt-6 lg:pb-28" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-orange)] mb-3">Where we are going</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-6 leading-tight">
            Small steps, shipped often.
          </h2>
          <ul class="flex flex-col gap-3">
            {[
              "Pilots running with Dutch and UK SMEs through Q2 2026.",
              "Integrations with HubSpot and Pipedrive shipping in Q3.",
              "Next market expansion: DACH. Dutch speakers already covered.",
            ].map((line) => (
              <li class="flex items-start gap-3 text-base text-[var(--muted-foreground)] leading-relaxed">
                <span class="mt-[9px] flex-none w-1.5 h-1.5 rounded-full" style="background: var(--hooklyne-blue);"></span>
                <span>{line}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </Background>
</DefaultLayout>

<style>
  .shape-dot {
    box-shadow: 0 0 0 0 currentColor;
    animation: shape-dot-pulse 6s ease-in-out infinite;
  }
  .shape-dot-0 { animation-delay: 0s; }
  .shape-dot-1 { animation-delay: 1.5s; }
  .shape-dot-2 { animation-delay: 3s; }
  .shape-dot-3 { animation-delay: 4.5s; }

  @keyframes shape-dot-pulse {
    0%, 80%, 100% { transform: scale(1); opacity: 1; }
    5% { transform: scale(1.6); opacity: 0.8; }
    10% { transform: scale(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shape-dot { animation: none; }
  }
</style>
