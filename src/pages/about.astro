---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { ArrowRight } from 'lucide-react';

const values = [
  {
    title: "Research quality over volume.",
    body: "More prospects isn't better. Better prospects is better. We'd rather ship 50 real hooks than 500 weak ones.",
    tone: "blue",
  },
  {
    title: "Tools that fit a small team.",
    body: "Most B2B software is built for big sales teams and sold down-market. We build for small teams from the start - 1 to 3 reps, no operations support, limited budget. Everything is designed to work in that shape.",
    tone: "orange",
  },
  {
    title: "Outreach that doesn't embarrass the sender.",
    body: "The bar for \"good enough\" AI outreach has dropped so low that a lot of it is genuinely harmful to the sender's reputation. We hold a higher bar. Every message that ships has been through multiple reasoning passes and a quality check. If it's not ready to send, we don't send it to you.",
    tone: "teal",
  },
];

const team = [
  {
    name: "Tim",
    role: "Founder - research engine",
    initial: "T",
    body: "Builds the research engine: discovery, verification, signals, drafting. Ex-B2B sales, has used every prospecting tool on the market and was done compromising.",
  },
  {
    name: "Joey",
    role: "Co-founder - product",
    initial: "J",
    body: "Builds the product you see: the portal, the interfaces, the daily experience. Keeps the tool usable for a rep with 20 minutes between calls.",
  },
];
---

<DefaultLayout
  title="About Hooklyne - Built for B2B teams who take prospecting seriously"
  description="Why we built Hooklyne, who's behind it, and how we think about B2B prospecting research."
>
  <Background>
    <section class="pt-32 lg:pt-40 pb-12" data-fade>
      <div class="container max-w-4xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">About</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-6">
          Built by people who were tired of choosing between proper research and enough outreach.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Hooklyne exists because B2B sales teams deserve better than cheap databases and expensive agencies. We built the research layer most teams can't afford to staff.
        </p>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-20 lg:py-24" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-orange)] mb-4">Why we built this</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-8 leading-tight">
          There was nothing built for a 15-person team that still wanted to do outbound properly.
        </h2>
        <div class="space-y-5 text-base text-[var(--muted-foreground)] leading-relaxed">
          <p>
            Most B2B teams we've worked with have the same problem. A handful of sales reps, no research support, and a choice between two bad options: prospect from a database that hands you yesterday's news, or hire an agency that charges more than a junior rep's salary. Neither works for a 10-person company trying to grow.
          </p>
          <p>
            We wanted to build something different. Not another database. Not another AI email writer. A proper research workflow - the kind of output a dedicated researcher would give you, if you could justify hiring one - delivered as software.
          </p>
          <p class="text-[var(--heading)] font-medium text-lg">
            The result is Hooklyne. Six specialised stages working together to produce prospect packages your reps can act on in under a minute. Built in the Netherlands, used by B2B teams across EMEA.
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-24" data-fade>
      <div class="container max-w-5xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">The team</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-tight">
          Two founders. A small group of collaborators.
        </h2>
        <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-10 max-w-2xl">
          Hooklyne is built by Tim and Joey, with help from a small group of collaborators. Tim builds the research engine. Joey builds the product you see. Both of us have done B2B sales and both of us have used every tool on the market.
        </p>

        <div class="grid md:grid-cols-2 gap-5">
          {team.map((t) => (
            <div
              class="rounded-2xl p-6 flex gap-5 items-start"
              style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
            >
              <div
                class="size-16 shrink-0 rounded-full flex items-center justify-center text-xl font-semibold"
                style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue); border: 1px dashed var(--border-strong);"
              >
                {t.initial}
              </div>
              <div>
                <div class="text-base font-semibold text-[var(--heading)]">{t.name}</div>
                <div class="text-xs text-[var(--muted-foreground)] mb-2">{t.role}</div>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{t.body}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="text-xs text-[var(--muted-foreground)] mt-4">
          Placeholder avatars for now. Real headshots go here in the next pass.
        </p>
      </div>
    </section>

    <section class="py-20 lg:py-24" data-fade>
      <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-4">What we care about</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-10 leading-tight max-w-2xl">
          How we think about the work.
        </h2>
        <div class="grid md:grid-cols-3 gap-5">
          {values.map((v) => (
            <div
              class="rounded-2xl p-6"
              style={`background: var(--card); border: 1px solid var(--border); border-top: 3px solid var(--hooklyne-${v.tone});`}
            >
              <h3 class="text-lg font-semibold text-[var(--heading)] mb-3 leading-tight">{v.title}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-24" data-fade>
      <div class="container max-w-4xl">
        <div
          class="rounded-3xl p-10 lg:p-14"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Where we are</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-tight">
            Dutch-built. EMEA-focused.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6 max-w-2xl">
            We're based in the Netherlands. Our core audience is B2B SMEs in the Netherlands and the UK, with strong support for the rest of EMEA. Dutch and English from day one - native, not translated. GDPR-compliant throughout, by design rather than as a bolt-on.
          </p>
          <div class="inline-flex items-center gap-2 text-sm" style="color: var(--muted-foreground);">
            <span class="text-xs font-semibold uppercase tracking-widest">KVK</span>
            <span class="font-mono text-sm text-[var(--heading)]">99990512</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-3xl text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
          Want to see it work?
        </h2>
        <p class="text-base md:text-lg text-[var(--muted-foreground)] mb-8 max-w-xl mx-auto leading-relaxed">
          Ten prospect packages, free, in exchange for a 20-minute feedback call.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group"
          >
            Start your free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="/faq"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Read the FAQ
            <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
