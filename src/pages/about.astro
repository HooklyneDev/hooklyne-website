---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight, ChatsCircle, Target, PencilSimpleLine, Calendar, Envelope, Compass } from "@phosphor-icons/react";

const values = [
  {
    icon: ChatsCircle,
    title: "Selling is still personal.",
    body: "Buying decisions still come down to one person picking up the phone. Software should free you up for that conversation, not pretend to replace it. The relationship is your rep's, not the tool's.",
  },
  {
    icon: Target,
    title: "Quality over volume.",
    body: "Fifty real hooks beat five hundred weak ones. We'd rather ship ten prospects you'd actually be proud to send than a hundred you'd be embarrassed by.",
  },
  {
    icon: PencilSimpleLine,
    title: "Outreach you'd sign your name to.",
    body: "Generic outreach burns sender reputation fast. Four reasoning passes, a quality check, and if it's not ready, it doesn't ship. Even if that means we ship fewer.",
  },
];

const pillars = [
  {
    icon: Calendar,
    title: "Founder-led onboarding.",
    body: "Your first ICP setup runs through Tim, not a junior. 30 minutes on a call. We learn what you sell, who you sell to, and how you actually talk to them.",
  },
  {
    icon: Envelope,
    title: "Direct team access.",
    body: "One Slack channel or email thread per customer. Replies inside four hours during business days. No ticket queue, no script, no chat-bot triage.",
  },
  {
    icon: Compass,
    title: "Your sector shapes the defaults.",
    body: "The first ten prospects in your pilot calibrate the system to your market. We keep tuning until the output reads like your rep wrote it after doing the research.",
  },
];

const replaced = [
  "Apollo / Cognism / Lusha",
  "Clay or Findymail",
  "ChatGPT or Claude",
  "A spreadsheet of signals",
  "A second sequencer for warm-up",
  "The hour you spent writing each email",
];

import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "About", path: "/about" },
]);
---

<DefaultLayout
  title="About | Hooklyne"
  description="A small Dutch team building B2B prospect research for SMEs. Founder-led pilots, direct access, your sector shapes the defaults."
  image="/og/EN/about.jpg"
  ctaVariant="about"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Hooklyne",
    "url": "https://www.hooklyne.com/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "Hooklyne",
      "url": "https://www.hooklyne.com",
      "foundingLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "NL" } },
      "areaServed": ["NL", "BE", "GB", "LU"],
      "founder": {
        "@type": "Person",
        "name": "Tim Wissink",
        "jobTitle": "Founder",
        "worksFor": { "@type": "Organization", "name": "Hooklyne" }
      },
      "identifier": { "@type": "PropertyValue", "propertyID": "KVK", "value": "99990512" }
    }
  })} />
  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">About</p>
        <h1 class="hero-headline text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          A small team that <span class="text-accent">does the research itself</span>.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Until we grow, you get us. The people who built the workflow run your pilot, set up your ICP, and answer the phone when something breaks.
        </p>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-[3fr_2fr] gap-10 lg:gap-16 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Why we built this</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-8 leading-tight">
              Ten years of doing the job. Built from every limit we hit.
            </h2>
            <div class="space-y-5 text-base text-[var(--muted-foreground)] leading-relaxed">
              <p>
                We've been in your seat. Ten-plus years of running outbound at international B2B companies came first - selling, being sold to, hiring SDRs, firing agencies, and trying every tool the market threw at us.
              </p>
              <p>
                Most of those years went into moving information between subscriptions: one tool for company data, another for contacts, another for signals, a CRM that didn't talk to any of them. The workflow lived in seven tabs. Every week, hours of shuffling rows just to brief one prospect.
              </p>
              <p>
                We kept a list of every limitation. Bounce rates from single-source databases. AI agents that hallucinated buying signals. Templates that read as templates. Agency quotes higher than the quota they promised. ChatGPT drafts that needed rewriting twice before they sounded like us.
              </p>
              <p>
                Hooklyne is what happens when you stop working around those limits and build a complete tool for the sales rep instead - the rep who has to actually open the inbox on Monday morning, not the buyer signing the SaaS contract.
              </p>
              <p class="text-[var(--heading)] font-medium text-lg">
                One place. One prospect. All the context a researcher would hand you. Under a minute to review.
              </p>
            </div>
          </div>

          <div class="lg:pt-12">
            <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--hooklyne-orange)] mb-4">What we replaced</p>
              <ul class="space-y-2.5">
                {replaced.map((r) => (
                  <li class="flex items-center gap-2.5 text-sm text-[var(--muted-foreground)]">
                    <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-orange);"><path d="M18 6 6 18M6 6l12 12"/></svg>
                    <span class="line-through">{r}</span>
                  </li>
                ))}
              </ul>
              <div class="my-5 h-px" style="background: var(--border);"></div>
              <div class="flex items-center gap-2.5 text-sm font-semibold text-[var(--heading)]">
                <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-teal);"><path d="M20 6 9 17l-5-5"/></svg>
                <span>One Hooklyne portal</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10 lg:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">How we work with you</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            While we're small, you get direct access.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Three pilots in. We're not a SaaS support queue yet, and we don't pretend to be. The founder runs your setup, the team answers your messages, and the output is shaped by you, not by an average customer that doesn't exist.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-4 md:gap-5">
          {pillars.map((p) => {
            const Icon = p.icon;
            return (
              <div class="rounded-2xl p-6 md:p-7 flex flex-col" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs);">
                <span class="block mb-4" style="color: var(--hooklyne-blue);">
                  <Icon className="size-7" />
                </span>
                <h3 class="text-lg font-semibold text-[var(--heading)] tracking-tight mb-2 leading-snug">{p.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{p.body}</p>
              </div>
            );
          })}
        </div>

      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Founder</p>
            <figure class="relative rounded-2xl overflow-hidden aspect-[4/5]" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-lg);">
              <picture>
                <source srcset="/about/tim-wissink.webp" type="image/webp" />
                <img
                  src="/about/tim-wissink.jpg"
                  alt="Tim, founder of Hooklyne"
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="529"
                  class="absolute inset-0 w-full h-full object-cover"
                />
              </picture>
              <div
                class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
                style="background: linear-gradient(180deg, transparent 0%, rgba(2,47,81,0.0) 20%, rgba(2,47,81,0.85) 85%, rgba(2,47,81,0.95) 100%);"
              ></div>
              <figcaption class="absolute left-6 right-6 bottom-6 text-white">
                <div class="text-2xl font-semibold tracking-tight leading-none">Tim Wissink</div>
                <div class="text-sm text-white/75 mt-2">Founder, Hooklyne</div>
              </figcaption>
            </figure>
          </div>

          <div class="lg:col-span-8 lg:pt-12">
            <p class="text-3xl md:text-4xl lg:text-[2.75rem] text-[var(--heading)] leading-[1.25] tracking-tight font-medium">
              "Selling is still a human thing. Software should free you up for the conversation, not try to replace it."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-px flex-1 bg-[var(--border)]"></div>
              <div class="text-xs uppercase tracking-[0.25em] text-[var(--muted-foreground)]">Tim, founder</div>
            </div>
            <div class="mt-8 grid grid-cols-3 gap-6 text-sm">
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Background</div>
                <div class="text-[var(--heading)] font-medium">10+ years, international B2B sales</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Live since</div>
                <div class="text-[var(--heading)] font-medium">February 2026</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">In pilot with</div>
                <div class="text-[var(--heading)] font-medium">3 Dutch teams</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">What we care about</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-10 leading-[1.1] max-w-2xl">
          Three rules we write down and keep.
        </h2>
        <div class="grid md:grid-cols-3 gap-4 md:gap-5">
          {values.map((v, i) => {
            const Icon = v.icon;
            return (
              <div class="rounded-2xl p-6 md:p-7 flex flex-col h-full" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs);">
                <div class="flex items-center gap-3 mb-4">
                  <span class="font-mono text-xs text-[var(--muted-foreground)]">0{i + 1}</span>
                  <span class="h-3 w-px bg-[var(--border)]"></span>
                  <span style="color: var(--hooklyne-teal);">
                    <Icon className="size-5" />
                  </span>
                </div>
                <h3 class="text-lg md:text-xl font-semibold text-[var(--heading)] mb-2 leading-snug tracking-tight">{v.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{v.body}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10 lg:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Company</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            The boring details. On the page, not buried.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Who we are, where we are, and what we won't do with your data.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 md:gap-5">
          <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-5">
              <span class="size-1.5 rounded-full" style="background: var(--hooklyne-blue);"></span>
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--hooklyne-blue)]">Registered</p>
            </div>
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 text-sm">
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Name</dt>
              <dd class="text-[var(--heading)] font-medium">Hooklyne</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">KVK</dt>
              <dd class="text-[var(--heading)] font-medium font-mono tabular-nums">99990512</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Country</dt>
              <dd class="text-[var(--heading)] font-medium">Netherlands</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Live since</dt>
              <dd class="text-[var(--heading)] font-medium">February 2026</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Founder</dt>
              <dd class="text-[var(--heading)] font-medium">Tim Wissink</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Pilot</dt>
              <dd class="text-[var(--heading)] font-medium">3 Dutch teams</dd>
            </dl>
          </div>

          <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-5">
              <span class="size-1.5 rounded-full" style="background: var(--hooklyne-teal);"></span>
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em]" style="color: var(--hooklyne-teal);">Posture</p>
            </div>
            <ul class="space-y-3.5 text-sm leading-relaxed">
              {[
                { t: "EU-based, GDPR-compliant.", b: "Data stays in the EU. We process what's needed for outreach research, nothing more." },
                { t: "We don't sell or share contact data.", b: "What's verified for your account stays in your account. No data brokerage, ever." },
                { t: "Your inbox, your domain.", b: "We don't run sequences for you. Sending happens from your mailbox so the relationship stays yours." },
                { t: "Nothing ships unverified.", b: "If a contact can't clear all four deliverability layers, it's held back. Your sender reputation matters more than the volume." },
              ].map((p) => (
                <li class="flex items-start gap-3">
                  <svg class="size-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-teal);"><path d="M20 6 9 17l-5-5"/></svg>
                  <div>
                    <p class="font-semibold text-[var(--heading)]">{p.t}</p>
                    <p class="text-[var(--muted-foreground)] mt-0.5">{p.b}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-4xl">
        <div
          class="glass-off relative rounded-3xl p-8 md:p-12 overflow-hidden text-center"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Who we serve</p>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Dutch and UK SMEs first. EN across EMEA.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-7 max-w-2xl mx-auto">
            We start close to home because we speak both languages natively and know the buyers. English-speaking teams elsewhere in EMEA are welcome. GDPR-compliant.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href="/contact"
              class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
            >
              Start your free pilot
              <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
            <a
              href="/how-it-works"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
            >
              See how it works
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </Background>
</DefaultLayout>
