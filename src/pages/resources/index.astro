---
import { Background } from '@/components/background';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const cards = [
  {
    href: '/faq',
    eyebrow: 'Answers',
    title: 'FAQ',
    body: 'The questions we hear most. How Hooklyne works, data quality, signals, credits, plans, and pilots.',
  },
  {
    href: '/blog',
    eyebrow: 'Updates',
    title: 'Blog',
    body: 'Product updates, founder notes, comparisons, and practical guides on B2B prospecting.',
  },
];
---

<DefaultLayout
  title="Resources - Hooklyne"
  description="Answers, product updates, and notes from the Hooklyne team. The FAQ and the news feed, in one place."
  ctaVariant="home"
>
  <Background>
    <section class="pt-32 lg:pt-40 pb-10">
      <div class="container max-w-5xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Resources</p>
        <h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4">Resources.</h1>
        <p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl leading-relaxed">
          Answers, product updates, and notes from the team. Two places to look.
        </p>
      </div>
    </section>

    <section class="pb-28 lg:pb-32">
      <div class="container max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {cards.map((c) => (
            <a
              href={c.href}
              class="group block rounded-2xl p-7 md:p-8 transition-colors"
              style="background: var(--card); border: 1px solid var(--border);"
            >
              <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">{c.eyebrow}</p>
              <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-3 group-hover:text-[var(--hooklyne-blue)] transition-colors">{c.title}</h2>
              <p class="text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed mb-5">{c.body}</p>
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--hooklyne-navy)] group-hover:text-[var(--hooklyne-blue)] transition-colors">
                Open
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
