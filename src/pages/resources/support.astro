---
import { Background } from '@/components/background';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Envelope, ChatCircle, BookOpen, ArrowRight } from "@phosphor-icons/react";
---

<DefaultLayout
  title="Support - Hooklyne"
  description="Get help with Hooklyne. Reach the team, find answers, and learn how to get more out of your prospect research."
  ctaVariant="home"
>
  <Background>
    <section class="pt-32 lg:pt-40 pb-10">
      <div class="container max-w-5xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Resources</p>
        <h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4">Support.</h1>
        <p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl leading-relaxed">
          Real humans, clear answers. Pick the route that fits what you need.
        </p>
      </div>
    </section>

    <section class="pb-14">
      <div class="container max-w-5xl">
        <div class="grid gap-4 md:grid-cols-3">

          <a
            href="/faq"
            class="group rounded-2xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1"
            style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
          >
            <BookOpen className="size-8 mb-4" style="color: var(--hooklyne-blue);" />
            <h2 class="text-[15px] font-semibold text-[var(--heading)] mb-2 leading-tight">Browse the FAQ</h2>
            <p class="text-[13px] text-[var(--muted-foreground)] leading-relaxed flex-1 mb-4">
              The fastest answers on credits, pricing, data handling, and how the free trial works.
            </p>
            <span class="text-[12px] font-semibold text-[var(--hooklyne-blue)] inline-flex items-center gap-1">
              Read the FAQ
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </span>
          </a>

          <a
            href="#message-form"
            class="group rounded-2xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1"
            style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
          >
            <Envelope className="size-8 mb-4" style="color: var(--hooklyne-teal);" />
            <h2 class="text-[15px] font-semibold text-[var(--heading)] mb-2 leading-tight">Send us a message</h2>
            <p class="text-[13px] text-[var(--muted-foreground)] leading-relaxed flex-1 mb-4">
              Something not working, or a question only a human can answer. We reply within one business day.
            </p>
            <span class="text-[12px] font-semibold inline-flex items-center gap-1" style="color: var(--hooklyne-teal);">
              Open the form
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </span>
          </a>

          <a
            href="/contact"
            class="group rounded-2xl p-6 flex flex-col transition-all duration-300 hover:-translate-y-1"
            style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
          >
            <ChatCircle className="size-8 mb-4" style="color: var(--hooklyne-orange);" />
            <h2 class="text-[15px] font-semibold text-[var(--heading)] mb-2 leading-tight">Talk to someone</h2>
            <p class="text-[13px] text-[var(--muted-foreground)] leading-relaxed flex-1 mb-4">
              Walk through the product, scope a trial, or get a tailored answer for your team. Book a short call.
            </p>
            <span class="text-[12px] font-semibold inline-flex items-center gap-1" style="color: var(--hooklyne-orange);">
              Book a call
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </span>
          </a>

        </div>
      </div>
    </section>

    <section id="message-form" class="pb-14 scroll-mt-24">
      <div class="container max-w-2xl">
        <div class="mb-6">
          <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">Send a message</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-3">Tell us what you need.</h2>
          <p class="text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed">
            Lands in our support inbox. Real humans read it. Most replies inside four hours.
          </p>
        </div>

        <form
          id="support-form"
          action="/api/contact"
          method="POST"
          class="rounded-2xl p-6 md:p-8 space-y-5"
          style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
        >
          <input type="hidden" name="subject" value="New support message from hooklyne.com" />
          <input type="hidden" name="from_name" value="Hooklyne website" />
          {/* Honeypot anti-spam. Bots fill it, humans do not. */}
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" aria-hidden="true" tabindex="-1" />

          <div>
            <label for="sf-name" class="block text-[12px] font-semibold text-[var(--heading)] mb-1.5">Name</label>
            <input
              id="sf-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="w-full px-3.5 py-2.5 text-sm rounded-lg transition-colors"
              style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="sf-email" class="block text-[12px] font-semibold text-[var(--heading)] mb-1.5">Email</label>
            <input
              id="sf-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-3.5 py-2.5 text-sm rounded-lg transition-colors"
              style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="you@company.com"
            />
          </div>

          <div>
            <label for="sf-topic" class="block text-[12px] font-semibold text-[var(--heading)] mb-1.5">Topic</label>
            <select
              id="sf-topic"
              name="topic"
              class="w-full px-3.5 py-2.5 text-sm rounded-lg transition-colors"
              style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
            >
              <option>General question</option>
              <option>Something not working</option>
              <option>Billing or credits</option>
              <option>Trial request</option>
              <option>Other</option>
            </select>
          </div>

          <div>
            <label for="sf-message" class="block text-[12px] font-semibold text-[var(--heading)] mb-1.5">Message</label>
            <textarea
              id="sf-message"
              name="message"
              required
              rows="6"
              class="w-full px-3.5 py-2.5 text-sm rounded-lg transition-colors resize-y"
              style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
              placeholder="Tell us what is going on, what you have tried, and what you expected."
            ></textarea>
          </div>

          <div class="flex items-center justify-between gap-4 pt-1">
            <p class="text-[11px] text-[var(--muted-foreground)] leading-relaxed">
              By submitting, you agree to our <a href="/privacy" class="underline underline-offset-2 hover:text-[var(--hooklyne-blue)]">privacy policy</a>.
            </p>
            <button
              type="submit"
              id="sf-submit"
              class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90 disabled:opacity-60 disabled:cursor-not-allowed shrink-0"
              style="background-color: var(--hooklyne-navy);"
            >
              <span id="sf-submit-label">Send message</span>
            </button>
          </div>

          <div
            id="sf-success"
            class="hidden rounded-lg p-3.5 text-sm"
            style="background: rgba(13,148,136,0.10); border: 1px solid rgba(13,148,136,0.30); color: var(--hooklyne-teal);"
          >
            Message sent. We will reply to the email you provided within one business day.
          </div>
          <div
            id="sf-error"
            class="hidden rounded-lg p-3.5 text-sm"
            style="background: rgba(255,140,66,0.10); border: 1px solid rgba(255,140,66,0.30); color: var(--hooklyne-orange);"
          >
            Something went wrong. Please email <a href="mailto:contact@hooklyne.com" class="underline underline-offset-2">contact@hooklyne.com</a> directly.
          </div>
        </form>
      </div>
    </section>

    <section class="pb-20">
      <div class="container max-w-3xl">
        <div
          class="rounded-2xl p-6 md:p-8 text-center"
          style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
        >
          <p class="text-[11px] font-semibold uppercase tracking-[0.25em] text-[var(--muted-foreground)] mb-3">Response times</p>
          <p class="text-sm text-[var(--heading)] leading-relaxed mb-1">
            Email support is handled by the team, not a ticket queue.
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Weekdays, Amsterdam hours. Most replies inside four hours, never later than one business day.
          </p>
        </div>
      </div>
    </section>

    <script is:inline>
      (() => {
        const form = document.getElementById("support-form");
        if (!form) return;
        const submitBtn = document.getElementById("sf-submit");
        const submitLabel = document.getElementById("sf-submit-label");
        const success = document.getElementById("sf-success");
        const errorBox = document.getElementById("sf-error");

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          success.classList.add("hidden");
          errorBox.classList.add("hidden");
          submitBtn.disabled = true;
          submitLabel.textContent = "Sending...";

          const data = new FormData(form);
          try {
            const res = await fetch(form.action, {
              method: "POST",
              body: data,
              headers: { Accept: "application/json" },
            });
            const json = await res.json();
            if (res.ok && json.success) {
              form.reset();
              success.classList.remove("hidden");
              submitLabel.textContent = "Send message";
            } else {
              throw new Error(json.message || "Request failed");
            }
          } catch (err) {
            errorBox.classList.remove("hidden");
            submitLabel.textContent = "Send message";
          } finally {
            submitBtn.disabled = false;
          }
        });
      })();
    </script>

  </Background>
</DefaultLayout>
