---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Agritech and food tech prospecting", path: "/agritech-prospecting" },
]);

const pains = [
  "The farm manager or cooperative director you need doesn't use LinkedIn as a business tool.",
  "Subsidy cycles and regulatory timelines are your best buying signals - and you're not tracking them.",
  "You're reaching growers but the purchasing decision sits at the cooperative or agri-dealer level.",
  "The season matters. An outreach campaign that ignores harvest timing reaches buyers at the worst possible moment.",
];

const signals = [
  {
    title: "EU agricultural subsidy cycles and CAP reform implementation.",
    body: "The Common Agricultural Policy shapes investment timelines across European farming. Eco-scheme payments, agri-environment-climate measures, and LEADER programme grants all create defined windows where farmers and cooperatives have fresh capital with conditions attached. The 2023-2027 CAP strategic plan has specific national implementation timelines that are public. A farmer who just secured an eco-scheme payment that requires precision agriculture tools is not comparing - they're buying. The timing is in the national programme documents, not on LinkedIn.",
  },
  {
    title: "Cooperative and food processor capital investment rounds.",
    body: "Agricultural cooperatives and food processors operate on multi-year investment cycles tied to member audits, processing capacity reviews, and sustainability commitments. Capital investment announcements - new processing lines, storage facilities, digital traceability systems - appear in annual reports, trade press, and company filings. A cooperative that has just committed to precision irrigation or food safety certification is in active procurement for the technology and services that make the commitment deliverable.",
  },
  {
    title: "Sustainability certification and traceability requirements.",
    body: "GlobalG.A.P., Rainforest Alliance, GLOBALG.A.P. Chain of Custody, and retailer-specific sustainability standards create mandatory procurement timelines. A producer that has just committed to a new retailer standard is buying the monitoring, reporting, and certification infrastructure to meet it. These commitments appear in supplier portals and trade press before the formal procurement opens. Supply chain traceability legislation from the EU - EUDR (EU Deforestation Regulation) and the Corporate Sustainability Due Diligence Directive - creates additional compliance-driven purchasing across the food supply chain.",
  },
  {
    title: "Farm consolidation and cooperative merger activity.",
    body: "Agricultural consolidation - farm mergers, cooperative amalgamations, agri-dealer acquisitions - creates procurement reviews at the combined entity level. A cooperative that has just merged with a neighbouring one is evaluating whether its operational technology scales across the new footprint. A farm that has expanded through land acquisition is buying inputs and services at a scale its previous vendor relationships don't cover. Company register filings and cooperative governance announcements are the earliest signals of this activity.",
  },
];

const faq = [
  {
    q: "Farmers and cooperatives are often conservative buyers. Is outreach-led prospecting effective?",
    a: "Conservative buyers don't mean closed buyers - they mean buyers who respond to relevance and trust signals rather than volume. A message that references a CAP subsidy they've just received, names a specific operational problem it creates, and comes from a company that demonstrably understands their regulatory context gets read. A generic outreach campaign does not. Hooklyne's approach is specifically suited to buyers who filter on relevance.",
  },
  {
    q: "The decision-making in agriculture is complex. Farmer, cooperative, agri-dealer - who do I target?",
    a: "It depends on what you sell and at what scale. Individual farm technology often goes directly to the farm manager or owner. Cooperative-level systems go to the operational or IT director at the cooperative. Input procurement often routes through agri-dealers. Hooklyne identifies the correct level for your offer rather than giving you a list and leaving the decision to you.",
  },
  {
    q: "Does Hooklyne cover Dutch agriculture specifically? It's a dense and specialised sector.",
    a: "Yes. Dutch agriculture and horticulture are well-represented in KVK registrations, sector databases, and cooperative governance filings. Wageningen University research networks, LTO Nederland membership data, and specialist trade press add to the signal coverage. Dutch agri is one of the better-documented agricultural sectors in Europe from a data perspective.",
  },
  {
    q: "What if Hooklyne doesn't work for our agritech ICP?",
    a: "Pilot first. Ten prospects from your actual target list, fully built, no card required. Agritech is a segment where the seasonal and regulatory timing approach either immediately resonates or it doesn't - the pilot will tell you quickly.",
  },
];
---

<DefaultLayout
  title="Prospecting into agritech and food technology | Hooklyne"
  description="How to reach buyers in agriculture and food technology: subsidy cycles, cooperative procurement signals, sustainability certification timelines, and how to time outreach around the agricultural calendar."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Agritech and food technology prospecting guide",
    "description": "How to prospect into agritech and food technology: signals, contacts, and buying windows.",
    "url": "https://www.hooklyne.com/agritech-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-24 sm:pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Agritech and food technology prospecting</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Agricultural buyers have seasons. Cold outreach usually ignores them.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Subsidy cycles, certification requirements, and cooperative investment rounds create predictable buying windows in agriculture and food technology. The buyers who matter - farm directors, cooperative operations leads, food processor procurement teams - are reachable when those windows open. This guide covers how to find the signal and when to act on it.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real agritech prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your agritech ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How agritech and food companies buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open an agricultural buying window.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Agricultural procurement follows subsidy cycles, certification requirements, and operational events - not social media activity. The signals are in programme documents and cooperative filings, not LinkedIn posts.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for sectors where timing is the whole game.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Agricultural buyers are not inaccessible - they're inaccessible at the wrong moment. A farm director in harvest planning mode is not evaluating new software. The same director in January, post-harvest, reviewing CAP subsidy options and next year's capital plan, is very different. Hooklyne tracks the signals that indicate which window applies to which company, rather than treating the whole sector as one undifferentiated list.</p>
          <p>Cooperative and food processor contacts are not well-represented in LinkedIn-based tools. Hooklyne waterfalls across 21 providers - including agricultural cooperative registries, food sector databases, and verified European sources - to surface contacts at the right organisational level. Individual farm technology goes to the owner. Cooperative systems go to the operations director. Input procurement routes through different channels again.</p>
          <p>The first message references the specific signal that makes this company relevant right now - a subsidy programme they're likely to have applied for, a certification standard their key customer just announced, a cooperative investment round in their sector. That specificity is what earns a read in a sector where buyers receive a lot of generic outreach and filter it aggressively.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/food-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Food and beverage</a>
          <a href="/industrial-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrial and manufacturing</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Agritech prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
