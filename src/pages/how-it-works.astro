---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { FinalCTA } from '@/components/blocks/final-cta';
import { PortalShot } from '@/components/portal-shot';
import { ArrowRight } from 'lucide-react';

const stages = [
  {
    n: 1,
    key: "Discovery",
    title: "Find fit. Not filters.",
    body: "Describe who you sell to in plain words. We match across billions of pages by what companies actually do, not the box they tick in a database.",
    shot: {
      label: "Discovery workspace",
      describe: "Portal: ICP prompt field, live results grid with fit scores and quick-add buttons.",
      url: "portal.hooklyne.com/prospecting",
      overlays: [
        { x: 22, y: 24, tag: "PROMPT", title: "Dutch industrial OEMs moving to service models", tone: "blue" as const },
        { x: 78, y: 70, tag: "MATCHED", title: "42 real fits", body: "Not SIC code guesses", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 2,
    key: "Verification",
    title: "The contact, verified before you see it.",
    body: "We check 20+ providers and four deliverability layers per email. If it can't be verified, it never ships. Your domain reputation stays clean.",
    shot: {
      label: "Verification waterfall",
      describe: "Portal: contact card with live provider attempts and a final deliverability score.",
      url: "portal.hooklyne.com/prospect/142",
      overlays: [
        { x: 22, y: 30, tag: "PROVIDER 3/20", title: "Verified match", tone: "teal" as const, pulse: true },
        { x: 78, y: 72, tag: "EMAIL", title: "Passed 4-layer check", body: "SMTP · Catch-all · Role · Deliverable", tone: "blue" as const },
      ],
    },
  },
  {
    n: 3,
    key: "Signals",
    title: "Catch the moment they're ready.",
    body: "Funding, hiring, leadership, launches, press, expansion, sector news. Every move scored for your ICP and your product. Only the real ones land in your inbox.",
    sources: ["Funding", "Hiring", "Leadership", "Launches", "Press", "Expansion", "Sector news"],
    shot: {
      label: "Signals feed",
      describe: "Portal: live signal feed with twin scores and a prep-meeting action per row.",
      url: "portal.hooklyne.com/signals",
      overlays: [
        { x: 24, y: 22, tag: "FUNDING", title: "Series B - €12M", body: "9/10 fit for your ICP", tone: "orange" as const, pulse: true },
        { x: 78, y: 70, tag: "HIRING", title: "New VP Sales", body: "Product relevance 8/10", tone: "blue" as const },
      ],
    },
  },
  {
    n: 4,
    key: "Research",
    title: "Every fact, sourced. No hallucinations.",
    body: "Live web research, not stale training data. Every claim traces back to a real URL you can click. Walk into the meeting without a single invented detail.",
    shot: {
      label: "Research brief",
      describe: "Portal: a prospect brief with numbered citations linking to live sources.",
      url: "portal.hooklyne.com/prospect/142/brief",
      overlays: [
        { x: 26, y: 26, tag: "SOURCED", title: "12 citations", tone: "blue" as const },
        { x: 76, y: 74, tag: "FRESH", title: "Pulled 2h ago", body: "Live web, not training data", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 5,
    key: "Drafting",
    title: "Reads like your rep wrote it.",
    body: "Four reasoning passes: hook, angle, voice, quality. Each draft is read and rewritten before it reaches you. Generic stops here.",
    shot: {
      label: "Draft with voice match",
      describe: "Portal: drafted email on the left, voice-match panel on the right showing cadence, openers, sign-off.",
      url: "portal.hooklyne.com/prospect/142/draft",
      overlays: [
        { x: 24, y: 26, tag: "VOICE", title: "Matched to your cadence", tone: "blue" as const },
        { x: 78, y: 70, tag: "PASSES", title: "4 reasoning passes", body: "Hook · Angle · Voice · QC", tone: "orange" as const, pulse: true },
      ],
    },
  },
  {
    n: 6,
    key: "Delivery",
    title: "One screen. Ready to send.",
    body: "Company, contact, signal, hook, email, LinkedIn - all on one card. Review, edit, accept, send from your own inbox. Under a minute per prospect.",
    shot: {
      label: "Prospect package card",
      describe: "Portal: single prospect card open with Company / Contact / Signal / Hook / Email / LinkedIn sections.",
      url: "portal.hooklyne.com/leads",
      overlays: [
        { x: 22, y: 24, tag: "REVIEW", title: "<60 seconds", tone: "teal" as const },
        { x: 78, y: 72, tag: "SEND", title: "Your inbox, your domain", tone: "blue" as const, pulse: true },
      ],
    },
  },
];
---

<DefaultLayout
  title="How it works - Hooklyne"
  description="Six stages, one prospect package. From discovery to delivery, here's the workflow behind every Hooklyne output."
>
  <Background>
    <section class="pt-32 lg:pt-40 pb-12" data-fade>
      <div class="container max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">How it works</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          A research workflow. Not a chatbot.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-xl mx-auto leading-relaxed mb-8">
          Six stages working together. Each one does what a good researcher would do, continuously, so your rep never has to.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group"
          >
            Start your free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="/product"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the product
            <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pb-16 lg:pb-24" data-fade>
      <div class="container max-w-5xl">
        <div
          class="rounded-3xl p-6 lg:p-8"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); box-shadow: var(--shadow-md); border: 1px solid var(--border);"
        >
          <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-4">
            {stages.map((s, i) => (
              <>
                <div class="flex items-center gap-2.5 px-3.5 py-2 rounded-full" style="background: var(--background); border: 1px solid var(--border);">
                  <span class="inline-flex items-center justify-center size-6 rounded-full text-[11px] font-bold text-white" style="background: var(--hooklyne-navy);">
                    {s.n}
                  </span>
                  <span class="text-sm font-semibold text-[var(--heading)]">{s.key}</span>
                </div>
                {i < stages.length - 1 && <span class="text-[var(--muted-foreground)] text-sm">→</span>}
              </>
            ))}
          </div>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-14 lg:py-20" data-fade>
      <div class="container max-w-3xl text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-tight mb-5">
          Most "AI prospecting" is one prompt and a list.
        </h2>
        <p class="text-lg text-[var(--muted-foreground)] leading-relaxed mb-4">
          Generic messages. Unverified emails. Your sender reputation quietly burned.
        </p>
        <p class="text-xl md:text-2xl font-medium italic text-[var(--heading)]">
          We do it differently. The workflow is the product.
        </p>
      </div>
    </section>

    <section class="py-10 lg:py-16">
      <div class="container max-w-6xl flex flex-col gap-24 lg:gap-32">
        {stages.map((s, i) => (
          <div data-fade class:list={["grid lg:grid-cols-2 gap-10 lg:gap-14 items-center", i % 2 === 1 && "lg:[&>*:first-child]:order-2"]}>
            <div>
              <div class="inline-flex items-center gap-2 mb-5">
                <span class="inline-flex items-center justify-center size-9 rounded-xl text-sm font-bold text-white" style="background: var(--hooklyne-navy);">
                  {s.n}
                </span>
                <span class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{s.key}</span>
              </div>
              <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-[1.1]">
                {s.title}
              </h2>
              <p class="text-lg text-[var(--muted-foreground)] leading-relaxed max-w-lg">
                {s.body}
              </p>

              {s.sources && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {s.sources.map((src) => (
                    <span class="text-xs font-medium px-3 py-1.5 rounded-full" style="background: var(--card); border: 1px solid var(--border); color: var(--heading);">
                      {src}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <div>
              <PortalShot
                label={s.shot.label}
                describe={s.shot.describe}
                url={s.shot.url}
                overlays={s.shot.overlays}
              />
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20 lg:py-24" data-fade>
      <div class="container max-w-3xl text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-tight mb-4">
          One credit system. One number.
        </h2>
        <p class="text-lg text-[var(--muted-foreground)] leading-relaxed max-w-xl mx-auto mb-8">
          Every action priced in plain view. You see what's used, what's left. Scale up, cancel, top up. No surprises.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/pricing"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group"
          >
            See pricing
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Start your free pilot
            <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <FinalCTA client:load />
  </Background>
</DefaultLayout>
