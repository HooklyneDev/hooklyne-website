---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { PortalShot } from '@/components/portal-shot';
import { ResearchBrief } from '@/components/research-brief';
import { ArrowRight } from 'lucide-react';

const stages = [
  {
    n: 1,
    key: "Discovery",
    title: "Describe it. We find it.",
    body: "Tell us who you sell to in plain words. We read billions of pages semantically and surface the companies that actually fit. Not a filter grid. A language-level match.",
    shot: {
      label: "Discovery workspace",
      describe: "Portal: a plain-language description field, live results grid with fit scores and quick-add buttons.",
      crumb: "Prospecting / Discovery",
      status: "Reading 1.2B pages",
      statusTone: "blue" as const,
      overlays: [
        { x: 30, y: 28, tag: "DESCRIBE", title: "Dutch industrial OEMs moving to service models", tone: "blue" as const },
        { x: 72, y: 70, tag: "MATCHED", title: "42 real fits", body: "Not SIC code guesses", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 2,
    key: "Verification",
    title: "The contact, verified before you see it.",
    body: "We check 20+ providers and four deliverability layers per email. If it can't be verified, it never ships. Your domain reputation stays clean.",
    shot: {
      label: "Verification waterfall",
      describe: "Portal: contact card with live provider attempts and a final deliverability score.",
      crumb: "Prospect / Contact verification",
      status: "Verified",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 30, tag: "PROVIDER 3/20", title: "Verified match", tone: "teal" as const, pulse: true },
        { x: 72, y: 72, tag: "EMAIL", title: "Passed 4-layer check", body: "SMTP · Catch-all · Role · Deliverable", tone: "blue" as const },
      ],
    },
  },
  {
    n: 3,
    key: "Signals",
    title: "Catch the moment they're ready.",
    body: "Funding, hiring, leadership, launches, press, expansion, sector news. Every move scored for your ICP and your product. Only the real ones land in your inbox.",
    sources: ["Funding", "Hiring", "Leadership", "Launches", "Press", "Expansion", "Sector news"],
    shot: {
      label: "Signals feed",
      describe: "Portal: live signal feed with twin scores and a prep-meeting action per row.",
      crumb: "Signals feed",
      status: "Live",
      statusTone: "orange" as const,
      overlays: [
        { x: 30, y: 26, tag: "FUNDING", title: "Series B - €12M", body: "9/10 fit for your ICP", tone: "orange" as const, pulse: true },
        { x: 72, y: 70, tag: "HIRING", title: "New VP Sales", body: "Product relevance 8/10", tone: "blue" as const },
      ],
    },
  },
  {
    n: 4,
    key: "Research",
    title: "Every fact, sourced. No made-up facts.",
    body: "Live web research, not stale training data. Every claim traces back to a real URL you can click. Walk into the meeting without a single invented detail.",
    shot: {
      label: "Research brief",
      describe: "Portal: a prospect brief with numbered citations linking to live sources.",
      crumb: "Prospect / Research brief",
      status: "Pulled 2m ago",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 28, tag: "SOURCED", title: "12 citations", tone: "blue" as const },
        { x: 72, y: 72, tag: "FRESH", title: "Pulled 2h ago", body: "Live web, not training data", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 5,
    key: "Drafting",
    title: "Reads like your rep wrote it.",
    body: "Every draft is reasoned through four times before it reaches you. Hook first, then angle, then voice, then a final quality check. Generic stops here.",
    shot: {
      label: "Draft with voice match",
      describe: "Portal: drafted email on the left, voice-match panel on the right showing cadence, openers, sign-off.",
      crumb: "Prospect / Draft",
      status: "Voice matched",
      statusTone: "blue" as const,
      overlays: [
        { x: 30, y: 28, tag: "VOICE", title: "Matched to your cadence", tone: "blue" as const },
        { x: 72, y: 70, tag: "PASSES", title: "4 reasoning passes", body: "Hook · Angle · Voice · QC", tone: "orange" as const, pulse: true },
      ],
    },
  },
  {
    n: 6,
    key: "Delivery",
    title: "One screen. Ready to send.",
    body: "Company, contact, signal, hook, email, LinkedIn - all on one card. Review, edit, accept, send from your own inbox. Under a minute per prospect.",
    shot: {
      label: "Prospect card",
      describe: "Portal: single prospect card open with Company / Contact / Signal / Hook / Email / LinkedIn sections.",
      crumb: "Leads / Prospect 142",
      status: "Ready to send",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 28, tag: "REVIEW", title: "<60 seconds", tone: "teal" as const },
        { x: 72, y: 72, tag: "SEND", title: "Your inbox, your domain", tone: "blue" as const, pulse: true },
      ],
    },
  },
];
---

<DefaultLayout
  title="How it works - Hooklyne"
  description="Six stages, one prospect package. From discovery to delivery, here's the workflow behind every Hooklyne output."
  ctaVariant="how-it-works"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Hooklyne builds a prospect package",
    "description": "Six stages from plain-language ICP to a ready-to-send prospect package in under a minute of review.",
    "totalTime": "PT1M",
    "step": stages.map((s) => ({
      "@type": "HowToStep",
      "position": s.n,
      "name": s.key,
      "text": s.body,
      "url": `https://www.hooklyne.com/how-it-works#stage-${s.n}`,
    })),
  })} />
  <Background>
    <section class="pt-32 lg:pt-44 pb-16 lg:pb-24 relative" data-fade>
      <HeroGlow client:load />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">How it works</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          A research workflow. Not a chatbot.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-xl mx-auto leading-relaxed mb-8">
          Six stages working together. Each one does what a good researcher would do, continuously, so your rep never has to.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 mb-14 lg:mb-16">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start your free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="/product"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the product
            <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>

      <div id="hero-video" class="container max-w-6xl relative z-10">
        <div
          class="relative rounded-2xl px-4 py-4 lg:px-6 lg:py-5 overflow-hidden"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); box-shadow: var(--shadow-lg); border: 1px solid var(--border);"
        >
          <div class="flex flex-col md:flex-row items-stretch md:items-center gap-2 md:gap-0">
            {stages.map((s, i) => (
              <>
                <a
                  href={`#stage-${s.n}`}
                  class="group flex-1 flex items-center gap-2.5 px-2 py-2 md:justify-center rounded-lg hover:bg-[var(--background)] transition-colors"
                >
                  <span class="inline-flex items-center justify-center size-7 shrink-0 rounded-full text-[11px] font-bold text-white transition-transform duration-200 group-hover:scale-110" style="background: var(--hooklyne-navy);">
                    {s.n}
                  </span>
                  <span class="text-[12px] md:text-[13px] font-semibold text-[var(--heading)] whitespace-nowrap tracking-tight group-hover:text-[var(--hooklyne-blue)] transition-colors">{s.key}</span>
                </a>
                {i < stages.length - 1 && (
                  <div class="shrink-0 flex items-center justify-center md:px-1">
                    <svg class="hidden md:block text-[var(--border-strong)]" width="16" height="10" viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M0 5 H13 M9 1 L13 5 L9 9"/></svg>
                    <svg class="md:hidden text-[var(--border-strong)] rotate-90" width="16" height="10" viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M0 5 H13 M9 1 L13 5 L9 9"/></svg>
                  </div>
                )}
              </>
            ))}
          </div>
        </div>

        <div class="flex items-center justify-center gap-5 mt-6 text-[11px] font-medium text-[var(--muted-foreground)]">
          <div class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/><path d="M5 3 2 6"/><path d="m22 6-3-3"/></svg>
            Under 60s to review per prospect
          </div>
          <div class="hidden sm:flex items-center gap-1.5">
            <span class="relative flex size-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-70 animate-ping"></span>
              <span class="relative inline-flex size-1.5 rounded-full bg-emerald-500"></span>
            </span>
            Live, not weekly
          </div>
        </div>
      </div>
    </section>

    <section class="pb-16 lg:pb-24 relative">
      <div class="container max-w-5xl">
        <div class="hiw-pipeline rounded-2xl p-5 md:p-6 relative overflow-hidden" style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
              <span class="relative flex size-1.5">
                <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-70 animate-ping"></span>
                <span class="relative inline-flex size-1.5 rounded-full bg-emerald-500"></span>
              </span>
              <span class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[var(--hooklyne-blue)]">Research pipeline</span>
            </div>
            <span class="text-[10px] font-mono text-[var(--muted-foreground)] hidden sm:block">Billions in &middot; one prospect out</span>
          </div>

          <div class="pipeline-track relative flex flex-col md:flex-row items-stretch md:items-center gap-3 md:gap-0">
            {[
              { n: 1, top: "1.2B", label: "pages read", tone: "navy" },
              { n: 2, top: "20+", label: "verifiers", tone: "navy" },
              { n: 3, top: "7", label: "signal types", tone: "teal" },
              { n: 4, top: "4", label: "reasoning passes", tone: "teal" },
              { n: 5, top: "<60s", label: "to send", tone: "orange" },
            ].map((s, i) => (
              <>
                <div class="pipeline-node flex-1 flex md:flex-col items-center md:items-center gap-3 md:gap-1 px-2 py-2 relative">
                  <div class="pipeline-dot size-7 md:size-8 shrink-0 rounded-full flex items-center justify-center text-[10px] font-bold text-white" style={`background: var(--hooklyne-${s.tone});`}>
                    {s.n}
                  </div>
                  <div class="flex md:flex-col items-baseline md:items-center gap-1.5 md:gap-0">
                    <span class="text-base md:text-lg font-semibold text-[var(--heading)] tracking-tight tabular-nums leading-none">{s.top}</span>
                    <span class="text-[10px] md:text-[11px] text-[var(--muted-foreground)] whitespace-nowrap md:mt-0.5">{s.label}</span>
                  </div>
                </div>
                {i < 4 && (
                  <div class="pipeline-connector hidden md:flex items-center shrink-0" aria-hidden="true">
                    <div class="relative h-px w-10 lg:w-14 bg-[var(--border-strong)]/50 overflow-hidden">
                      <div class="pipeline-tracer absolute top-1/2 -translate-y-1/2 h-[2px] w-5 rounded-full" style={`background: linear-gradient(90deg, transparent 0%, var(--hooklyne-blue) 50%, transparent 100%); animation-delay: ${i * 0.6}s;`}></div>
                    </div>
                  </div>
                )}
              </>
            ))}
          </div>

          <div class="mt-5 pt-4 border-t border-[var(--border)] flex items-center justify-between flex-wrap gap-2">
            <span class="text-[11px] text-[var(--muted-foreground)]">Every stage, continuous. So your rep never has to.</span>
            <a href="#stage-1" class="text-[11px] font-semibold text-[var(--hooklyne-blue)] hover:opacity-80 transition-opacity inline-flex items-center gap-1">
              Jump to stage one
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-20 lg:py-28" data-fade>
      <div class="container max-w-4xl text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-tight mb-5">
          Most prospecting tools give you one ask and a list.
        </h2>
        <p class="text-lg text-[var(--muted-foreground)] leading-relaxed mb-4">
          Generic messages. Unverified emails. Your sender reputation quietly burned.
        </p>
        <p class="text-xl md:text-2xl font-medium italic text-[var(--heading)]">
          We do it differently. The workflow is the product.
        </p>
      </div>
    </section>

    <section class="py-20 lg:py-28">
      <div class="container max-w-6xl flex flex-col gap-24 lg:gap-32">
        {stages.map((s, i) => (
          <div id={`stage-${s.n}`} data-fade class:list={["scroll-mt-28 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center", i % 2 === 1 && "lg:[&>*:first-child]:order-2"]}>
            <div>
              <div class="inline-flex items-center gap-2 mb-5">
                <span class="inline-flex items-center justify-center size-9 rounded-xl text-sm font-bold text-white" style="background: var(--hooklyne-navy);">
                  {s.n}
                </span>
                <span class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{s.key}</span>
                {s.n === 6 && (
                  <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2 py-1 rounded-full" style="background: rgba(13,148,136,0.12); color: var(--hooklyne-teal);">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/></svg>
                    Under 60s
                  </span>
                )}
              </div>
              <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-5 leading-[1.1]">
                {s.title}
              </h2>
              <p class="text-lg text-[var(--muted-foreground)] leading-relaxed max-w-lg">
                {s.body}
              </p>

              {s.sources && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {s.sources.map((src) => (
                    <span class="text-xs font-medium px-3 py-1.5 rounded-full" style="background: var(--card); border: 1px solid var(--border); color: var(--heading);">
                      {src}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <div>
              {s.n === 4 ? (
                <ResearchBrief />
              ) : (
                <PortalShot
                  label={s.shot.label}
                  describe={s.shot.describe}
                  crumb={s.shot.crumb}
                  status={s.shot.status}
                  statusTone={s.shot.statusTone}
                  overlays={s.shot.overlays}
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

  </Background>
</DefaultLayout>

<style>
  .pipeline-tracer {
    left: -20px;
    animation: pipeline-tracer-flow 3.2s ease-in-out infinite;
    opacity: 0;
  }

  @keyframes pipeline-tracer-flow {
    0% { left: -20px; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  .pipeline-node .pipeline-dot {
    animation: pipeline-node-pulse 5s ease-in-out infinite;
  }
  .pipeline-node:nth-child(1) .pipeline-dot { animation-delay: 0s; }
  .pipeline-node:nth-child(3) .pipeline-dot { animation-delay: 0.6s; }
  .pipeline-node:nth-child(5) .pipeline-dot { animation-delay: 1.2s; }
  .pipeline-node:nth-child(7) .pipeline-dot { animation-delay: 1.8s; }
  .pipeline-node:nth-child(9) .pipeline-dot { animation-delay: 2.4s; }

  @keyframes pipeline-node-pulse {
    0%, 70%, 100% { transform: scale(1); filter: brightness(1); }
    5% { transform: scale(1.08); filter: brightness(1.15); }
    10% { transform: scale(1); filter: brightness(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pipeline-tracer,
    .pipeline-node .pipeline-dot { animation: none; }
    .pipeline-tracer { opacity: 0.6; left: 50%; }
  }
</style>
