---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Healthcare prospecting", path: "/healthcare-prospecting" },
]);

const pains = [
  "Healthcare buyers have strict procurement rules. Cold outreach that ignores them doesn't get a reply.",
  "The procurement manager changed. You found out from the bounce.",
  "You're reaching clinicians who have no purchasing authority, not the procurement or operations leads who do.",
  "Accreditation renewals and digital transformation timelines are your best signals - and you're not tracking them.",
];

const signals = [
  {
    title: "Digital transformation and EHR implementation projects.",
    body: "A healthcare organisation that has announced or begun an electronic health record implementation, a digital patient portal, or a clinical decision support project is in an extended procurement cycle that creates multiple adjacent purchasing decisions. IT infrastructure, integration middleware, training, data management, cybersecurity - each is a sub-project with its own procurement window. Implementation announcements are often in annual reports, hospital board minutes (which are public in the Netherlands), and trade press.",
  },
  {
    title: "Accreditation renewals and quality certifications.",
    body: "NIAZ, JCI, NEN 7510, and ISO 27001 for healthcare information security - each creates a procurement review cycle. A hospital or clinic approaching accreditation renewal is evaluating whether its current suppliers and systems meet the updated criteria. A clinic that just achieved a new accreditation has demonstrated its willingness to invest in quality infrastructure and often has ongoing procurement to maintain the standard. Accreditation cycles are documented and predictable.",
  },
  {
    title: "Merger, acquisition, and network consolidation.",
    body: "Healthcare consolidation - hospital mergers, clinic acquisitions, GP practice network formation - creates procurement reviews at the consolidated entity level. The new combined organisation needs to rationalise suppliers, standardise systems, and often upgrade infrastructure to serve the larger patient base. These consolidations are registered with healthcare regulators and often in company registries. The procurement window is in the 6-18 months following the merger, not before it.",
  },
  {
    title: "New facility openings and department expansions.",
    body: "A new clinic, a department expansion, or a satellite facility opening is a clean procurement trigger: equipment, IT, staffing systems, patient management software. Planning applications for healthcare facilities are filed with municipal authorities and often accompanied by press announcements. The procurement window opens at planning approval, not at opening day. Reaching the operations or procurement director at planning stage is significantly easier than arriving after the equipment decisions have already been made.",
  },
];

const faq = [
  {
    q: "Healthcare procurement is highly regulated. Can Hooklyne operate in this environment?",
    a: "Yes - and it's one of the most important reasons to use a GDPR-native tool in this sector. Every Hooklyne contact has a documented source. No scraped contact data, no grey-area databases. For healthcare buyers who run their own compliance checks on vendor relationships, Hooklyne's provenance approach is documentable and defensible.",
  },
  {
    q: "Hospital procurement often goes through formal tendering. Is outreach-led prospecting useful?",
    a: "Formal tendering is the end of the process, not the beginning. The organisations that win tenders are usually known to the procurement team before the tender is published. Being a known, credible supplier at the pre-tender stage is the goal. Hooklyne gets you to the right person at the right moment to establish that relationship.",
  },
  {
    q: "We sell to private clinics, not large hospitals. Does coverage work at that level?",
    a: "Yes. Private clinics and specialist care providers are well-covered in KVK registrations, healthcare regulatory filings, and sector databases. The segment where outreach-led prospecting has the most leverage is often mid-size private healthcare - 20-200 FTE - where procurement isn't fully formalised and relationships matter more than framework agreements.",
  },
  {
    q: "What if Hooklyne doesn't work for our healthcare ICP?",
    a: "Pilot first. Ten prospects from your actual target list, fully built, no card required. Healthcare is a segment where the accreditation and transformation timing approach either resonates immediately or the buyer isn't in a procurement window yet - the pilot will make that clear quickly.",
  },
];
---

<DefaultLayout
  title="Prospecting into healthcare organisations | Hooklyne"
  description="How to reach buyers in healthcare: digital transformation signals, accreditation timelines, facility opening triggers, and how to navigate procurement rules to reach the right decision-maker."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Healthcare prospecting guide",
    "description": "How to prospect into healthcare organisations: signals, contacts, and buying windows.",
    "url": "https://www.hooklyne.com/healthcare-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Healthcare prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Healthcare buyers have strict rules. The ones who matter are still reachable.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Procurement in healthcare is governed by accreditation requirements, digital transformation timelines, and regulatory frameworks - not by LinkedIn activity. The signals that indicate an active buying window are in board minutes, facility filings, and accreditation databases. This guide covers where those signals are and how to reach the right person before the formal process starts.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real healthcare prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your healthcare ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How healthcare organisations buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open a healthcare buying window.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Healthcare procurement follows accreditation cycles, digital transformation projects, and organisational changes - not social media activity. The signals are in public filings and regulatory databases.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for buyers who check where your data comes from.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Healthcare buyers are among the most data-conscious in any sector. Every Hooklyne contact has a documented source - public registry, company website, accreditation database. No scraped contact data, no grey-area sourcing. For healthcare procurement teams that run compliance checks on vendor relationships, that provenance is documentable. Hooklyne is built and hosted in the Netherlands and waterfall-verifies contacts across 21 registered providers.</p>
          <p>The right contact in healthcare depends on what you're selling and the size of the organisation. At a private clinic, the decision maker is often the medical director or practice manager. At a larger hospital, it's the procurement director, CIO, or operations director depending on the category. Hooklyne identifies the correct role at each organisation rather than surfacing a list of clinicians who have no purchasing authority.</p>
          <p>The first message references the specific trigger that makes this organisation relevant right now - a digital transformation project they've announced, an accreditation renewal approaching, a new facility filing. That specificity matters more in healthcare than almost any other sector, because procurement managers receive a high volume of outreach and filter it based on demonstrated relevance.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/fintech-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Fintech and financial services</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Healthcare prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
