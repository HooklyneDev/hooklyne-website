---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Energy and utilities prospecting", path: "/energy-prospecting" },
]);

const pains = [
  "The sustainability manager you need doesn't respond to cold outreach that ignores the regulatory context.",
  "Grid connection announcements are your best signal - you find them in press releases, weeks after everyone else.",
  "You're reaching the right company but the wrong role: procurement, not operations, owns the decision.",
  "Renewable project timelines create tight windows. You're not tracking them systematically.",
];

const signals = [
  {
    title: "Renewable energy project announcements.",
    body: "A wind, solar, or hydrogen project announcement is one of the cleanest procurement signals in the energy sector. Project development timelines are public - planning applications, grid connection agreements, and permitting milestones are filed before construction begins. Each milestone is a procurement event: equipment suppliers, grid services, monitoring technology, O&M contracts. The companies that reach project developers at planning stage are on the shortlist. Companies that arrive at commissioning are not.",
  },
  {
    title: "Regulatory compliance deadlines: RED III, CSRD, ETS.",
    body: "The Renewable Energy Directive III, Corporate Sustainability Reporting Directive, and EU Emissions Trading System each create mandatory compliance timelines with real purchasing attached. A utility or industrial energy buyer approaching a RED III reporting deadline is actively buying renewable energy attribute certificates and energy management software. A manufacturer inside the EU ETS threshold is buying carbon management tools and energy efficiency services. These deadlines are public and company-specific eligibility is often derivable from company size and sector.",
  },
  {
    title: "Energy management and sustainability role openings.",
    body: "A new Head of Sustainability, Energy Manager, or Chief Sustainability Officer hire signals that a company is either building a compliance function for the first time or upgrading one that wasn't fit for purpose. The first 90 days involve a supplier and tooling review. That review window is more accessible than the ongoing management relationship that follows it. A sustainability hire at a 50-200 person company is often the first dedicated resource - which means the person has significant purchase authority and a mandate to establish vendor relationships from scratch.",
  },
  {
    title: "Grid connection approvals and capacity expansions.",
    body: "A company that just received a grid connection approval for a new site or expanded capacity is entering a defined procurement sequence: electrical infrastructure, energy management systems, demand response contracts, and often storage solutions. Grid connection approvals are filed with network operators and are often listed in public planning databases. Most sellers miss this signal entirely because they're watching LinkedIn, not permitting portals.",
  },
];

const faq = [
  {
    q: "Energy procurement involves very long decision cycles. Is signal-led outreach still useful?",
    a: "The cycle from first contact to signed contract in energy can be 12-24 months. But the companies that get into that cycle early - before the specification is written, before the vendor list is formed - are the ones that win it. Arriving at the RFP stage as an unknown is very hard. Arriving 12 months earlier with a relevant reason to talk is not.",
  },
  {
    q: "We sell to utilities specifically. Does Hooklyne have coverage there?",
    a: "Large utilities have structured procurement with formal RFP processes that are hard to enter without an existing relationship. The more productive segment for signal-led outreach is mid-size utilities, municipal energy companies, and energy-intensive manufacturers. Hooklyne is built for 10-200 FTE companies - that's where the most leverage is.",
  },
  {
    q: "CSRD and energy compliance requirements change frequently. How does Hooklyne keep up?",
    a: "Hooklyne monitors regulatory timelines and scores prospects against the applicable deadlines for their sector and size. The compliance calendar is built into the scoring model - you don't need to track it separately. When a deadline is approaching for a company that matches your ICP, that's the signal.",
  },
  {
    q: "What if Hooklyne doesn't work for our energy ICP?",
    a: "Pilot first. Ten prospects from your actual energy target list, fully built, no card required. If the output doesn't open conversations you wouldn't have had otherwise, you stop. Energy is a sector where the regulatory timing approach either resonates quickly or the buyer isn't in the window yet - the pilot makes that clear.",
  },
];
---

<DefaultLayout
  title="Prospecting into energy and utilities companies | Hooklyne"
  description="How to reach buyers in energy and utilities: the regulatory signals that open buying windows, how to find project procurement contacts, and how to arrive before the shortlist closes."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Energy and utilities prospecting guide",
    "description": "How to prospect into energy and utilities companies: signals, contacts, and buying windows.",
    "url": "https://www.hooklyne.com/energy-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Energy and utilities prospecting</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Energy buyers aren't hard to convince. They're hard to reach at the right moment.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Procurement decisions in energy and utilities cluster around project milestones, regulatory deadlines, and capacity changes - not LinkedIn activity. This guide covers where the signals are, which roles own the decision, and how to arrive before the shortlist is already formed.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real energy prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your energy ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How energy companies buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open an energy buying window.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Energy procurement is driven by project timelines, regulatory milestones, and capacity events - not by social media activity. The signals are in public filings and compliance calendars, not LinkedIn.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for procurement driven by regulation and project milestones.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Energy and utilities contacts are not well-covered in LinkedIn-based databases. Project developers, grid operators, and sustainability managers at mid-size companies rarely maintain public profiles detailed enough to be useful. Hooklyne waterfalls across 21 providers - including company registries, sector databases, and verified European sources - to surface the right contact at each company rather than returning a generic list.</p>
          <p>The regulatory calendar in energy is predictable. RED III, CSRD, ETS - each has company-specific applicability based on size, sector, and geography. Hooklyne scores prospects against these timelines so your outreach arrives when the compliance pressure is actually building, not when a sequence happens to reach day seven.</p>
          <p>The first message is drafted in your rep's writing style and references the specific event or deadline that makes this company relevant right now. A sustainability manager who receives a message that names their grid connection approval and connects it to a real procurement implication reads it. One that says 'I help energy companies' does not.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/industrial-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrial and manufacturing</a>
          <a href="/construction-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Construction and real estate</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Energy prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
