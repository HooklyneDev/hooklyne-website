---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/" },
  { name: "Industries", path: "/industries" },
  { name: "Food and beverage prospecting", path: "/food-prospecting" },
]);

const pains = [
  "The production director you need runs a factory, not a LinkedIn profile.",
  "Food safety certification renewals are your best timing signal - and you're missing them.",
  "Retailer listing requirements are driving supplier technology upgrades. You're finding out after the upgrade.",
  "The procurement decision at a food company involves R&D, production, and commercial. You're reaching one of the three.",
];

const signals = [
  {
    title: "Food safety certification renewals and new scheme adoptions.",
    body: "FSSC 22000, BRC Global Standard, IFS Food, and HACCP certification cycles are among the most reliable procurement triggers in the food sector. A producer approaching certification renewal is reviewing whether its current processes, technology, and suppliers meet the latest standard version. A company adopting a new scheme - often driven by a retailer requirement - is buying the systems and consultancy to get there. Certification status is often publicly listed in scheme databases, which means the renewal timeline is derivable without cold intelligence.",
  },
  {
    title: "Retailer and QSR listing requirements.",
    body: "When a major retailer or food service operator sets a new supplier standard - traceability, packaging, allergen management, carbon labelling - every company in that supply chain has a compliance deadline attached to their commercial relationship. These requirements are often announced in retailer sustainability reports and trade press well before the supplier deadline. A food producer that supplies Albert Heijn, Lidl, or a major UK retailer and has just received a new packaging or traceability requirement is a motivated buyer with a date.",
  },
  {
    title: "New product launches and capacity expansions.",
    body: "A food company launching a new product range or expanding production capacity is in a procurement cycle for ingredients, packaging, processing equipment, quality management systems, and logistics. Product launches are announced in trade press, category databases, and retailer promotional calendars. A capacity expansion is visible in planning applications and company filings weeks before production starts. Both events create predictable procurement sequences that are easier to enter at the front than mid-cycle.",
  },
  {
    title: "EUDR, CSRD, and supply chain traceability legislation.",
    body: "The EU Deforestation Regulation (EUDR) and Corporate Sustainability Due Diligence Directive create mandatory supply chain traceability obligations for food companies above a revenue threshold. Implementation deadlines are phased by company size and category. A mid-size food processor approaching its EUDR compliance date is actively buying traceability software, supplier data systems, and third-party audit services. The regulatory calendar is public. Company eligibility is largely derivable from sector and size. That combination is the signal.",
  },
];

const faq = [
  {
    q: "Food companies are relationship-driven buyers. Does outreach-led prospecting work here?",
    a: "Relationship buyers are not relationship-only buyers. They switch suppliers when there's a reason - a quality failure, a price difference that can't be ignored, or a new requirement they can't meet with their current supplier. Hooklyne surfaces companies in the window where the reason to switch exists, not companies that are perfectly happy with their current setup.",
  },
  {
    q: "The decision involves several departments. Who do I target in a food company?",
    a: "For production technology and quality systems: operations director or quality manager. For ingredients and packaging: procurement director or category manager. For traceability and sustainability software: sustainability manager or CTO at more digitally mature companies. Hooklyne identifies the right role for your offer at each company rather than returning a generic contact list.",
  },
  {
    q: "We sell to food manufacturers with 50-500 employees. Is that a well-covered segment?",
    a: "Yes. Mid-size food manufacturers are well-covered in KVK registrations, food safety scheme databases, trade association records, and sector publications. It's actually one of the better-documented segments in European food - the regulatory requirements create a paper trail that makes companies findable even when their digital footprint is low.",
  },
  {
    q: "What if Hooklyne doesn't work for our food sector ICP?",
    a: "Pilot first. Ten prospects from your actual target list, fully built, no card required. Food is a sector where the certification timing approach either immediately resonates or the company isn't in a procurement window yet - the pilot makes that distinction quickly.",
  },
];
---

<DefaultLayout
  title="Prospecting into food and beverage companies | Hooklyne"
  description="How to reach buyers in food and beverage: food safety certification signals, retailer compliance requirements, EUDR traceability deadlines, and how to find the right contact in a multi-department procurement decision."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Food and beverage prospecting guide",
    "description": "How to prospect into food and beverage companies: certification signals, contacts, and buying windows.",
    "url": "https://www.hooklyne.com/food-prospecting",
    "inLanguage": "en"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Food and beverage prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Food buyers aren't closed to new suppliers. They're closed to irrelevant ones.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Food safety certifications, retailer requirements, and supply chain legislation create predictable procurement windows across food and beverage. The production and quality directors who own these decisions are reachable - when there's a reason to talk. This guide covers how to find that reason and when to act on it.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start a free pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signals"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            See the signals
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">You probably came here because</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">If any of that lands, the rest of this page is for you.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Free pilot, no card</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Try it on 10 of your real food sector prospects first.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Ten fully researched prospect packages from your food ICP. No payment, no contract. Twenty minutes of honest feedback after - that's it.</p>
            <a href="/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Request a pilot <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signals" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">How food companies buy</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Four signals that open a food sector buying window.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Food procurement follows certification cycles, retailer requirements, and legislation timelines - not LinkedIn activity. The signals are in scheme databases, trade press, and regulatory calendars.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Where Hooklyne fits</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Built for sectors where the signal is in the regulatory calendar, not the news feed.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Food and beverage contacts are moderately covered in LinkedIn-based tools but poorly covered in terms of buying signals. A production director's LinkedIn profile tells you their job title. It doesn't tell you their FSSC 22000 renewal is in six months or that their largest retailer just issued a new traceability requirement. Hooklyne monitors certification scheme databases, food industry trade press, and regulatory filings to surface the signals that actually indicate a buying window.</p>
          <p>The right contact in food depends on category. Quality management systems go to the quality director. Ingredients and packaging route through procurement. Technology and sustainability software increasingly goes to a dedicated sustainability manager or digital operations lead. Hooklyne identifies the correct role at each company based on your offer rather than returning a list and leaving the targeting decision to your rep with 20 other prospects to work through.</p>
          <p>The first message references the specific signal that makes this company relevant right now - a certification renewal timeline, a retailer requirement they supply into, a product launch in a category they're active in. Food buyers receive a high volume of generic outreach. The messages that earn a response name something specific and connect it to a real operational implication. That's the difference between a read and a delete.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Related guides</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">All industry guides</a>
          <a href="/agritech-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Agritech and food technology</a>
          <a href="/industrial-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrial and manufacturing</a>
          <a href="/gdpr-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">GDPR-compliant prospecting</a>
          <a href="/compare" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool comparisons</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Food sector prospecting questions, answered.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
