---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DefaultLayout
	title="Blog | Hooklyne"
	description="Founder notes, product updates, comparisons, and field-tested takes on B2B prospect research from the Hooklyne team."
	image="/og/blog.jpg"
>
	<Background>
		<section class="pt-32 lg:pt-40 pb-10">
			<div class="container max-w-5xl">
				<p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Resources</p>
				<h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4">Blog.</h1>
				<p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl leading-relaxed">
					Product updates, founder notes, comparisons, and practical guides on B2B prospecting. One feed.
				</p>
			</div>
		</section>

		<div class="pb-20">
			{posts.length === 0 ? (
				<div class="container max-w-5xl">
					<div
						class="rounded-2xl p-8 md:p-10 text-center"
						style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
					>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--hooklyne-blue)] mb-3">First post soon</p>
						<h2 class="text-xl md:text-2xl font-semibold text-[var(--heading)] tracking-tight mb-3">
							Why we don't name our data stack.
						</h2>
						<p class="text-sm text-[var(--muted-foreground)] max-w-lg mx-auto leading-relaxed">
							Our first note lands shortly. In the meantime, the short version: the workflow is the product, the suppliers behind it are the kitchen. We believe buyers should judge the plate, not the pantry.
						</p>
					</div>
				</div>
			) : (
				<BlogPosts posts={posts} lang="en" client:only='react' />
			)}
		</div>
	</Background>
</DefaultLayout>
