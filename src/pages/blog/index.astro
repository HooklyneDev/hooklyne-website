---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DefaultLayout title="Blog | Hooklyne" description="Founder notes, product updates, and field-tested takes on B2B prospect research from the Hooklyne team." image="/og/blog.jpg">
	<Background>
		<BlogPosts posts={posts} client:only='react' />
	</Background>
</DefaultLayout>

