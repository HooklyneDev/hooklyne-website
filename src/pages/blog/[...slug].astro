---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';

import { BlogPost } from '@/components/blocks/blog-post';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { SITE_URL } from '@/consts';
import { breadcrumbList } from '@/lib/seo';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { title, description, pubDate, updatedDate, image, authorName, translationSlug } = post.data;
const { Content } = await render(post);

/* Per-post OG: /og/EN/blog.jpg generic for now. Custom per-post images
   can be added later by changing this to /og/blog-{post.id}.jpg.
   Distinct from `image` (the in-page hero), which is bigger and unbranded. */
const ogImage = `/og/EN/blog.jpg`;

const canonicalUrl = `${SITE_URL}/blog/${post.id}`;
const blogPostingSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description,
	image: image ? new URL(image, SITE_URL).toString() : `${SITE_URL}${ogImage}`,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: { "@type": authorName ? "Person" : "Organization", name: authorName ?? "Hooklyne" },
	publisher: {
		"@type": "Organization",
		name: "Hooklyne",
		logo: { "@type": "ImageObject", url: `${SITE_URL}/logo.svg` },
	},
	mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
};

const breadcrumb = breadcrumbList([
	{ name: 'Home', path: '/' },
	{ name: 'Blog', path: '/blog' },
	{ name: title, path: `/blog/${post.id}` },
]);
---
<DefaultLayout
	title={`${title} | Hooklyne Blog`}
	description={description}
	image={ogImage}
	ogType="article"
	publishedTime={pubDate.toISOString()}
	modifiedTime={(updatedDate ?? pubDate).toISOString()}
>
	{translationSlug && (
		<Fragment slot="head">
			<link rel="alternate" hreflang="en" href={`${SITE_URL}/blog/${post.id}`} />
			<link rel="alternate" hreflang="nl" href={`${SITE_URL}/nl/blog/${translationSlug}`} />
			<link rel="alternate" hreflang="x-default" href={`${SITE_URL}/blog/${post.id}`} />
		</Fragment>
	)}
	<script type="application/ld+json" is:inline set:html={JSON.stringify(blogPostingSchema)} />
	<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
	<div class="py-28 lg:pt-44 lg:pb-32">
		<BlogPost post={post} client:only='react' >
			<Content />
		</BlogPost>
	</div>
</DefaultLayout>
