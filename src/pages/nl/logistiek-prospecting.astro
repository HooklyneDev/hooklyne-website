---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, Building, MapPin, FileText, Calendar, Search, Shield, Clock, AlertCircle, Gift } from 'lucide-react';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Logistiek en transport prospecting", path: "/nl/logistiek-prospecting" },
]);

const pains = [
  "De operationeel directeur die je nodig hebt, heeft geen LinkedIn-profiel.",
  "Je beste signaal was een nieuwe depot - je las het in een vakblad, een maand te laat.",
  "Je stuurt naar info@ omdat de juiste contactpersoon in geen enkele database staat.",
  "Logistieke kopers negeren mail die niet op het juiste moment arriveert.",
];

const signals = [
  {
    icon: Building,
    title: "Nieuwe depots en facilitaire uitbreiding.",
    body: "Een nieuw distributiecentrum, warehouse of regionaal hub gaat bijna altijd gepaard met inkoop: nieuwe apparatuur, nieuwe leveranciers, nieuwe servicecontracten. Omgevingsvergunningen en KVK-wijzigingen verschijnen weken voor een persbericht. Dat is het venster - voordat de shortlist al bestaat.",
  },
  {
    icon: MapPin,
    title: "Nieuwe contractwinsten en routeaankondigingen.",
    body: "Een vervoerder of expediteur die net een groot contract heeft binnengehaald of een nieuwe route heeft geopend, groeit. Dat betekent headcount, nieuwe voertuigen en leveranciersreviews. Deze aankondigingen staan in vakpublicaties en bedrijfspersbulletins, voordat ze in de bredere pers verschijnen.",
  },
  {
    icon: Calendar,
    title: "Regelgevings- en compliance-deadlines.",
    body: "Clean-transportregels, ETS-uitbreidingen, CSRD-rapportage en grensoverschrijdende compliance creëren inkoopvensters. Een logistiek bedrijf dat voor een deadline koopt, is een gemotiveerde koper met een datum. Ze weten wat het kost als ze te laat zijn.",
  },
  {
    icon: FileText,
    title: "Vacatures in inkoop en operations.",
    body: "Een nieuwe Head of Procurement, Supply Chain Director of Fleetmanager is een sterk kortetermijnsignaal. De nieuwe persoon beoordeelt leveranciersrelaties in de eerste negentig dagen. Dat venster sluit zodra bestaande relaties zijn bevestigd of nieuwe zijn vastgelegd.",
  },
];

const hooklynePoints = [
  {
    icon: Search,
    title: "Waterval over 21 bronnen voor sectoren met lage LinkedIn-dekking.",
    body: "Logistieke en transportbedrijven zijn het slechtst gedekt in op LinkedIn gebaseerde databases. Operationeel directeuren en fleetmanagers hebben zelden publieke profielen. Hooklyne watervalt over 21 providers - waaronder KVK, brancheregisters en bedrijvengidsen - en vindt contacten die een sociaal-eerste tool simpelweg mist.",
  },
  {
    icon: Shield,
    title: "Signalen uit vakbronnen, niet alleen nieuwsfeeds.",
    body: "De meeste prospectingtools kijken naar LinkedIn-activiteit en bedrijfsnieuws. Hooklyne haalt ook uit KVK-wijzigingen, vakpublicaties, planningsdatabases en aanbestedingsportalen - de plekken waar logistieke koopsignalen het eerst verschijnen.",
  },
  {
    icon: Clock,
    title: "Op het inkoopvenster, niet op een weekschema.",
    body: "Logistieke kopers bladeren niet. Ze lossen operationele problemen op binnen strakke tijdlijnen. Hooklyne scoort het signaal, verifieert het contact over 21 bronnen en stelt een openingsbericht op in de schrijfstijl van jouw vertegenwoordiger - getimed op het trigger-event, niet op een wekelijkse drip.",
  },
];

const faq = [
  {
    q: "Logistieke bedrijven gebruiken nauwelijks LinkedIn. Kun je contacten vinden?",
    a: "Dat is precies waarom de waterval over 21 bronnen hier het meeste oplevert. Hooklyne is niet afhankelijk van LinkedIn-dichtheid. Het haalt uit KVK, bedrijvengidsen, brancheregisters en geverifieerde Europese providers. Operations- en inkoopcontacten in logistiek en transport staan in die bronnen - ook als ze onzichtbaar zijn op de tools die de meeste concurrenten gebruiken.",
  },
  {
    q: "Dit zijn lange verkooptrajecten. Loont signaalgedreven outreach dan nog?",
    a: "Het traject is lang, maar als eerste binnen zijn is nog steeds het verschil tussen op de shortlist staan en er niet op staan. Het signaal - nieuw depot, nieuw contract, nieuwe inkoophire - is de opening. Zes maanden later koud bellen als het venster al dicht is, werkt niet.",
  },
  {
    q: "Verkopen we aan kleinere carriers en expediteurs, niet aan de grote 3PL-spelers?",
    a: "Ja. Hooklyne is gebouwd voor bedrijven van 10-100 fte, en dat dekt het merendeel van de onafhankelijke carriers, regionale expediteurs en specialistische logistiek operators. Grote 3PLs hebben inkoopafdelingen die formele RFP-processen draaien. Het segment waar signaalgedreven outreach het meeste oplevert, is de middenmarkt.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons logistieke ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte doellijst, volledig opgebouwd, zonder kaart. Levert de output geen gesprekken op die je anders niet had gehad, dan stop je. Liever eerlijke feedback dan een klant die geen fit is.",
  },
];
---

<DefaultLayout
  title="Logistiek en transport prospecting: signalen en koopvensters | Hooklyne"
  description="Hoe je buyers in logistiek en transport bereikt: waar de signalen zijn, waarom standaarddatabases operations- en inkoopcontacten missen en hoe je er bent voordat het venster sluit."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Logistiek en transport prospecting-gids",
    "description": "Hoe je logistieke en transportbedrijven prospecteert: signalen, contacten en koopvensters.",
    "url": "https://www.hooklyne.com/nl/logistiek-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Logistiek en transport prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Logistieke kopers zijn moeilijk te bereiken. Dat is het punt.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Operationeel directeuren en inkoopmanagers in logistiek en transport brengen geen tijd door op LinkedIn. Hun signalen zitten in vakpublicaties, KVK-registers en planningsdatabases. Deze gids laat zien waar die signalen zijn en hoe je de juiste persoon bereikt voordat het venster sluit.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <AlertCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>

          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte logistieke prospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw logistieke ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan
              <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe logistieke bedrijven kopen</p>
          <h2 class="text-2xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een logistiek koopvenster openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Logistieke inkoop wordt gedreven door operationele events - niet door LinkedIn-activiteit. Dit is waar de echte signalen zijn.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 md:gap-5">
          {signals.map((s) => (
            <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
              <div class="size-10 rounded-xl flex items-center justify-center mb-4" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                <s.icon className="size-5" />
              </div>
              <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Hooklyne voor logistieke salesteams</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Gebouwd voor sectoren met een lage digitale voetafdruk.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Multi-source contactverificatie, branchesignalen en outreach getimed op het operationele venster - niet een wekelijkse drip.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-4 md:gap-5">
          {hooklynePoints.map((h) => (
            <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid rgba(13,148,136,0.20);">
              <div class="size-10 rounded-xl flex items-center justify-center mb-4" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal);">
                <h.icon className="size-5" />
              </div>
              <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{h.title}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{h.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over logistiek prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
