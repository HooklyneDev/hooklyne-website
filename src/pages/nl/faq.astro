---
import { Background } from '@/components/background';
import { FAQ } from '@/components/blocks/faq';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { faqGroups, faqGroupsNL } from '@/data/faq';
import { breadcrumbList } from "@/lib/seo";

const groups = faqGroupsNL ?? faqGroups;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: "nl-NL",
  mainEntity: groups.flatMap((g) =>
    g.items.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    }))
  ),
};

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "FAQ", path: "/nl/faq" },
]);
---
<DefaultLayout title="FAQ | Hooklyne" description="Antwoorden op veelgestelde vragen over Hooklyne, de onderzoeksworkflow, credits, signalen en wat in elk plan zit." image="/og/NL/faq.jpg" ctaVariant="faq">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <Background>
    <div class="pt-32 lg:pt-40">
      <FAQ lang="nl" client:visible />
    </div>
  </Background>
</DefaultLayout>
