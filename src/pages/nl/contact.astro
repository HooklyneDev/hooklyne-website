---
import { Background } from '@/components/background';
import { Contact } from '@/components/blocks/contact';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Contact", path: "/nl/contact" },
]);
---
<DefaultLayout title="Contact | Hooklyne" description="Neem contact op met het Hooklyne-team. Boek een demo, start een gratis trial of stel een vraag." image="/og/NL/contact.jpg" hideFinalCTA={true}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <Background>
    <Contact lang="nl" client:load />
  </Background>
</DefaultLayout>
