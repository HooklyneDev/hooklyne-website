---
import { SITE_DESCRIPTION_NL } from '../../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';
import { WeeklyBrief } from '@/components/product/weekly-brief';
import { WhatYouGet } from '@/components/blocks/what-you-get';
import { WaysToStart } from '@/components/blocks/ways-to-start';
import { BuiltFor } from '@/components/blocks/built-for';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Hooklyne | B2B leadgeneratie voor Nederlandse MKB-salesteams"
  description={SITE_DESCRIPTION_NL}
  image="/og/NL/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Hooklyne",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "inLanguage": "nl-NL",
    "description": "B2B leadgeneratie en prospect-onderzoek voor MKB-salesteams. Geverifieerde contacten, real-time koopsignalen en een eerste mail in de schrijfstijl van je salesmedewerker. AVG-proof.",
    "url": "https://www.hooklyne.com/nl",
    "offers": {
      "@type": "Offer",
      "price": "39",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "39",
        "priceCurrency": "EUR",
        "billingIncrement": 1,
        "unitText": "MONTH"
      }
    },
    "featureList": [
      "B2B prospect-onderzoek",
      "Signaal-gedreven outreach",
      "E-mailverificatie",
      "Bedrijfs-discovery",
      "Gepersonaliseerde drafting in Nederlands en Engels"
    ]
  })} />
  <Background>
    <Hero lang="nl" client:load />
    <SignalTicker />
    <DIYCompare lang="nl" hideCompare client:visible />

    <section class="pb-14 lg:pb-20" data-fade>
      <div class="container max-w-6xl">
        <div class="flex flex-col lg:flex-row lg:items-center gap-10 lg:gap-16">
          <div class="lg:w-2/5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Verificatie</p>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-tight mb-4">
              21 providers. Vier lagen. Één verdict.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-6">
              Geen enkele database dekt je markt volledig. Wij draaien er 21 tegelijk en sturen elk resultaat door vier deliverability-checks. Alleen veilige adressen komen door.
            </p>
            <div class="flex items-center gap-3 pt-4" style="border-top: 1px solid var(--border);">
              <img src="/about/tim-wissink.jpg" alt="Tim Wissink" class="size-9 rounded-full object-cover shrink-0" />
              <p class="text-sm text-[var(--muted-foreground)] leading-snug italic">
                "Verkopen blijft mensenwerk. Software hoort je vrij te maken voor het gesprek, niet het gesprek over te nemen."
                <span class="block not-italic font-medium text-[var(--heading)] mt-1">Tim Wissink, Oprichter</span>
              </p>
            </div>
          </div>
          <div class="w-full lg:w-3/5">
            <VerificationWaterfall lang="nl" client:visible ratio="3/2" tabletRatio="16/9" mobileRatio="4/3" />
          </div>
        </div>
      </div>
    </section>
  </Background>

  <div style="position: relative; overflow: hidden; background: linear-gradient(180deg, var(--hooklyne-navy) 0%, #011f37 100%);">
    <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 80% 55% at 50% 0%, rgba(52,76,163,0.4) 0%, transparent 70%);"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg, transparent 0%, rgba(52,76,163,0.5) 30%, rgba(255,140,66,0.25) 55%, transparent 100%);"></div>
    <section class="py-14 lg:py-20 relative" data-fade>
      <div class="container max-w-6xl">
        <div class="flex flex-col lg:flex-row lg:items-center gap-10 lg:gap-16">
          <div class="w-full lg:w-3/5 order-2 lg:order-1">
            <WeeklyBrief lang="nl" client:visible ratio="3/2" tabletRatio="16/9" mobileRatio="4/3" />
          </div>
          <div class="lg:w-2/5 order-1 lg:order-2">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] mb-4" style="color: var(--hooklyne-orange);">Signaalbriefing</p>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-tight leading-tight mb-4" style="color: #fff;">
              Je markt gebrieft. Elke maandagochtend.
            </h2>
            <p class="text-base leading-relaxed" style="color: rgba(255,255,255,0.6);">
              Hooklyne scant de hele week koopsignalen bij je gevolgde prospects. Je ontvangt een briefing - wie bewoog, wat het betekent, wat je als eerste stuurt. Geen dashboard om te checken. Het vindt jou.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Background variant="bottom">
    <WhatYouGet lang="nl" />
    <WaysToStart lang="nl" client:visible />
    <BuiltFor lang="nl" client:visible />
    <HomePricing lang="nl" client:visible />
  </Background>
</DefaultLayout>
