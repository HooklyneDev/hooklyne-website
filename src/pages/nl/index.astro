---
import { SITE_DESCRIPTION_NL } from '../../consts';
import { Background } from '@/components/background';
import { Hero } from '@/components/blocks/hero';
import SignalTicker from '@/components/blocks/signal-ticker.astro';
import { DIYCompare } from '@/components/blocks/diy-compare';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';
import { WhatYouGet } from '@/components/blocks/what-you-get';
import { WaysToStart } from '@/components/blocks/ways-to-start';
import { BuiltFor } from '@/components/blocks/built-for';
import { HomePricing } from '@/components/blocks/home-pricing';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Hooklyne | B2B leadgeneratie voor Nederlandse MKB-salesteams"
  description={SITE_DESCRIPTION_NL}
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Hooklyne",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "inLanguage": "nl-NL",
    "description": "B2B leadgeneratie en prospect-onderzoek voor MKB-salesteams. Geverifieerde contacten, real-time koopsignalen en een eerste mail in de stem van je vertegenwoordiger. AVG-proof.",
    "url": "https://www.hooklyne.com/nl",
    "offers": {
      "@type": "Offer",
      "price": "39",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "39",
        "priceCurrency": "EUR",
        "billingIncrement": 1,
        "unitText": "MONTH"
      }
    },
    "featureList": [
      "B2B prospect-onderzoek",
      "Signaal-gedreven outreach",
      "E-mailverificatie",
      "Bedrijfs-discovery",
      "Gepersonaliseerde drafting in Nederlands en Engels"
    ]
  })} />
  <Background>
    <Hero client:load />
    <SignalTicker />
    <DIYCompare client:visible />
  </Background>

  <Background variant="bottom">
    <section class="pt-4 pb-8 sm:pt-6 lg:pt-10 lg:pb-12" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-10 px-2">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Verificatie</p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
            20+ databronnen. Vier lagen. Eén oordeel.
          </h2>
          <p class="text-sm sm:text-base text-[var(--muted-foreground)] leading-relaxed">
            Geen enkele database dekt meer dan ~40% van een markt, dus checken we er 20+ tegen elkaar en draaien daarna nog vier deliverability-checks. Komt een contact er niet door, dan gaat het ook niet uit.
          </p>
        </div>
        <VerificationWaterfall client:visible ratio="5/2" tabletRatio="2/1" mobileRatio="1/1" />
      </div>
    </section>

    <WhatYouGet />
    <WaysToStart client:visible />
    <BuiltFor client:visible />
    <HomePricing client:visible />
  </Background>
</DefaultLayout>
