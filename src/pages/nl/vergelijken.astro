---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";
import { livByCategory } from "@/data/guides";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Guides", path: "/nl/guides" },
  { name: "Vergelijken", path: "/nl/vergelijken" },
]);

const alternatives = livByCategory("alternative");
---

<DefaultLayout
  title="Hooklyne vergeleken — Apollo, Cognism, Lusha | Hooklyne"
  description="Hooklyne vergeleken met Apollo, Cognism, Lusha en andere B2B-prospectingtools. Eerlijke vergelijkingen voor Europese MKB-bedrijven. Waar Hooklyne wint en waar niet."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Hooklyne vergeleken — Apollo, Cognism, Lusha",
    "description": "Eerlijke vergelijkingen van Hooklyne versus de B2B-prospectingtools die Europese MKB-salesteams het meest gebruiken.",
    "url": "https://www.hooklyne.com/nl/vergelijken",
    "inLanguage": "nl"
  })} />

  <Background>
    <section class="pt-24 sm:pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">
          <a href="/nl/guides" class="hover:underline">Guides</a> / Vergelijken
        </p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Hoe Hooklyne zich <span class="text-accent">verhoudt</span>.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Eerlijke vergelijkingen met de B2B-prospectingtools die Europese salesteams het meest gebruiken. Waar Hooklyne wint, waar niet, en voor wie elk tool is gebouwd.
        </p>
      </div>
    </section>

    <section class="pb-24 lg:pb-32">
      <div class="container max-w-5xl">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {alternatives.map((item) => (
            <a
              href={item.nl.slug}
              class="group block rounded-2xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
              style="background: var(--card); border: 1px solid var(--border);"
            >
              <span class="inline-block text-[10px] font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-3">Alternatief</span>
              <h3 class="text-base font-semibold text-[var(--heading)] mb-2 group-hover:text-[var(--hooklyne-blue)] transition-colors">{item.nl.label}</h3>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">{item.nl.description}</p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-[var(--hooklyne-blue)]">
                {item.nl.cta}
                <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
