---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, AlertCircle, Gift } from 'lucide-react';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Bouw en vastgoed prospecting", path: "/nl/bouw-prospecting" },
]);

const pains = [
  "De projectdirecteur die je nodig hebt is op de bouwplaats, niet op LinkedIn.",
  "Omgevingsvergunningen zijn je beste lead-signaal - en je vindt ze na de eerste paal.",
  "Bouwinkoop verloopt in fasen. Je komt aan op de verkeerde.",
  "Ontwikkelaarscontacten wisselen per project. Je werkt met een lijst die al verouderd is.",
];

const signals = [
  {
    title: "Omgevingsvergunningen en bouwvergunningen.",
    body: "Een omgevingsvergunningsaanvraag is het vroegste mogelijke signaal dat een bouw- of ontwikkelingsproject reëel en gefinancierd is. Het gaat maanden vooraf aan aannemerbenoemingen, materiaalaankoop en apparatuurbestellingen. In Nederland zijn omgevingsvergunningsaanvragen openbaar via Omgevingsloket. De meeste verkopers horen over projecten via persberichten van eerstesteenleggingen - op welk moment de inkoop al grotendeels is beslist.",
  },
  {
    title: "Ontwikkelaar- en aannemersaanbestedingen.",
    body: "Publieke en semi-publieke aanbestedingen in de bouw staan in inkoopportalen, sectorspecifieke databases en vakpublicaties voordat ze sluiten. TenderNed voor Nederlandse overheidsdrempel-projecten, TED voor EU-drempel-projecten. Op de aanbestedingslijst staan is veel makkelijker als je al contact hebt gemaakt voordat de aanbesteding is opgesteld. Inkoopmanagers schrijven specificaties rondom leveranciers die ze al hebben gesproken. Koud bij een aanbestedingsfase aankomen is beginnen met een achterstand.",
  },
  {
    title: "Vastgoedacquisities en portefeuilleaankondigingen.",
    body: "Een projectontwikkelaar die zojuist een locatie heeft verworven of een nieuw project heeft aangekondigd, gaat een inkoopvolgorde in voor professionele diensten, bouwmanagement, materialen en technologie. Commercieel vastgoedacquisities worden geregistreerd in openbare kadasters en vaak aangekondigd in vakbladen binnen dagen. De inkoop die volgt is zowel voorspelbaar als tijdsgecomprimeerd - ontwikkelaars bewegen snel zodra de vergunning is verleend.",
  },
  {
    title: "Duurzaamheidscertificering en ESG-compliance-vereisten.",
    body: "BREEAM, LEED, WELL en energieprestatie-vereisten zijn steeds vaker verplicht voor commerciële ontwikkeling - door regelgeving, investeerderconvenant of huurderseisen. Een ontwikkelaar die BREEAM Excellent heeft toegezegd voor een project, koopt actief de systemen, materialen en adviseurs die de rating haalbaar maken. Deze toezeggingen staan in vergunningsaanvragen, investeringsaankondigingen en ESG-rapporten voordat ze in een database verschijnen.",
  },
];

const faq = [
  {
    q: "Bouwbeslissingen betrekken veel onderaannemers en tussenpersonen. Wie bereik ik eigenlijk?",
    a: "Dat hangt af van wat je verkoopt. Voor materialen en apparatuur: inkoopmanager of projectmanager. Voor professionele diensten: de lead-ontwikkelaar of ontwikkelingsdirecteur. Voor technologie en software: de digitaal/BIM-manager of operationeel directeur. Hooklyne bepaalt het juiste senioriteitsniveau voor jouw aanbod bij elk bedrijf - de bouw heeft meer onderscheiden contacttypes dan de meeste sectoren.",
  },
  {
    q: "Bouwcycli zijn lang en relatiegedreven. Is koude outreach effectief?",
    a: "Koude outreach op het verkeerde moment is ineffectief. Koude outreach in de planningsfase - voordat de shortlist wordt gevormd - is zeer effectief. Het doel is een bekende naam zijn op het moment dat inkoop formeel opengaat. Dat vereist het bereiken van de juiste persoon voordat het project in actieve inkoop zit, niet erna.",
  },
  {
    q: "We richten ons op woningbouwontwikkelaars specifiek. Heeft Hooklyne dekking in dat segment?",
    a: "Ja. Woningbouwontwikkelaars en projectbouwers zijn gedekt via bedrijfsregisters, planningsdatabases en sectorbronnen. Zowel grote volumebouwers als MKB-woningbouwers zijn in scope. De signaalsbronnen verschillen iets - woningbouwvergunningsaanvragen gaan doorgaans via gemeentelijke portalen, commercieel via nationale databases - maar beide worden gemonitord.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons bouw-ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte doellijst, volledig opgebouwd, zonder kaart. Bouw is een segment waar de planningsdatabasesignaalanpak ofwel meteen logisch is voor jouw aanbod of niet - de pilot laat dat snel zien.",
  },
];
---

<DefaultLayout
  title="Prospecting bij bouw en vastgoedontwikkeling | Hooklyne"
  description="Hoe je buyers in bouw en vastgoed bereikt: waar planningssignalen zijn, hoe je actieve inkoopfasen herkent en hoe je er bent voordat de shortlist gesloten is."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Bouw en vastgoed prospecting-gids",
    "description": "Hoe je bouw- en vastgoedbedrijven prospecteert: planningssignalen, contacten en koopfasen.",
    "url": "https://www.hooklyne.com/nl/bouw-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Bouw en vastgoed prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Bouwinkoop is beslist voordat de bouwborden staan.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Tegen de tijd dat een bouwproject in de vakpers verschijnt, is de leveranciersshortlist grotendeels gevormd. De kopers die ertoe doen - projectontwikkelaars, inkoopmanagers, ontwikkelingsmanagers - zijn maanden eerder bereikbaar, wanneer de omgevingsvergunning is ingediend en de inkoop nog niet is begonnen. Deze gids behandelt hoe je die signalen vindt en wat je ermee doet.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <AlertCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte bouwprospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw bouw-ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe bouw- en vastgoedbedrijven kopen</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een bouwkoopvenster openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Bouwinkoop is voorspelbaar als je weet waar je moet kijken. De signalen staan in planningsdatabases en registers - niet in persberichten die aankomen nadat de beslissingen al genomen zijn.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Waar Hooklyne past</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Gebouwd voor inkoop die begint voordat het project openbaar is.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Bouw- en vastgoedinkoop is front-loaded. De beslissingen die ertoe doen - wie op de shortlist komt, wie de specificatie schrijft, wie wordt uitgenodigd voor een aanbesteding - vinden plaats in de planningsfase, niet in de bouwfase. Hooklyne monitort Omgevingsloket, kadasters en inkoopportalen om het signaal te vinden op het punt waar contact nog een verschil maakt.</p>
          <p>Het juiste contact varieert aanzienlijk per projectfase en bedrijfstype. Een ontwikkelaar in de pre-planningsfase verschilt van een aannemer in de aanbestedingsfase. Hooklyne bepaalt de juiste rol bij elk bedrijf op basis van jouw aanbod en verifieert het contact over 21 providers - in plaats van een generieke lijst te geven en de targetingbeslissing aan jouw vertegenwoordiger over te laten.</p>
          <p>De eerste mail wordt opgesteld in de schrijfstijl van jouw vertegenwoordiger en verwijst naar het specifieke project of de aanvraag die dit bedrijf nu relevant maakt. Een ontwikkelingsmanager die een bericht ontvangt dat zijn recente omgevingsvergunningsaanvraag noemt en koppelt aan een concrete inkoopbehoefte, leest het. Een generieke 'wij helpen bouwbedrijven'-boodschap niet.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Gerelateerde gidsen</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/nl/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Alle branchegidsen</a>
          <a href="/nl/industrie-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrie en productie</a>
          <a href="/nl/energie-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Energie en nutsbedrijven</a>
          <a href="/nl/avg-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">AVG-compliant prospecting</a>
          <a href="/nl/vergelijken" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool-vergelijkingen</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over bouw prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
