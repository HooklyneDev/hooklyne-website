---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Fintech en financiële diensten prospecting", path: "/nl/fintech-prospecting" },
]);

const pains = [
  "Een CCO bij een gereguleerde firma die vraagt 'hoe bent u aan mijn gegevens gekomen?' is geen kleinigheid.",
  "Fintech-kopers hebben een kortere lont voor irrelevantie dan vrijwel elke andere sector.",
  "Regelgevingsmijlpalen zijn je beste timing-signalen - en je houdt ze bij in een spreadsheet.",
  "De CFO was al weg. Dat merkte je toen de mail bounced.",
];

const signals = [
  {
    title: "Regelgevingsautorisaties en compliance-mijlpalen.",
    body: "FCA-autorisatie, DNB-registratie, PSD2-compliance, DORA-gereedheidsterminijnen, NIS2 - elk creëert een inkoopvenster. Een fintech-bedrijf dat net een vergunning heeft ontvangen, schaalt snel met vers budget en een mandaat om infrastructuur op te bouwen. Een bedrijf dat een compliance-deadline nadert, is een gemotiveerde koper met een datum. Beide zijn sterker als signaal dan 'ze passen op het ICP' - omdat ze aangeven dat de beslissing om te investeren al is genomen.",
  },
  {
    title: "Financieringsrondes en productlanceringen.",
    body: "Series A tot C in fintech gaan doorgaans gepaard met agressieve wervingsplannen, nieuwe marktintrede en infrastructuurupbouw op tijdlijnen die zijn vastgesteld door boardverwachtingen. Een productlancering - een nieuw betalingsrail, een nieuw leenproduct, een embedded finance-functie - brengt vaak ook nieuwe leveranciersbeslissingen mee. De inkoop die volgt op een productlancering is vaak gecomprimeerd: teams bewegen snel als er een commerciële deadline aan een nieuwe capability is gekoppeld.",
  },
  {
    title: "Compliance-vacatures.",
    body: "Een nieuwe Head of Compliance, Chief Risk Officer of MLRO-hire signaleert dat een bedrijf schaalt, op regelgevingsdruk reageert, of beide. De nieuwe persoon beoordeelt leveranciersrelaties vroeg - voordat bestaande relaties zijn vastgelegd en voordat het nieuwe compliance-kader business as usual wordt. Dat zijn ook de eerste 60 tot 90 dagen. Het is ook het moment waarop een bedrijf het meest open staat voor het wisselen van providers die zijn meegelopen onder de vorige leiding.",
  },
  {
    title: "Uitbreiding naar nieuwe markten of betalingscorridors.",
    body: "Een fintech die uitbreidt van Nederland naar Duitsland, of een nieuwe betalingscorridor toevoegt, koopt nieuwe dingen: compliance-infrastructuur, lokale dataproviders, nieuwe bankrelaties en vaak nieuwe tooling voor het uitgebreide toepassingsgebied. Marktuitbreidingsaankondigingen zijn openbaar en de inkoop die volgt is direct. Het team dat de uitbreiding leidt neemt deze beslissingen doorgaans onafhankelijk van het kernproductteam.",
  },
];

const faq = [
  {
    q: "Fintech compliance-teams zijn erg gevoelig voor data. Kan Hooklyne hier opereren?",
    a: "Ja - en dit is waar Hooklyne's herkomstbenadering het meest telt. Elk contact heeft een gedocumenteerde bron. Geen gescrapete sessiedata, geen lookalike audiences, geen 'onze database' als enig antwoord. Voor fintech-bedrijven die hun eigen AVG-audits uitvoeren is de contactbronning van Hooklyne documenteerbaar en verdedigbaar.",
  },
  {
    q: "We verkopen aan heel specifieke fintech-subsegmenten. Werkt de dekking op dat niveau?",
    a: "Dat hangt af van het segment. Gevestigde payments-, lending- en wealthtech-bedrijven zijn goed gedekt in Europese provider-databases. Vroege-fase fintechs en niche embedded finance-spelers kunnen dunner zijn. De pilot vertelt het je - tien prospects uit jouw exacte ICP, volledig opgebouwd, voor enige verplichting.",
  },
  {
    q: "Fintech-verkooptrajecten zijn lang en hebben meerdere stakeholders. Is Hooklyne dan nog nuttig?",
    a: "Het eerste gesprek moet toch ergens beginnen. Hooklyne brengt je bij het juiste eerste contact op het juiste moment met een reden die een antwoord verdient. Wat daarna gebeurt is jouw proces. De meeste teams die Hooklyne in fintech gebruiken, zetten het in om de bovenkant van de funnel te openen - niet om de relatie te vervangen.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons fintech-ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte fintech-doellijst, volledig opgebouwd, zonder kaart. Levert de output geen gesprekken op die je anders niet had gehad, dan stop je. Fintech is een segment waar de sourcing- en timing-aanpak snel resoneert of niet - de pilot maakt dat duidelijk.",
  },
];
---

<DefaultLayout
  title="Prospecting bij fintech en financiële diensten | Hooklyne"
  description="Hoe je buyers in fintech en financiële diensten bereikt: de regelgevingssignalen die koopvensters openen, waarom dataprovenance in gereguleerde sectoren telt en hoe je een CCO een antwoord ontlokt."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Fintech en financiële diensten prospecting-gids",
    "description": "Hoe je fintech- en financiële dienstverleners prospecteert: signalen, compliance en timing.",
    "url": "https://www.hooklyne.com/nl/fintech-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Fintech en financiële diensten prospecting</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Fintech-kopers hebben een kortere lont voor irrelevantie dan de meesten.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Gereguleerde kopers lezen koude outreach kritisch. Een verkeerd bericht wordt niet alleen genegeerd - het laat een negatieve indruk achter. Deze gids behandelt de signalen die een echt venster openen in financiële diensten, waarom dataprovenance hier meer telt dan ergens anders en hoe je op precies het juiste moment aankomt.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte fintech-prospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw fintech-ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe fintech-bedrijven kopen</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een koopvenster in financiële diensten openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Fintech-inkoop is event-gedreven: regelgevingsmijlpalen, funding, productlanceringen, marktintrede. Buiten die vensters is de deur grotendeels dicht. Dit zijn de signalen die aangeven wanneer hij open is.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Waar Hooklyne past</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Gebouwd voor kopers die kritisch kijken naar hoe je ze hebt gevonden.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>In gereguleerde sectoren heeft 'hoe bent u aan mijn gegevens gekomen?' juridisch gewicht. Elk Hooklyne-contact wordt geleverd met zijn gedocumenteerde bron - publiek profiel, geregistreerde provider, bedrijfswebsite. Hooklyne is gebouwd en gehost in Nederland, gebruikt geen gescrapete gedragsdata en watervalt over 21 geregistreerde providers. Voor fintech-kopers in gereguleerde omgevingen telt die herkomst - zeker als jouw eigen compliance-team ooit vraagt hoe je contacten bronneert.</p>
          <p>Fintech-inkoop clustert rond regelgevingsdeadlines, funding-events en productlanceringen. Hooklyne scoort prospects op die signalen en bereidt outreach voor om op het event te landen - niet op een sequentiedag. Een bericht dat de DORA-gereedheidstermijn noemt en koppelt aan een concrete infrastructuurimplicatie wordt gelezen. Hetzelfde bericht op een dinsdag-drip niet.</p>
          <p>Het juiste contact in fintech hangt af van wat je verkoopt. Een betalingsinfrastructuurtool gaat naar de CTO of Head of Engineering. Een compliance-platform gaat naar de Head of Compliance of de nieuwe MLRO. Hooklyne bepaalt het correcte senioriteitsniveau per bedrijf en verifieert het contact voordat het bij jouw vertegenwoordiger terechtkomt - in plaats van een generieke lijst te geven en het oordeel over te laten aan iemand die nog twintig andere prospects te verwerken heeft.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Gerelateerde gidsen</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/nl/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Alle branchegidsen</a>
          <a href="/nl/saas-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">B2B SaaS</a>
          <a href="/nl/avg-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">AVG-compliant prospecting</a>
          <a href="/nl/vergelijken" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool-vergelijkingen</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over fintech prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
