---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { breadcrumbList } from '@/lib/seo';
import { SITE_URL } from '@/consts';

const breadcrumb = breadcrumbList([
  { name: 'Home', path: '/nl' },
  { name: 'Prijzen', path: '/nl/prijzen' },
]);

const offerCatalog = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Hooklyne",
  serviceType: "B2B prospect research",
  provider: { "@type": "Organization", name: "Hooklyne", url: SITE_URL },
  areaServed: ["NL", "BE", "GB", "LU", "DE", "FR", "IE", "DK", "SE", "NO", "FI"],
  audience: { "@type": "BusinessAudience", audienceType: "B2B MKB-salesteams (10-100 personen)" },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Hooklyne plans",
    itemListElement: [
      { "@type": "Offer", name: "Start", price: "39", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Growth", price: "129", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Scale", price: "239", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Enterprise", url: `${SITE_URL}/nl/contact`, category: "custom" },
    ],
  },
};
---

<DefaultLayout title="Prijzen | Hooklyne" description="Prijzen voor B2B leadgeneratie en prospectie voor het MKB. Betaal voor wat je gebruikt: elk credit is een duidelijk eindproduct. Vanaf €39 per maand." image="/og/NL/prijzen.jpg" ctaVariant="pricing">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(offerCatalog)} />
  <Background>
  <section class="pt-32 lg:pt-44 pb-10 relative">
    <HeroGlow lang="nl" client:idle signals={false} />
    <div id="hero-content" class="container max-w-6xl relative z-10">

      <!-- Header -->
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Prijzen</p>
        <h1 class="hero-headline text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">Heldere prijzen, <span class="text-accent">transparante credits</span>.</h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">Een transparant credit-systeem waarin elke actie hetzelfde kost, op elk abonnement. Geen seat-kosten op Start en Growth, en je wisselt of zegt op wanneer je wilt.</p>
      </div>

      <!-- Free pilot banner (kept inside the hero section so the glow reaches behind it) -->
      <div class="mt-14 rounded-2xl overflow-hidden" style="background: var(--card); box-shadow: var(--shadow-xs); border: 1px solid var(--border)">
        <div class="grid md:grid-cols-[auto_1fr_auto] gap-6 items-center p-6">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center size-10 rounded-xl" style="background: rgba(13,148,136,0.12)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hooklyne-teal)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 7l8 5 8-5-8-5Z"/><path d="m4 12 8 5 8-5"/><path d="m4 17 8 5 8-5"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)]">Gratis pilot</p>
              <p class="text-base font-semibold text-[var(--heading)]">Probeer het voor je betaalt.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 text-sm md:border-l md:border-r md:border-[var(--border)] md:px-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">Jij krijgt</p>
              <p class="text-[var(--foreground)] leading-relaxed">Tien complete prospectpakketten, volledige toegang tot het portaal en twee weken sectornieuws.</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">Wij vragen</p>
              <p class="text-[var(--foreground)] leading-relaxed">Twintig minuten eerlijke feedback, en als het werkt mogen we je noemen.</p>
            </div>
          </div>

          <a href="/nl/contact" class="inline-flex items-center justify-center gap-1.5 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine whitespace-nowrap" style="background: var(--hooklyne-teal)">
            Start pilot
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container max-w-6xl">

      <!-- Toggle -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <span class="text-sm font-medium transition-colors" id="label-monthly" style="color: var(--muted-foreground)">Maandelijks</span>
        <button
          id="toggle-btn"
          class="relative w-12 h-6 rounded-full transition-colors cursor-pointer btn-shine"
          style="background: var(--hooklyne-navy)"
          onclick="toggleBilling()"
          aria-label="Toggle billing period"
        >
          <span id="toggle-knob" class="absolute top-0.5 left-0.5 size-5 rounded-full bg-white transition-transform duration-200 shadow-sm" style="transform: translateX(24px)"></span>
        </button>
        <span class="text-sm font-medium flex items-center gap-2 transition-colors" id="label-annual" style="color: var(--heading)">
          Jaarlijks
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal)">Bespaar tot €60/maand</span>
        </span>
      </div>

      <!-- Plan cards -->
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-12">

        <!-- Start -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Start</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="49" data-annual="39">€39</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Bespaar €10/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Voor solo reps die hun outbound willen valideren.</p>
          <div class="flex items-baseline gap-2 rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">100</span>
            <span class="text-xs text-[var(--muted-foreground)]">credits / mnd</span>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["100 credits / mnd", "1 seat", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktupdate", "Meeting prep briefs"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="start" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Aan de slag
          </a>
        </div>

        <!-- Growth (featured) -->
        <div class="rounded-2xl p-5 flex flex-col relative text-white" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-xl)">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-white text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap" style="background: var(--hooklyne-orange)">
            Meest gekozen
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-3 mt-1">Growth</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-white price-display" data-monthly="159" data-annual="129">€129</span>
            <span class="text-sm text-white/40 ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-green-300">Bespaar €30/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-white/50 mb-4">Voor 1-2 reps met een volle pipeline en alles erbij.</p>
          <div class="flex items-baseline gap-2 rounded-xl px-3 py-2.5 mb-4" style="background: rgba(255,255,255,0.08)">
            <span class="text-2xl font-bold text-blue-300">400</span>
            <span class="text-xs text-white/40">credits / mnd</span>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["400 credits / mnd", "2 seats", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktupdate", "Meeting prep briefs", "45-min setup + strategiegesprek", "ideaal klantprofiel samen met jou ingesteld"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-white/70">
                <svg class="size-3.5 shrink-0 mt-0.5 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-white/30 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="growth" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine bg-white/14 text-white border border-white/22 hover:bg-white/24">
            Aan de slag
          </a>
        </div>

        <!-- Scale -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Scale</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="299" data-annual="239">€239</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Bespaar €60/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Voor teams tot 5 reps die volume-outbound draaien.</p>
          <div class="flex items-baseline gap-2 rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">800</span>
            <span class="text-xs text-[var(--muted-foreground)]">credits / mnd</span>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["800 credits / mnd", "5 seats", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktupdate", "Meeting prep briefs", "Volledige setup + teamtraining"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="scale" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Aan de slag
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Enterprise</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)]">Custom</span>
          </div>
          <div class="h-5 mb-2"></div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Voor sales-afdelingen in meerdere markten, met afspraken op maat.</p>
          <div class="flex items-baseline gap-2 rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">Custom</span>
            <span class="text-xs text-[var(--muted-foreground)]">credit-volume</span>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["Custom credit-volume", "Unlimited seats", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktupdate", "Meeting prep briefs", "Volledige setup + teamtraining", "Eigen account manager"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: Op maat</p>
          <a href="/nl/contact" data-tier="enterprise" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Praat met ons
          </a>
        </div>

      </div>

      <!-- Three ways to build a prospect -->
      <div class="mb-12">
        <div class="text-center max-w-2xl mx-auto mb-8">
          <h2 class="text-2xl font-semibold text-[var(--heading)] tracking-tight mb-2">Drie manieren om een prospect op te bouwen.</h2>
          <p class="text-sm text-[var(--muted-foreground)]">Elke workflow eindigt op hetzelfde punt - een verzendklaar prospectpakket - en jij kiest het pad dat past bij hoe je werkt.</p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <!-- Path 1 -->
          <div class="rounded-2xl bg-[var(--card)] p-5 flex flex-col relative" style="box-shadow: var(--shadow-xs)">
            <div class="flex items-center gap-2 mb-3">
              <span class="flex items-center justify-center size-7 rounded-full text-xs font-bold text-white" style="background: var(--hooklyne-blue)">1</span>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">Discovery-eerst</p>
            </div>
            <h3 class="text-base font-semibold text-[var(--heading)] mb-2">Begin met een ideaal klantprofiel</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">Beschrijf je ideale klant en wij leveren tot 20 gerangschikte bedrijven met signaal-hooks. Kies er een uit, dan bouwen wij het hele pakket.</p>
            <div class="mt-auto pt-4 border-t border-[var(--border)]">
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-[var(--muted-foreground)]">Bedrijven-discovery</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">1cr</span>
              </div>
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-[var(--muted-foreground)]">Contact zoeken</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">2cr</span>
              </div>
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-[var(--muted-foreground)]">Prospect-pakket</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">1cr</span>
              </div>
              <div class="flex items-center justify-between text-sm font-semibold pt-2 border-t border-[var(--border)]">
                <span class="text-[var(--heading)]">Totaal per prospect</span>
                <span class="text-[var(--hooklyne-navy)]">4cr</span>
              </div>
            </div>
          </div>

          <!-- Path 2 -->
          <div class="rounded-2xl bg-[var(--card)] p-5 flex flex-col relative" style="box-shadow: var(--shadow-xs)">
            <div class="flex items-center gap-2 mb-3">
              <span class="flex items-center justify-center size-7 rounded-full text-xs font-bold text-white" style="background: var(--hooklyne-blue)">2</span>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">Contact-eerst</p>
            </div>
            <h3 class="text-base font-semibold text-[var(--heading)] mb-2">Begin met een bekend bedrijf</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">Je hebt de targetlijst al, en wij vinden en verifiëren de juiste besluitvormer voor je en bouwen het volledige prospectpakket.</p>
            <div class="mt-auto pt-4 border-t border-[var(--border)]">
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-[var(--muted-foreground)]">Contact zoeken</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">2cr</span>
              </div>
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-[var(--muted-foreground)]">Prospect-pakket</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">1cr</span>
              </div>
              <div class="flex items-center justify-between text-sm font-semibold pt-2 border-t border-[var(--border)]">
                <span class="text-[var(--heading)]">Totaal per prospect</span>
                <span class="text-[var(--hooklyne-navy)]">3cr</span>
              </div>
            </div>
          </div>

          <!-- Path 3 -->
          <div class="rounded-2xl bg-[var(--card)] p-5 flex flex-col relative" style="box-shadow: var(--shadow-xs)">
            <div class="flex items-center gap-2 mb-3">
              <span class="flex items-center justify-center size-7 rounded-full text-xs font-bold text-white" style="background: var(--hooklyne-blue)">3</span>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">Signaal-gedreven</p>
            </div>
            <h3 class="text-base font-semibold text-[var(--heading)] mb-2">Begin met een signaal</h3>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">We volgen je targets dagelijks, en zodra er een koopsignaal binnenkomt - een hire, nieuws, funding of expansie - staat het prospectpakket voor je klaar.</p>
            <div class="mt-auto pt-4 border-t border-[var(--border)]">
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-[var(--muted-foreground)]">Signal tracking</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">2cr / co / mo</span>
              </div>
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-[var(--muted-foreground)]">Prospect-pakket</span>
                <span class="font-semibold text-[var(--hooklyne-blue)]">1cr</span>
              </div>
              <div class="flex items-center justify-between text-sm font-semibold pt-2 border-t border-[var(--border)]">
                <span class="text-[var(--heading)]">Timing</span>
                <span class="text-[var(--hooklyne-teal)]">Op hún moment</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Credit table -->
      <div class="rounded-2xl bg-[var(--card)] overflow-hidden mb-12" style="box-shadow: var(--shadow-sm)">
        <div class="px-6 py-5 border-b border-[var(--border)]">
          <h2 class="text-base font-semibold text-[var(--heading)]">Wat je voor een credit krijgt.</h2>
          <p class="text-sm text-[var(--muted-foreground)] mt-1">Elke credit staat voor een duidelijk eindproduct, en bladeren, signalen lezen en intel bekijken blijven altijd gratis.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[var(--border)]" style="background: var(--background)">
                <th class="text-left px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--muted-foreground)]">Actie</th>
                <th class="text-left px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--muted-foreground)] hidden lg:table-cell">Wat je krijgt</th>
                <th class="text-right px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--hooklyne-blue)]">Credits</th>
              </tr>
            </thead>
            <tbody>
              {[
                ["Bedrijven-discovery", "Tot 20 gerangschikte bedrijven, ideaal klantprofiel-gefilterd en voorzien van signaal-hooks.", "1cr", false],
                ["Bekijk passende rollen", "Tot 3 besluitvormers per bedrijf.", "Inclusief", true],
                ["Prospect-pakket", "Mail met nieuws-hook plus LinkedIn-bericht in NL of EN, in jouw stem.", "1cr", false],
                ["Contact zoeken", "Geverifieerd mailadres, drievoudig gecheckt over 21 bronnen.", "2cr", false],
                ["Signal tracking", "Dagelijkse scans op vacatures, nieuws en funding, gescoord en gerangschikt op relevantie.", "2cr / bedrijf / mnd", false],
                ["Meeting prep brief", "Bedrijfsoverzicht, talking points, sleutelpersonen en recent nieuws op een pagina.", "1cr", false],
                ["Wekelijkse marktupdate", "5-10 artikelen uit jouw markt, gescoord op relevantie.", "Inclusief", true],
                ["Export naar CSV", "Volledige export van je leads en signalen", "Inclusief", true],
              ].map(([action, desc, cost, isFree]) => (
                <tr class="border-b border-[var(--border)] last:border-0 hover:bg-[var(--card-hover)] transition-colors">
                  <td class="px-6 py-3.5 font-medium text-[var(--foreground)] whitespace-nowrap">{action}</td>
                  <td class="px-6 py-3.5 text-[var(--muted-foreground)] hidden lg:table-cell">{desc}</td>
                  <td class="px-6 py-3.5 text-right">
                    <span class={`text-sm font-semibold ${isFree ? "text-[var(--hooklyne-teal)]" : "text-[var(--hooklyne-blue)]"}`}>{cost}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- FAQ section -->
      <div class="mb-12">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-semibold text-[var(--heading)] tracking-tight">Vragen over prijzen.</h2>
          <p class="text-sm text-[var(--muted-foreground)] mt-2">Alles wat je moet weten voor je begint.</p>
        </div>

        <div class="max-w-3xl mx-auto space-y-2" id="pricing-faq">
          {[
            {
              q: "Wat is een credit?",
              a: "Een credit is wat je uitgeeft aan acties die een eindproduct opleveren: bedrijven-discovery kost 1 credit (tot 20 bedrijven), een prospectpakket 1 credit (mail plus LinkedIn-bericht in jouw stem), contact zoeken 2 credits (geverifieerd mailadres, drievoudig gecheckt) en signal tracking 2 credits per bedrijf per maand. Bladeren, intel lezen en exporteren blijven altijd gratis."
            },
            {
              q: "Wat gebeurt er als ik door mijn credits heen ben?",
              a: "Op elk moment kun je top-uppen voor €0,85 per credit, zonder blokkades. Je bestaande data, signalen en contacten blijven beschikbaar, ongeacht je credit-saldo."
            },
            {
              q: "Wat is signal tracking?",
              a: "Signal tracking volgt een bedrijf dagelijks op vacatures, nieuws, fundingrondes en leiderschapswissels, en elk signaal wordt gescoord op relevantie voor wat jij verkoopt. Start dekt tot 10 bedrijven, Growth tot 40, Scale tot 100, en Enterprise op maat. Extra bedrijven boven je limiet kosten 2 credits per bedrijf per maand."
            },
            {
              q: "Kan ik van plan wisselen?",
              a: "Ja, op elk moment. Maandelijkse plannen wisselen op de volgende factuurdatum, en upgrade je halverwege de maand, dan krijg je naar rato credits voor de resterende dagen. Downgrades gaan in bij je volgende verlenging."
            },
            {
              q: "Wat zit er in de gratis pilot?",
              a: "Tien complete prospectpakketten met een seat ingericht op je ideaal klantprofiel, twee weken sectornieuws en volledige toegang tot het portaal. Signal tracking, discovery en meeting prep zijn zichtbaar maar op slot. In ruil vragen we een feedbackgesprek van 20 minuten en toestemming voor een case study; geen betaling vereist."
            },
            {
              q: "Is er een contract?",
              a: "Op maandelijkse plannen is er geen contract en altijd opzegbaar; jaarplannen lopen 12 maanden, vooraf of maandelijks gefactureerd, met korting ingebouwd. Op Scale bespaar je tot €60 per maand."
            },
            {
              q: "Wat betekent 'outreach in je stem'?",
              a: "Tijdens de setup verzamelen we schrijfvoorbeelden en toon-input van jou, en daarna past elke mail en elk LinkedIn-bericht zich aan jouw stijl aan in plaats van te leunen op een generieke template. Het prospectpakket is daarna klaar om direct te versturen of te kopiëren."
            },
            {
              q: "Wat zit er in het 45-min setup-gesprek op Growth?",
              a: "We richten je ideaal klantprofiel samen in, zetten signal tracking op voor je targetmarkt, lopen je toonprofiel door en plannen de eerste maand outbound. Na afloop staat het systeem en heb je je eerste lijst met targets klaar."
