---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { breadcrumbList } from '@/lib/seo';
import { SITE_URL } from '@/consts';

const breadcrumb = breadcrumbList([
  { name: 'Home', path: '/nl' },
  { name: 'Prijzen', path: '/nl/prijzen' },
]);

const offerCatalog = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Hooklyne",
  serviceType: "B2B prospect research",
  provider: { "@type": "Organization", name: "Hooklyne", url: SITE_URL },
  areaServed: ["NL", "BE", "GB", "LU", "DE", "FR", "IE", "DK", "SE", "NO", "FI"],
  audience: { "@type": "BusinessAudience", audienceType: "B2B MKB-salesteams (10-100 personen)" },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Hooklyne plans",
    itemListElement: [
      { "@type": "Offer", name: "Start", price: "39", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Growth", price: "129", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Scale", price: "239", priceCurrency: "EUR", url: `${SITE_URL}/nl/prijzen`, category: "annual billing" },
      { "@type": "Offer", name: "Enterprise", url: `${SITE_URL}/nl/contact`, category: "custom" },
    ],
  },
};
---

<DefaultLayout title="Prijzen | Hooklyne" description="Prijzen voor B2B leadgeneratie en prospectie voor het MKB. Betaal voor wat je gebruikt: elk credit is een duidelijk eindproduct. Vanaf €39 per maand." image="/og/NL/prijzen.jpg" ctaVariant="pricing">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(offerCatalog)} />
  <Background>
  <section class="pt-24 sm:pt-32 lg:pt-44 pb-10 relative">
    <HeroGlow lang="nl" client:idle signals={false} />
    <div id="hero-content" class="container max-w-6xl relative z-10">

      <!-- Header -->
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Prijzen</p>
        <h1 class="hero-headline text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">Heldere prijzen, <span class="text-accent">transparante credits</span>.</h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">Een transparant credit-systeem waarin elke actie hetzelfde kost, op elk abonnement. Geen seat-kosten op Start en Growth, en je wisselt of zegt op wanneer je wilt.</p>
        <a href="/nl/hoe-het-werkt" class="inline-block mt-3 text-[12.5px] text-[var(--muted-foreground)] hover:text-[var(--hooklyne-blue)] hover:underline transition-colors">
          Hoe wij anders zijn dan andere prospecting tools →
        </a>
      </div>

      <!-- Free pilot banner (kept inside the hero section so the glow reaches behind it) -->
      <div class="mt-14 rounded-2xl overflow-hidden" style="background: var(--card); box-shadow: var(--shadow-xs); border: 1px solid var(--border)">
        <div class="grid md:grid-cols-[auto_1fr_auto] gap-6 items-center p-6">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center size-10 rounded-xl" style="background: rgba(13,148,136,0.12)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hooklyne-teal)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 7l8 5 8-5-8-5Z"/><path d="m4 12 8 5 8-5"/><path d="m4 17 8 5 8-5"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)]">Gratis pilot</p>
              <p class="text-base font-semibold text-[var(--heading)]">Probeer het voor je betaalt.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 text-sm md:border-l md:border-r md:border-[var(--border)] md:px-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">Jij krijgt</p>
              <p class="text-[var(--foreground)] leading-relaxed">Tien complete prospectpakketten, volledige toegang tot het portaal en twee weken sectornieuws.</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-2">Wij vragen</p>
              <p class="text-[var(--foreground)] leading-relaxed">Twintig minuten eerlijke feedback, en als het werkt mogen we je noemen.</p>
            </div>
          </div>

          <a href="/nl/contact" class="inline-flex items-center justify-center gap-1.5 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine whitespace-nowrap" style="background: var(--hooklyne-teal)">
            Start pilot
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container max-w-6xl">

      <!-- Toggle -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <span class="text-sm font-medium transition-colors" id="label-monthly" style="color: var(--muted-foreground)">Maandelijks</span>
        <button
          id="toggle-btn"
          class="relative w-12 h-6 rounded-full transition-colors cursor-pointer btn-shine"
          style="background: var(--hooklyne-navy)"
          onclick="toggleBilling()"
          aria-label="Toggle billing period"
        >
          <span id="toggle-knob" class="absolute top-0.5 left-0.5 size-5 rounded-full bg-white transition-transform duration-200 shadow-sm" style="transform: translateX(24px)"></span>
        </button>
        <span class="text-sm font-medium flex items-center gap-2 transition-colors" id="label-annual" style="color: var(--heading)">
          Jaarlijks
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal)">Bespaar tot €60/maand</span>
        </span>
      </div>

      <!-- Plan cards -->
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-12">

        <!-- Start -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Start</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="49" data-annual="39">€39</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Bespaar €10/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Eén rep. Test en valideer je outbound. Self-serve.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">100</span>
              <span class="text-xs text-[var(--muted-foreground)]">credits / mnd</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">≈ 25 verzendklare prospects, 10 getrackte bedrijven, 5 meeting briefings</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["1 zetel", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktbriefing", "Meeting prep briefings", "Signal tracking: tot 10 bedrijven"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="start" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Aan de slag
          </a>
        </div>

        <!-- Growth (featured) -->
        <div class="rounded-2xl p-5 flex flex-col relative text-white" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-xl)">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-white text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap" style="background: var(--hooklyne-orange)">
            Meest gekozen
          </div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-3 mt-1">Growth</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-white price-display" data-monthly="159" data-annual="129">€129</span>
            <span class="text-sm text-white/40 ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-green-300">Bespaar €30/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-white/50 mb-4">1-2 reps. Volledige pipeline. Setup call inbegrepen.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: rgba(255,255,255,0.08)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-blue-300">400</span>
              <span class="text-xs text-white/40">credits / mnd</span>
            </div>
            <p class="text-[10.5px] text-white/55 leading-snug mt-1.5">≈ 90 verzendklare prospects, 30 getrackte bedrijven, 10 meeting briefings</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["2 zetels (max 2 extra zetels bij +€30/zetel/mo)", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktbriefing", "Meeting prep briefings", "Signal tracking: tot 40 bedrijven", "45-min setup + strategiegesprek", "Ideaal klantprofiel samen met jou geconfigureerd", "Maandelijkse check-in (eerste 3 maanden)"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-white/70">
                <svg class="size-3.5 shrink-0 mt-0.5 text-green-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-white/30 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="growth" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine bg-white/14 text-white border border-white/22 hover:bg-white/24">
            Aan de slag
          </a>
        </div>

        <!-- Scale -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Scale</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)] price-display" data-monthly="299" data-annual="239">€239</span>
            <span class="text-sm text-[var(--muted-foreground)] ml-1">/mnd</span>
          </div>
          <div class="h-5 mb-2">
            <span class="text-xs font-medium save-note text-[var(--hooklyne-teal)]">Bespaar €60/maand op jaarbasis</span>
          </div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Klein salesteam. Volume outbound. Tot 5 reps.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">800</span>
              <span class="text-xs text-[var(--muted-foreground)]">credits / mnd</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">≈ 190 verzendklare prospects, 60 getrackte bedrijven, 20 meeting briefings</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["5 zetels", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktbriefing", "Meeting prep briefings", "Signal tracking: tot 100 bedrijven", "Volledige setup + teamtraining", "Eigen Slack of WhatsApp", "Tweewekelijkse check-in calls", "Maandelijkse playbook-iteratie"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: €0,85/cr</p>
          <a href="/nl/contact" data-tier="scale" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Aan de slag
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-2xl p-5 flex flex-col relative" style="background: var(--card); box-shadow: var(--shadow-xs)">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3 mt-1">Enterprise</p>
          <div class="mb-1">
            <span class="text-3xl font-bold text-[var(--heading)]">Custom</span>
          </div>
          <div class="h-5 mb-2"></div>
          <p class="text-xs leading-relaxed text-[var(--muted-foreground)] mb-4">Salesafdelingen. Multi-market. Custom volumes.</p>
          <div class="rounded-xl px-3 py-2.5 mb-4" style="background: var(--background)">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-[var(--hooklyne-blue)]">Custom</span>
              <span class="text-xs text-[var(--muted-foreground)]">credit-volume</span>
            </div>
            <p class="text-[10.5px] text-[var(--muted-foreground)] leading-snug mt-1.5">Onderhandeld op basis van outbound-volume van je team</p>
          </div>
          <ul class="flex-1 space-y-2 mb-5">
            {["Unlimited zetels", "Bedrijven + contacten vinden", "Outreach in NL + EN", "Wekelijkse marktbriefing", "Meeting prep briefings", "Signal tracking: op maat", "Volledige setup + teamtraining", "Eigen account manager"].map((f) => (
              <li class="flex items-start gap-2 text-xs text-[var(--muted-foreground)]">
                <svg class="size-3.5 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="text-xs text-[var(--muted-foreground)]/60 mb-4">Top-up: Op maat</p>
          <a href="/nl/contact" data-tier="enterprise" data-location="pricing" class="block text-center rounded-lg text-sm font-semibold py-2.5 transition-all btn-shine ring-1 ring-[var(--hooklyne-navy)] text-[var(--heading)] hover:bg-[var(--hooklyne-navy)] hover:text-white">
            Praat met ons
          </a>
        </div>

      </div>

      <!-- Subnote under plan cards -->
      <p class="text-center text-xs text-[var(--muted-foreground)] leading-relaxed max-w-3xl mx-auto mb-4 -mt-6">
        Jaarplannen worden vooraf in rekening gebracht. Credits zijn 12 maanden geldig. Ongebruikte credits rollen 1 maand door (max saldo 2× je maandquota). Top-up €0,85/cr op alle plannen. Signal tracking-limiet is per workspace, niet per gebruiker. Growth extra zetels: +€30/zetel/mo, tot maximaal 4 zetels.
      </p>

      <!-- Why Growth is worth it callout -->
      <div class="rounded-xl px-5 py-4 mb-16 max-w-3xl mx-auto" style="background: rgba(52,76,163,0.06); border: 1px solid rgba(52,76,163,0.18)">
        <p class="text-sm font-semibold text-[var(--heading)] mb-1.5">Waarom Growth het waard is</p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          100 extra credits bij Start kosten €85 aan top-up. Growth geeft je 400 credits (4× meer dan Start), 2 zetels, 4× hogere signal tracking, en een echte setup call - voor €90 meer dan Start. Elke credit op Growth is goedkoper dan op Start, en de prijs per credit blijft dalen naarmate je opschaalt.
        </p>
      </div>

      <!-- ===========================================================
           HOE CREDITS WERKEN - lifecycle structure
           =========================================================== -->
      <div class="mb-16">
        <div class="max-w-3xl mb-10">
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-3">Hoe credits werken</h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Credits worden gebruikt wanneer je iets produceert - een prospect, een contact, een briefing. Bladeren, signalen lezen, intel bekijken en exporteren zijn altijd gratis. De flow hieronder volgt hoe prospects door je pipeline bewegen.
          </p>
        </div>

        <!-- ─── STAGE 1 ─── -->
        <div class="flex items-center gap-3.5 mb-5">
          <span class="flex items-center justify-center size-9 rounded-full text-base font-bold text-white shrink-0" style="background: var(--hooklyne-navy)">1</span>
          <div>
            <p class="text-[15px] font-semibold text-[var(--heading)] leading-tight">Krijg prospects in My Leads</p>
            <p class="text-[12.5px] text-[var(--muted-foreground)] leading-snug mt-0.5">Kies het pad dat past bij wat je al weet. Elk pad eindigt in een verzendklaar prospect-pakket in My Leads.</p>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-5">
          {[
            { n: "1", title: "Vind bedrijven voor me", featured: true, desc: "Beschrijf je ideaal klantprofiel. Hooklyne geeft tot 20 gerangschikte bedrijven met tot 3 gematchte rollen per bedrijf.", lines: [["Discovery (tot 20 bedrijven)", "1cr"], ["Prospect-pakket", "1cr"], ["Contact (e-mail + bedrijfstelefoon)", "2cr"]], total: "4cr", soon: false },
            { n: "2", title: "Ik ken het bedrijf", featured: false, desc: "Voer een bedrijfsnaam en domein in. We laten tot 3 gematchte rollen zien om uit te kiezen.", lines: [["Gematchte rollen bekijken", "Gratis"], ["Prospect-pakket", "1cr"], ["Contact (e-mail + bedrijfstelefoon)", "2cr"]], total: "3cr", soon: false },
            { n: "3", title: "Ik weet wie ik wil bereiken", featured: false, desc: "Je hebt een naam en LinkedIn-URL. Wij verifiëren het e-mailadres en schrijven outreach in jouw stijl.", lines: [["Prospect-pakket", "1cr"], ["Contact (e-mail + bedrijfstelefoon)", "2cr"]], total: "3cr", soon: false },
            { n: "4", title: "Vind soortgelijke bedrijven", featured: false, desc: "Upload je beste klanten. Hooklyne vindt bedrijven die op hen lijken - zelfde omvang, sector en signalen.", lines: [["ICP modellering", "TBA"], ["Prospect-pakket", "TBA"], ["Contact (e-mail + bedrijfstelefoon)", "TBA"]], total: "TBA", soon: true },
          ].map((c) => (
            <div class:list={["relative rounded-2xl p-5 flex flex-col", c.featured ? "border-2" : "border", c.soon && "border-dashed"]} style={c.featured ? "background: var(--card); border-color: var(--hooklyne-blue); box-shadow: var(--shadow-sm)" : c.soon ? "background: #f8fafc; border-color: var(--border-strong)" : "background: var(--card); border-color: var(--border); box-shadow: var(--shadow-xs)"}>
              {c.soon && <span class="absolute top-3 right-3 text-[9.5px] font-semibold uppercase tracking-[0.12em] text-[var(--muted-foreground)] px-2 py-0.5 rounded-full bg-white border border-[var(--border)]">Binnenkort</span>}
              <div class="flex items-center gap-2.5 mb-3">
                <span class:list={["flex items-center justify-center size-6 rounded-full text-[11px] font-bold text-white shrink-0"]} style={c.featured ? "background: var(--hooklyne-blue)" : c.soon ? "background: #cbd5e1" : "background: var(--muted-foreground)"}>
                  {c.n}
                </span>
                <span class="text-[13px] font-semibold text-[var(--heading)]">{c.title}</span>
              </div>
              <p class="text-[12px] text-[var(--muted-foreground)] leading-relaxed mb-4 min-h-[58px]">{c.desc}</p>
              <div class="border-t border-[var(--border)] pt-2.5 mt-auto space-y-1">
                {c.lines.map(([k, v]) => (
                  <div class="flex items-baseline justify-between text-[11.5px]">
                    <span class="text-[var(--muted-foreground)]">{k}</span>
                    <span class:list={[v === "Gratis" ? "text-[var(--hooklyne-teal)] italic" : v === "TBA" ? "text-[var(--muted-foreground)] italic" : "text-[var(--hooklyne-blue)] font-semibold"]}>{v}</span>
                  </div>
                ))}
                <div class="flex items-baseline justify-between pt-1.5 mt-1.5 border-t border-[var(--hooklyne-navy)]/15">
                  <span class="text-[11.5px] font-semibold text-[var(--heading)]">Per prospect</span>
                  <span class:list={["text-[14px] font-semibold", c.total === "TBA" ? "text-[var(--muted-foreground)]" : "text-[var(--hooklyne-navy)]"]}>{c.total}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="rounded-xl px-5 py-4 mb-4" style="background: rgba(13,148,136,0.08); border: 1px solid rgba(13,148,136,0.22)">
          <p class="text-sm font-semibold mb-1.5" style="color: #0F6E56">Hoe Route 1 in de praktijk werkt</p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Eén discovery (1cr) geeft tot 20 gerangschikte bedrijven. Jij kiest welke je omzet. Bouw de 5 beste matches: 1cr discovery + 5 × 3cr pakketten = <strong class="text-[var(--heading)]">16cr voor 5 verzendklare prospects</strong>. Bouw alle 20: 61cr. Sla een bedrijf over dat niet past: geen extra kosten. De discovery-credit verdient zichzelf terug zodra je een tweede bedrijf uit dezelfde lijst omzet.
          </p>
        </div>

        <!-- Direct nummer / mobiel binnenkort -->
