---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { PortalShot } from '@/components/portal-shot';
import { ResearchBrief } from '@/components/research-brief';
import { FindCompaniesFlow } from '@/components/product/find-companies-flow';
import { SignalHeatTable } from '@/components/product/signal-heat-table';
import { EmailCompose } from '@/components/product/email-compose';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';
import { ArrowRight } from 'lucide-react';

const stages = [
  {
    n: 1,
    key: "Discovery",
    title: "Beschrijf het. Wij vinden het.",
    body: "Vertel in gewone taal aan wie je verkoopt. Wij lezen miljarden pagina's. Wij halen de bedrijven naar boven die echt passen. Geen filter-raster. Een match op taalniveau.",
    facts: ["1,2 mld pagina's geïndexeerd", "Semantische match, geen SBI-codes", "Gewone-taal invoer"],
    shot: {
      label: "Discovery workspace",
      describe: "Portal: a plain-language description field, live results grid with fit scores and quick-add buttons.",
      crumb: "Prospecting / Discovery",
      status: "Reading 1.2B pages",
      statusTone: "blue" as const,
      overlays: [
        { x: 30, y: 28, tag: "DESCRIBE", title: "Dutch industrial OEMs moving to service models", tone: "blue" as const },
        { x: 72, y: 70, tag: "MATCHED", title: "42 real fits", body: "Not SIC code guesses", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 2,
    key: "Verificatie",
    title: "Het contact. Geverifieerd voor jij het ziet.",
    body: "We checken 20+ providers en vier deliverability-lagen per mail. Komt het er niet door, dan gaat het niet uit. Je domeinreputatie blijft schoon.",
    facts: ["20+ providers", "4 deliverability-lagen", "Tegengehouden als niet geverifieerd"],
    shot: {
      label: "Verification waterfall",
      describe: "Portal: contact card with live provider attempts and a final deliverability score.",
      crumb: "Prospect / Contact verification",
      status: "Verified",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 30, tag: "PROVIDER 3/20", title: "Verified match", tone: "teal" as const, pulse: true },
        { x: 72, y: 72, tag: "EMAIL", title: "Passed 4-layer check", body: "SMTP · Catch-all · Role · Deliverable", tone: "blue" as const },
      ],
    },
  },
  {
    n: 3,
    key: "Signalen",
    title: "Vang het moment dat ze klaar zijn.",
    body: "Funding. Hiring. Leiderschap. Launches. Pers. Expansie. Sectornieuws. We scoren elke beweging tegen jouw ICP en jouw product. Alleen de echte landen in je inbox.",
    sources: ["Funding", "Hiring", "Leiderschap", "Launches", "Pers", "Expansie", "Sectornieuws"],
    shot: {
      label: "Signals feed",
      describe: "Portal: live signal feed with twin scores and a prep-meeting action per row.",
      crumb: "Signals feed",
      status: "Live",
      statusTone: "orange" as const,
      overlays: [
        { x: 30, y: 26, tag: "FUNDING", title: "Series B - €12M", body: "9/10 fit for your ICP", tone: "orange" as const, pulse: true },
        { x: 72, y: 70, tag: "HIRING", title: "New VP Sales", body: "Product relevance 8/10", tone: "blue" as const },
      ],
    },
  },
  {
    n: 4,
    key: "Onderzoek",
    title: "Elk feit met bron. Geen verzinsels.",
    body: "Live webonderzoek. Geen stoffige trainingsdata. Elke claim te herleiden naar een echte URL die je aanklikt. Loop het gesprek in zonder één verzonnen detail.",
    facts: ["Live van het web", "Gemiddeld 12 bronnen", "Elke claim met bron"],
    shot: {
      label: "Research brief",
      describe: "Portal: a prospect brief with numbered citations linking to live sources.",
      crumb: "Prospect / Research brief",
      status: "Pulled 2m ago",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 28, tag: "SOURCED", title: "12 citations", tone: "blue" as const },
        { x: 72, y: 72, tag: "FRESH", title: "Pulled 2h ago", body: "Live web, not training data", tone: "teal" as const, pulse: true },
      ],
    },
  },
  {
    n: 5,
    key: "Schrijven",
    title: "Klinkt als je rep. Niet als een tool.",
    body: "Elk concept gaat vier keer door reasoning voor het bij jou belandt. Eerst de hook. Dan de invalshoek. Dan de stem. Dan een laatste kwaliteitscheck. Generiek stopt hier.",
    facts: ["4 reasoning-passes", "Stem uit je eerdere mails", "NL · EN auto"],
    shot: {
      label: "Draft with voice match",
      describe: "Portal: drafted email on the left, voice-match panel on the right showing cadence, openers, sign-off.",
      crumb: "Prospect / Draft",
      status: "Voice matched",
      statusTone: "blue" as const,
      overlays: [
        { x: 30, y: 28, tag: "VOICE", title: "Matched to your cadence", tone: "blue" as const },
        { x: 72, y: 70, tag: "PASSES", title: "4 reasoning passes", body: "Hook · Angle · Voice · QC", tone: "orange" as const, pulse: true },
      ],
    },
  },
  {
    n: 6,
    key: "Levering",
    title: "Eén scherm. Klaar om uit te sturen.",
    body: "Bedrijf, contact, signaal, hook, mail, LinkedIn. Allemaal op één kaart. Bekijken, bewerken, accepteren, versturen vanuit je eigen inbox. Onder de minuut per prospect.",
    facts: ["Versturen uit je inbox", "Je eigen domein", "NL · EN auto"],
    shot: {
      label: "Prospect card",
      describe: "Portal: single prospect card open with Company / Contact / Signal / Hook / Email / LinkedIn sections.",
      crumb: "Leads / Prospect 142",
      status: "Ready to send",
      statusTone: "teal" as const,
      overlays: [
        { x: 30, y: 28, tag: "REVIEW", title: "<60 seconds", tone: "teal" as const },
        { x: 72, y: 72, tag: "SEND", title: "Your inbox, your domain", tone: "blue" as const, pulse: true },
      ],
    },
  },
];
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Hoe het werkt", path: "/nl/hoe-het-werkt" },
]);
---

<DefaultLayout
  title="Hoe het werkt | Hooklyne"
  description="Hoe Hooklyne werkt: zes-staps werkstroom voor B2B leadgeneratie en koude acquisitie. Van discovery tot levering."
  image="/og/how-it-works.jpg"
  ctaVariant="how-it-works"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "Hoe Hooklyne een prospect-pakket bouwt",
    "description": "Zes fases van een ICP in plain language tot een verzendklaar prospect-pakket, in minder dan een minuut beoordeeld.",
    "inLanguage": "nl-NL",
    "totalTime": "PT1M",
    "step": stages.map((s) => ({
      "@type": "HowToStep",
      "position": s.n,
      "name": s.key,
      "text": s.body,
      "url": `https://www.hooklyne.com/nl/hoe-het-werkt#stage-${s.n}`,
    })),
  })} />
  <Background topStop="85%">
    <section class="pt-28 sm:pt-32 lg:pt-44 pb-10 sm:pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Hoe het werkt</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-4 sm:mb-5">
          Een werkstroom voor onderzoek. Geen chatbot.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-xl mx-auto leading-relaxed mb-6 sm:mb-8">
          Zes fases die samenwerken. Elke fase doet wat een goede researcher zou doen. Continu. Zodat je rep dat niet hoeft.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 mb-10 sm:mb-14 lg:mb-16">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start je gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="/nl/product"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk het product
            <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>

      <div id="hero-video" class="container max-w-6xl relative z-10">
        <div
          class="relative rounded-2xl px-4 py-4 lg:px-6 lg:py-5 overflow-hidden"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); box-shadow: var(--shadow-lg); border: 1px solid var(--border);"
        >
          <div class="hidden md:flex items-center gap-0">
            {stages.map((s, i) => (
              <>
                <a
                  href={`#stage-${s.n}`}
                  class="group flex-1 flex items-center gap-2.5 px-2 py-2 justify-center rounded-lg hover:bg-[var(--background)] transition-colors"
                >
                  <span class="inline-flex items-center justify-center size-7 shrink-0 rounded-full text-[11px] font-bold text-white transition-transform duration-200 group-hover:scale-110" style="background: var(--hooklyne-navy);">
                    {s.n}
                  </span>
                  <span class="text-[12px] md:text-[13px] font-semibold text-[var(--heading)] whitespace-nowrap tracking-tight group-hover:text-[var(--hooklyne-blue)] transition-colors">{s.key}</span>
                </a>
                {i < stages.length - 1 && (
                  <div class="shrink-0 flex items-center justify-center px-1">
                    <svg class="text-[var(--border-strong)]" width="16" height="10" viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M0 5 H13 M9 1 L13 5 L9 9"/></svg>
                  </div>
                )}
              </>
            ))}
          </div>

          <div class="md:hidden grid grid-cols-3 gap-1.5">
            {stages.map((s) => (
              <a
                href={`#stage-${s.n}`}
                class="group flex flex-col items-center justify-center gap-1 px-1.5 py-2.5 rounded-lg bg-[var(--background)] hover:bg-[var(--card-hover)] transition-colors min-w-0"
              >
                <span class="inline-flex items-center justify-center size-6 shrink-0 rounded-full text-[10px] font-bold text-white" style="background: var(--hooklyne-navy);">
                  {s.n}
                </span>
                <span class="text-[11px] font-semibold text-[var(--heading)] tracking-tight truncate max-w-full">{s.key}</span>
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>

  </Background>

  <Background variant="bottom">
    <section class="pt-10 sm:pt-12 lg:pt-16 pb-10 sm:pb-12 lg:pb-16">
      <div class="container max-w-6xl flex flex-col gap-14 sm:gap-20 lg:gap-28">
        {stages.map((s, i) => (
          <div id={`stage-${s.n}`} data-fade class:list={["scroll-mt-28 grid lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-14 items-center min-w-0", i % 2 === 1 && "lg:[&>*:first-child]:order-2"]}>
            <div class="min-w-0">
              <div class="inline-flex items-center flex-wrap gap-2 mb-4 sm:mb-5">
                <span class="inline-flex items-center justify-center size-8 sm:size-9 rounded-xl text-sm font-bold text-white" style="background: var(--hooklyne-navy);">
                  {s.n}
                </span>
                <span class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{s.key}</span>
                {s.n === 6 && (
                  <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold px-2 py-1 rounded-full" style="background: rgba(13,148,136,0.12); color: var(--hooklyne-teal);">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/></svg>
                    Binnen 60s
                  </span>
                )}
              </div>
              <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4 sm:mb-5 leading-[1.15] sm:leading-[1.1]">
                {s.title}
              </h2>
              <p class="text-base sm:text-lg text-[var(--muted-foreground)] leading-relaxed max-w-lg">
                {s.body}
              </p>

              {s.facts && (
                <div class="mt-5 flex flex-wrap gap-1.5">
                  {s.facts.map((f) => (
                    <span class="text-[11px] font-semibold px-2.5 py-1 rounded-md tracking-tight" style="background: var(--card); border: 1px solid var(--border); color: var(--heading);">
                      {f}
                    </span>
                  ))}
                </div>
              )}

              {s.sources && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {s.sources.map((src) => (
                    <span class="text-xs font-medium px-3 py-1.5 rounded-full" style="background: var(--card); border: 1px solid var(--border); color: var(--heading);">
                      {src}
                    </span>
                  ))}
                </div>
              )}

              {s.n === 4 && (
                <div class="mt-6 rounded-2xl p-5" style="background: var(--card); border: 1px solid var(--border);">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--hooklyne-teal)] mb-2">Na het antwoord</p>
                  <p class="text-sm font-semibold text-[var(--heading)] mb-1.5">Meeting Prep, op aanvraag.</p>
                  <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
                    Komt het antwoord binnen, vraag een brief aan. Vijf minuten later loop je naar binnen. Met wat ze net hebben opgehaald. Wat hun contact vorig kwartaal publiek zei. En drie openers die bij dit gesprek passen.
                  </p>
                  <div class="flex flex-wrap gap-1.5">
                    {["Koud", "Warm", "Inbound", "Follow-up", "Beurs", "Na de beurs", "Pitch"].map((t) => (
                      <span class="text-[10px] font-medium px-2 py-1 rounded-full" style="background: var(--background); border: 1px solid var(--border); color: var(--heading);">{t}</span>
                    ))}
                  </div>
                </div>
              )}

              {s.n === 6 && (
                <div class="mt-6">
                  <a href="/nl/product" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--hooklyne-blue)] hover:opacity-80 transition-opacity group">
                    Zie de schermen in het portaal
                    <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
                  </a>
                </div>
              )}
            </div>

            <div class="min-w-0">
              {s.n === 1 && <FindCompaniesFlow client:visible ratio="4/3" tabletRatio="16/9" mobileRatio="3/4" />}
              {s.n === 2 && <VerificationWaterfall client:visible ratio="5/4" tabletRatio="16/9" mobileRatio="1/1" />}
              {s.n === 3 && <SignalHeatTable client:visible ratio="4/3" tabletRatio="16/9" mobileRatio="3/4" />}
              {s.n === 4 && <ResearchBrief />}
              {s.n === 5 && <EmailCompose client:visible ratio="4/3" tabletRatio="16/9" mobileRatio="3/4" />}
              {s.n === 6 && (
                <PortalShot
                  label={s.shot.label}
                  src="/how-it-works/prospect-card.jpg"
                  fit="contain"
                  ratio="3/2"
                  crumb={s.shot.crumb}
                  status={s.shot.status}
                  statusTone={s.shot.statusTone}
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="pt-4 pb-12 sm:pt-6 sm:pb-16 lg:pt-8 lg:pb-24" data-fade>
      <div class="container max-w-4xl">
        <div
          class="relative rounded-3xl p-6 sm:p-8 md:p-12 overflow-hidden text-center"
          style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);"
        >
          <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
            Dit is de werkstroom. Zie 'm in het product.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-7 max-w-2xl mx-auto">
            Zes fases achter één prospect-kaart. Onder de minuut beoordeeld. Verzonden vanuit je eigen inbox.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href="/nl/contact"
              class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
            >
              Start je gratis pilot
              <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
            <a
              href="/nl/product"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
            >
              Zie de schermen
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </Background>
</DefaultLayout>

