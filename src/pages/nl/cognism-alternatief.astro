---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HeadToHead } from '@/components/blocks/head-to-head';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Cognism-alternatief", path: "/nl/cognism-alternatief" },
]);

const pains = [
  "Je jaaroffer kwam boven de €15k uit, terwijl het team uit twaalf mensen bestaat.",
  "Inkoop vraagt waarom een sales-tool een wederzijdse NDA en een contract-redline nodig heeft.",
  "De data is goed, maar je wilt ook de mail geschreven hebben - en Cognism doet dat niet.",
  "Je wilde binnen een week starten, niet na onboarding plus training plus integratie.",
];

const breakdowns = [
  {
    title: "Abonnementsprijs voor MKB, geen enterprise-contract.",
    body: "Cognism is gebouwd rond een platform fee en een jaarcontract. Voor sales-organisaties boven de 50 FTE klopt die rekensom. Voor een team van twaalf dat outbound draait naast het bouwen van product, is €15k betalen voor de eerste mail de uitgaat de verkeerde commitment-vorm. Hooklyne is €39 tot €239 per maand, op een abonnement dat je elke maand kunt opzeggen.",
  },
  {
    title: "Outreach opgesteld, niet alleen data geleverd.",
    body: "Cognism stopt bij de rij in de database. Daarna schrijft jouw team de mail, scoort het signaal en zet het in een sequencer. Een aparte werkstroom op een aparte tool. Hooklyne levert het prospectpakket compleet - geverifieerd contact, gescoord koopsignaal en een opgesteld bericht in de stem van je salesmedewerker - zodat het werk tussen data en inbox niet meer van jou is.",
  },
  {
    title: "AVG-vriendelijk zonder de enterprise-wikkel.",
    body: "Cognism staat sterk op AVG voor juridische teams die een DPA, audit-trails en expliciete data-lineage nodig hebben. Heeft jouw motion dat papierwerk nodig, dan hebben zij het. Heb je vooral het vertrouwen nodig dat je outreach niet ontploft onder de AVG en geen procurement-grade compliance-pakket, dan brengt Hooklynes Europees gebouwde, scraping-vrije, citeerbare-bronnen-aanpak je daar tegen een fractie van de prijs.",
  },
];

const faq = [
  {
    q: "Wat als Hooklyne niet werkt voor ons team?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects volledig opgebouwd, zonder kaart en zonder verplichting. Levert de output geen replies op die je anders niet had gekregen, dan stop je. Liever eerlijke feedback dan een klant die geen fit is.",
  },
  {
    q: "Cognism gaf ons een mobiel nummer voor bijna elk contact. Evenaart Hooklyne dat?",
    a: "Nee - en daar zijn we eerlijk over. De Diamond Verified mobile-dataset van Cognism is echt sterk. Mail plus LinkedIn-URL is de hoofdroute van Hooklyne. Bij een phone-outbound motion wint Cognism die vergelijking. Bij een mail-gedreven motion betaal je voor mobile-data die je niet gebruikt.",
  },
  {
    q: "Cognisms data voelt dieper dan Apollo. Is Hooklyne werkelijk anders in die vergelijking?",
    a: "Cognism is op EU-MKB-datakwaliteit duidelijk beter dan Apollo - dat klopt. Hooklyne gebruikt vergelijkbare bronmixen via een waterval over 21 providers en voegt daarboven de lagen toe die Cognism niet levert: signaalscoring, opgestelde berichten en verificatie per provider. Eerlijke framing: Cognism is data-gedreven, Hooklyne is workflow-gedreven.",
  },
  {
    q: "We zitten nog zes maanden vast aan ons Cognism-contract. Heeft het zin om nu te praten?",
    a: "Ja. Draai de pilot tijdens je bestaande contract op een andere sender om like-for-like te vergelijken, en beslis over verlenging op basis van echte data in plaats van een sales-call. De pilot is sowieso gratis en tien prospects staan binnen de eerste week in je inbox.",
  },
  {
    q: "En de AVG-kant? Cognism maakt daar veel werk van.",
    a: "Hun compliance-pakket is uitstekend voor juridische teams die het nodig hebben. Hooklyne is in Nederland gebouwd, elke claim is voorzien van een citeerbare bron, en wij scrapen niet. De meeste MKB-salesteams hebben geen DPA op briefpapier nodig - ze willen er zeker van zijn dat hun outreach niet ontploft. Daar brengen we je.",
  },
];
---

<DefaultLayout
  title="Cognism-alternatief voor het Nederlandse MKB | Hooklyne"
  description="Hooklyne is het MKB-geprijsde Cognism-alternatief. Abonnementsprijs in plaats van enterprise-contracten, met signaallaag en opgestelde berichten ingebouwd. Europees gebouwde onderzoeksworkflow voor teams van 10 tot 100 FTE."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Cognism-alternatief voor het Nederlandse MKB",
    "description": "Hooklyne is het abonnement-geprijsde Cognism-alternatief voor Nederlandse en Britse B2B-MKB-teams.",
    "url": "https://www.hooklyne.com/nl/cognism-alternatief",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Cognism-alternatief</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Het Cognism-alternatief voor MKB-teams zonder inkoopafdeling.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Hooklyne is een onderzoeksgedreven prospectworkflow, gebouwd voor het Europese B2B-MKB. Elke prospect arriveert als een pakket - een geverifieerd contact, een gescoord koopsignaal en een opgesteld bericht in de stem van je salesmedewerker - klaar om binnen een minuut te beoordelen en versturen. Cognism is data-gedreven en contract-gebonden. Hooklyne is workflow-gedreven, op een maandabonnement.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/nl/contact" class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine">
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a href="#vergelijk" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group">
            Bekijk de vergelijking
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je kwam hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Klopt iets daarvan, dan is de rest van deze pagina voor jou.</p>
          </div>

          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, zonder kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het op tien van je eigen prospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig onderzochte prospectpakketten. Zonder betaling, zonder contract. Wij vragen twintig minuten eerlijke feedback achteraf - meer niet.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan
              <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Waar Cognism niet voor MKB is gevormd</p>
          <h2 class="text-2xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Drie dingen waar Cognism het MKB buiten de prijsvloer zet.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Cognism is een sterk product voor de koper waar het voor is gebouwd: enterprise sales-organisaties met inkoop, compliance-teams en een phone-led outbound motion. Onder de 50 FTE in NL, BE en UK breekt de contractvorm en de ontbrekende drafted-message-laag de rekensom.
          </p>
        </div>

        <div class="space-y-8">
          {breakdowns.map((b, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{b.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{b.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div id="vergelijk">
      <HeadToHead competitor="cognism" lang="nl" />
    </div>
  </Background>

  <Background variant="bottom">
    <HomePricing lang="nl" client:visible />

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">Veelgestelde vragen</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">Vragen over de overstap vanaf Cognism.</h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
