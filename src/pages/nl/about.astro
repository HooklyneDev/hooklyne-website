---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight, MessagesSquare, Target, PenLine, Calendar, Mail, Compass } from 'lucide-react';

const values = [
  {
    icon: MessagesSquare,
    title: "Verkopen blijft mensenwerk.",
    body: "Een koopbeslissing eindigt nog steeds bij iemand die de telefoon oppakt. Software hoort jou ruimte te geven voor dat gesprek, niet net doen alsof het 'm zelf voert. De relatie is van je rep, niet van de tool.",
  },
  {
    icon: Target,
    title: "Kwaliteit boven volume.",
    body: "Vijftig echte hooks zijn meer waard dan vijfhonderd zwakke. Liever tien prospects waar je trots op bent dan honderd waar je je voor schaamt.",
  },
  {
    icon: PenLine,
    title: "Outreach waar je je naam onder zet.",
    body: "Generieke mails verbranden je sender reputation in een week. Vier reasoning-passes, een kwaliteitscheck, en is het niet klaar, dan gaat het niet uit. Ook al levert dat minder volume op.",
  },
];

const pillars = [
  {
    icon: Calendar,
    title: "De founder onboardt je zelf.",
    body: "Je eerste ICP-setup loopt via Tim, niet via een junior. Dertig minuten op een call. We leren wat je verkoopt, aan wie, en hoe je rep daar normaal over praat.",
  },
  {
    icon: Mail,
    title: "Direct contact met het team.",
    body: "Eén Slack-kanaal of mailthread per klant. Antwoord binnen vier uur op werkdagen. Geen ticketqueue, geen script, geen chatbot die je doorverwijst.",
  },
  {
    icon: Compass,
    title: "Jouw sector vormt de defaults.",
    body: "De eerste tien prospects in je pilot kalibreren het systeem op jouw markt. We blijven bijstellen tot de output leest alsof je rep het zelf schreef na een uur onderzoek.",
  },
];

const replaced = [
  "Apollo / Cognism / Lusha",
  "Clay of Findymail",
  "ChatGPT of Claude",
  "Een spreadsheet met signalen",
  "Een tweede sequencer voor warm-up",
  "Het uur dat je per mail kwijt was",
];

import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Over ons", path: "/nl/about" },
]);
---

<DefaultLayout
  title="Over Hooklyne | Klein Nederlands team, hands-on bij elke pilot"
  description="Een klein Nederlands team dat B2B prospect-onderzoek voor het MKB bouwt. Tien jaar zelf gedaan, opgebouwd uit elke limiet die we tegenkwamen. De founder runt elke pilot."
  image="/og/about.jpg"
  ctaVariant="about"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "inLanguage": "nl-NL",
    "name": "Over Hooklyne",
    "url": "https://www.hooklyne.com/nl/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "Hooklyne",
      "url": "https://www.hooklyne.com",
      "foundingLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressCountry": "NL" } },
      "areaServed": ["NL", "BE", "GB", "LU"],
      "founder": { "@type": "Person", "name": "Tim Wissink", "jobTitle": "Founder", "worksFor": { "@type": "Organization", "name": "Hooklyne" } },
      "identifier": { "@type": "PropertyValue", "propertyID": "KVK", "value": "99990512" }
    }
  })} />
  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Over ons</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Een klein team dat het onderzoek zelf doet.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Tot we groeien, krijg je ons. De mensen die de werkstroom hebben gebouwd, runnen je pilot, zetten je ICP op, en pakken op als er iets stuk is.
        </p>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-[3fr_2fr] gap-10 lg:gap-16 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Waarom we dit bouwden</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-8 leading-tight">
              Tien jaar zelf gedaan. Gebouwd uit elke limiet die we raakten.
            </h2>
            <div class="space-y-5 text-base text-[var(--muted-foreground)] leading-relaxed">
              <p>
                Hooklyne is niet in een vacuüm bedacht. Eerst kwamen tien-plus jaar outbound bij internationale B2B-bedrijven. Verkopen, verkocht worden, SDRs aannemen, agencies opzeggen, en elke tool proberen die de markt erop gooide.
              </p>
              <p>
                Het meeste van die jaren ging op aan informatie tussen abonnementen schuiven: één tool voor bedrijfsdata, één voor contacten, één voor signalen, een CRM die met geen enkele praatte. De werkstroom leefde in zeven tabbladen. Elke week uren met rijen schuiven om één prospect te briefen.
              </p>
              <p>
                We hielden een lijst bij van elke limiet. Bouncerates op single-source databases. AI-agents die koopsignalen verzonnen. Templates die als templates leesbaar waren. Agency-offertes hoger dan het quotum dat ze beloofden. ChatGPT-concepten die twee herschrijfrondes nodig hadden om als ons te klinken.
              </p>
              <p>
                Hooklyne is wat je krijgt als je stopt met om die limieten heen werken en in plaats daarvan een complete tool bouwt voor de sales rep - degene die op maandagochtend de inbox moet openen, niet de buyer die het SaaS-contract tekent.
              </p>
              <p class="text-[var(--heading)] font-medium text-lg">
                Eén plek. Eén prospect. Alle context die een researcher je zou geven. In minder dan een minuut bekeken.
              </p>
            </div>
          </div>

          <div class="lg:pt-12">
            <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--hooklyne-orange)] mb-4">Wat we vervangen</p>
              <ul class="space-y-2.5">
                {replaced.map((r) => (
                  <li class="flex items-center gap-2.5 text-sm text-[var(--muted-foreground)]">
                    <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-orange);"><path d="M18 6 6 18M6 6l12 12"/></svg>
                    <span class="line-through">{r}</span>
                  </li>
                ))}
              </ul>
              <div class="my-5 h-px" style="background: var(--border);"></div>
              <div class="flex items-center gap-2.5 text-sm font-semibold text-[var(--heading)]">
                <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-teal);"><path d="M20 6 9 17l-5-5"/></svg>
                <span>Eén Hooklyne-portaal</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10 lg:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Hoe we met je samenwerken</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Klein zijn betekent dat jij direct contact krijgt.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Drie pilots verder. We zijn nog geen SaaS-supportwachtrij en doen ook niet alsof. De founder zet je systeem op, het team beantwoordt je berichten, en de output wordt gevormd door jou - niet door een gemiddelde klant die niet bestaat.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-4 md:gap-5">
          {pillars.map((p) => {
            const Icon = p.icon;
            return (
              <div class="rounded-2xl p-6 md:p-7 flex flex-col" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs);">
                <span class="inline-flex items-center justify-center size-10 rounded-xl mb-4" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <Icon className="size-5" />
                </span>
                <h3 class="text-lg font-semibold text-[var(--heading)] tracking-tight mb-2 leading-snug">{p.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{p.body}</p>
              </div>
            );
          })}
        </div>

        <div class="mt-8 rounded-2xl p-5 md:p-6 flex items-center gap-4 md:gap-5" style="background: var(--hooklyne-navy); color: white;">
          <picture class="shrink-0">
            <source srcset="/about/tim-wissink.webp" type="image/webp" />
            <img
              src="/about/tim-wissink.jpg"
              alt="Tim Wissink, founder van Hooklyne"
              loading="lazy"
              decoding="async"
              width="80"
              height="80"
              class="size-14 md:size-16 rounded-full object-cover"
              style="border: 2px solid rgba(255,255,255,0.18);"
            />
          </picture>
          <div class="min-w-0">
            <p class="text-sm md:text-base font-medium leading-snug mb-1">
              "Elke pilot loopt nog steeds via mij. Dat blijft zo tot we hires doen, en waarschijnlijk nog een tijd daarna."
            </p>
            <p class="text-xs text-white/65">Tim Wissink &middot; Founder, Hooklyne</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Founder</p>
            <figure class="relative rounded-2xl overflow-hidden aspect-[4/5]" style="background: var(--hooklyne-navy); box-shadow: var(--shadow-lg);">
              <picture>
                <source srcset="/about/tim-wissink.webp" type="image/webp" />
                <img src="/about/tim-wissink.jpg" alt="Tim, founder van Hooklyne" loading="lazy" decoding="async" width="800" height="529" class="absolute inset-0 w-full h-full object-cover" />
              </picture>
              <div class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, rgba(2,47,81,0.0) 20%, rgba(2,47,81,0.85) 85%, rgba(2,47,81,0.95) 100%);"></div>
              <figcaption class="absolute left-6 right-6 bottom-6 text-white">
                <div class="text-2xl font-semibold tracking-tight leading-none">Tim Wissink</div>
                <div class="text-sm text-white/75 mt-2">Founder, Hooklyne</div>
              </figcaption>
            </figure>
          </div>

          <div class="lg:col-span-8 lg:pt-12">
            <p class="text-3xl md:text-4xl lg:text-[2.75rem] text-[var(--heading)] leading-[1.25] tracking-tight font-medium">
              "Verkopen blijft mensenwerk. Software hoort je ruimte te geven voor het gesprek. Niet om het over te nemen."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-px flex-1 bg-[var(--border)]"></div>
              <div class="text-xs uppercase tracking-[0.25em] text-[var(--muted-foreground)]">Tim, founder</div>
            </div>
            <div class="mt-8 grid grid-cols-3 gap-6 text-sm">
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Achtergrond</div>
                <div class="text-[var(--heading)] font-medium">10+ jaar internationale B2B-sales</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">Live sinds</div>
                <div class="text-[var(--heading)] font-medium">februari 2026</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-1">In pilot met</div>
                <div class="text-[var(--heading)] font-medium">3 Nederlandse teams</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Waar we om geven</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-10 leading-[1.1] max-w-2xl">
          Drie regels die we opschrijven en aanhouden.
        </h2>
        <div class="grid md:grid-cols-3 gap-4 md:gap-5">
          {values.map((v, i) => {
            const Icon = v.icon;
            return (
              <div class="rounded-2xl p-6 md:p-7 flex flex-col h-full" style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-xs);">
                <div class="flex items-center gap-3 mb-4">
                  <span class="font-mono text-xs text-[var(--muted-foreground)]">0{i + 1}</span>
                  <span class="h-3 w-px bg-[var(--border)]"></span>
                  <span class="inline-flex items-center justify-center size-7 rounded-lg" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal);">
                    <Icon className="size-4" />
                  </span>
                </div>
                <h3 class="text-lg md:text-xl font-semibold text-[var(--heading)] mb-2 leading-snug tracking-tight">{v.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{v.body}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-3xl mb-10 lg:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Bedrijf</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            De saaie details. Op de pagina, niet weggestopt.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Wie we zijn, waar we zitten, en wat we niet met je data doen.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 md:gap-5">
          <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-5">
              <span class="size-1.5 rounded-full" style="background: var(--hooklyne-blue);"></span>
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--hooklyne-blue)]">Geregistreerd</p>
            </div>
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 text-sm">
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Naam</dt>
              <dd class="text-[var(--heading)] font-medium">Hooklyne</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">KVK</dt>
              <dd class="text-[var(--heading)] font-medium font-mono tabular-nums">99990512</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Land</dt>
              <dd class="text-[var(--heading)] font-medium">Nederland</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Live sinds</dt>
              <dd class="text-[var(--heading)] font-medium">februari 2026</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Founder</dt>
              <dd class="text-[var(--heading)] font-medium">Tim Wissink</dd>
              <dt class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] pt-1">Pilot</dt>
              <dd class="text-[var(--heading)] font-medium">3 Nederlandse teams</dd>
            </dl>
          </div>

          <div class="rounded-2xl p-6 md:p-7" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-5">
              <span class="size-1.5 rounded-full" style="background: var(--hooklyne-teal);"></span>
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em]" style="color: var(--hooklyne-teal);">Houding</p>
            </div>
            <ul class="space-y-3.5 text-sm leading-relaxed">
              {[
                { t: "EU-gevestigd, AVG-proof.", b: "Data blijft in de EU. We verwerken wat nodig is voor outreach-onderzoek, niets meer." },
                { t: "We verkopen of delen geen contactdata.", b: "Wat geverifieerd is voor je account, blijft in je account. Geen data-brokerage. Nooit." },
                { t: "Je inbox, je domein.", b: "We runnen geen sequences voor je. Versturen gebeurt vanuit je mailbox, zodat de relatie bij jou blijft." },
                { t: "Niets gaat ongeverifieerd uit.", b: "Komt een contact niet door alle vier de deliverability-lagen, dan houden we het tegen. Je sender reputation telt zwaarder dan het volume." },
              ].map((p) => (
                <li class="flex items-start gap-3">
                  <svg class="size-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-teal);"><path d="M20 6 9 17l-5-5"/></svg>
                  <div>
                    <p class="font-semibold text-[var(--heading)]">{p.t}</p>
                    <p class="text-[var(--muted-foreground)] mt-0.5">{p.b}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 lg:py-20" data-fade>
      <div class="container max-w-4xl">
        <div class="relative rounded-3xl p-8 md:p-12 overflow-hidden text-center" style="background: linear-gradient(180deg, var(--card) 0%, var(--card-hover) 100%); border: 1px solid var(--border); box-shadow: var(--shadow-md);">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Voor wie</p>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-4 leading-tight">
            Nederlands en Brits MKB eerst. EN door heel EMEA.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-7 max-w-2xl mx-auto">
            We beginnen dichtbij huis omdat we beide talen native spreken en de kopers kennen. Engelstalige teams elders in EMEA zijn welkom. AVG-proof.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="/nl/contact" class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine">
              Start je gratis pilot
              <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
            <a href="/nl/how-it-works" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group">
              Bekijk hoe het werkt
              <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

  </Background>
</DefaultLayout>
