---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Agritech en voedseltechnologie prospecting", path: "/nl/agritech-prospecting" },
]);

const pains = [
  "De bedrijfsleider of coöperatiedirecteur die je nodig hebt gebruikt LinkedIn niet als zakelijk instrument.",
  "Subsidiecycli en regelgevingstijdlijnen zijn je beste koopsignalen - en je houdt ze niet bij.",
  "Je bereikt telers, maar de aankoopbeslissing ligt op coöperatie- of agri-dealerniveau.",
  "Het seizoen doet ertoe. Een campagne die oogst-timing negeert bereikt kopers op het slechtste moment.",
];

const signals = [
  {
    title: "EU-landbouwsubsidiecycli en GLB-hervormingsimplementatie.",
    body: "Het Gemeenschappelijk Landbouwbeleid bepaalt investeringstijdlijnen in de Europese landbouw. Eco-regelingbetalingen, agromilieu-klimaatmaatregelen en LEADER-programmabeurzen creëren gedefinieerde vensters waarbij boeren en coöperaties vers kapitaal hebben met bijgevoegde voorwaarden. De GLB-strategische plannen 2023-2027 hebben specifieke nationale implementatietijdlijnen die openbaar zijn. Een boer die zojuist een eco-regelingbetaling heeft verkregen die precisielandbouwtools vereist, vergelijkt niet - die koopt. De timing staat in de nationale programmadocumenten, niet op LinkedIn.",
  },
  {
    title: "Kapitaalinvesteringsrondes van coöperaties en voedselverwerkers.",
    body: "Landbouwcoöperaties en voedselverwerkers opereren op meerjarige investeringscycli gekoppeld aan ledenaudits, verwerkingscapaciteitsbeoordelingen en duurzaamheidsverplichtingen. Kapitaalinvesteringsaankondigingen - nieuwe verwerkingslijnen, opslagfaciliteiten, digitale traceerbaarheidssystemen - staan in jaarverslagen, vakbladen en bedrijfsfilings. Een coöperatie die zojuist heeft toegezegd aan precisieirrigatie of voedselveiligheidscertificering, koopt actief de technologie en diensten om de toezegging waar te maken.",
  },
  {
    title: "Duurzaamheidscertificering en traceerbaarheidsvereisten.",
    body: "GlobalG.A.P., Rainforest Alliance, GlobalG.A.P. Chain of Custody en retailer-specifieke duurzaamheidsstandaarden creëren verplichte inkoopleadlijnen. Een producent die zojuist heeft toegezegd aan een nieuwe retailerstandaard koopt de monitoring-, rapportage- en certificeringsinfrastructuur om er aan te voldoen. EU-wetgeving inzake toeleveringsketens - de EUDR (EU-ontbossingregeling) en de richtlijn inzake duurzaamheidszorgplicht - creëert aanvullende compliance-gedreven inkoop in de voedselketen.",
  },
  {
    title: "Landbouwconsolidatie en coöperatiefusiering.",
    body: "Landbouwconsolidatie - boerderijfusies, coöperatiesamenvoegingen, agri-dealeracquisities - creëert inkoopbeoordelingen op het niveau van de gecombineerde entiteit. Een coöperatie die zojuist is gefuseerd met een naburige beoordeelt of zijn operationele technologie schaalbaar is over de nieuwe omvang. Een boerderij die is uitgebreid via landverwerving koopt inputs en diensten op een schaal die de vorige leveranciersrelaties niet dekt. KVK-wijzigingen en bestuursbeslissingen van coöperaties zijn de vroegste signalen van deze activiteit.",
  },
];

const faq = [
  {
    q: "Boeren en coöperaties zijn conservatieve kopers. Is outreach-gedreven prospecting effectief?",
    a: "Conservatieve kopers betekent niet gesloten kopers - het betekent kopers die reageren op relevantie en vertrouwenssignalen in plaats van volume. Een bericht dat een GLB-subsidie verwijst die ze net hebben ontvangen, een specifiek operationeel probleem benoemt dat het creëert en van een bedrijf komt dat aantoonbaar hun regelgevingscontext begrijpt, wordt gelezen. Een generieke campagne niet.",
  },
  {
    q: "Besluitvorming in de landbouw is complex. Boer, coöperatie, agri-dealer - wie target ik?",
    a: "Dat hangt af van wat je verkoopt en op welke schaal. Individuele boerderijtech gaat direct naar de bedrijfsleider of eigenaar. Coöperatieniveau-systemen gaan naar de operationeel of IT-directeur van de coöperatie. Inputinkoop loopt vaak via agri-dealers. Hooklyne bepaalt het juiste niveau voor jouw aanbod in plaats van een lijst te geven en de beslissing aan jou over te laten.",
  },
  {
    q: "Heeft Hooklyne dekking van de Nederlandse landbouw specifiek? Het is een dichte en gespecialiseerde sector.",
    a: "Ja. Nederlandse landbouw en tuinbouw zijn goed gedekt in KVK-registraties, sectorspecifieke databases en coöperatiebestuursfilings. Wageningen University-onderzoeksnetwerken, LTO Nederland-ledengegevens en gespecialiseerde vakpers voegen dekking toe. Nederlands agri is een van de beter gedocumenteerde landbouwsectoren in Europa vanuit een dataperspectief.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons agritech-ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte doellijst, volledig opgebouwd, zonder kaart. Agritech is een segment waar de seizoens- en regelgevingstimingaanpak ofwel meteen resoneert of niet - de pilot vertelt je dat snel.",
  },
];
---

<DefaultLayout
  title="Prospecting bij agritech en voedseltechnologie | Hooklyne"
  description="Hoe je buyers in landbouw en voedseltechnologie bereikt: subsidiecycli, coöperatieve inkoop-signalen, duurzaamheidscertificeringstijdlijnen en hoe je outreach rond de landbouwkalender timt."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Agritech en voedseltechnologie prospecting-gids",
    "description": "Hoe je agritech- en voedseltechnologiebedrijven prospecteert: signalen, contacten en koopvensters.",
    "url": "https://www.hooklyne.com/nl/agritech-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Agritech en voedseltechnologie prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Landbouwkopers hebben seizoenen. Koude outreach negeert ze meestal.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Subsidiecycli, certificeringsvereisten en coöperatieve investeringsrondes creëren voorspelbare koopvensters in landbouw en voedseltechnologie. De kopers die ertoe doen - bedrijfsdirecteuren, coöperatieve operationele leads, inkoopteams van voedselverwerkers - zijn bereikbaar wanneer die vensters opengaan. Deze gids behandelt hoe je het signaal vindt en wanneer je er op handelt.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte agritech-prospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw agritech-ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe agritech- en voedselbedrijven kopen</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een landbouwkoopvenster openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Landbouwinkoop volgt subsidiecycli, certificeringsvereisten en operationele events - niet sociale media. De signalen staan in programmadocumenten en coöperatieve filings, niet op LinkedIn.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Waar Hooklyne past</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Gebouwd voor sectoren waar timing het hele spel is.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Landbouwkopers zijn niet ontoegankelijk - ze zijn ontoegankelijk op het verkeerde moment. Een bedrijfsdirecteur in de oogstplanningmodus evalueert geen nieuwe software. Dezelfde directeur in januari, na de oogst, die GLB-subsidie-opties en het kapitaalplan voor volgend jaar beoordeelt, is heel anders. Hooklyne volgt de signalen die aangeven welk venster van toepassing is op welk bedrijf, in plaats van de hele sector als één ongedifferentieerde lijst te behandelen.</p>
          <p>Coöperatie- en voedselverwerkercontacten zijn niet goed gedekt in op LinkedIn gebaseerde tools. Hooklyne watervalt over 21 providers - waaronder landbouwcoöperatieregisters, voedselsectorspecifieke databases en geverifieerde Europese bronnen - om contacten op het juiste organisatieniveau te vinden. Individuele boerderijtech gaat naar de eigenaar. Coöperatiesystemen gaan naar de operationeel directeur. Inputinkoop loopt via andere kanalen.</p>
          <p>De eerste mail verwijst naar het specifieke signaal dat dit bedrijf nu relevant maakt - een subsidieprogramma waarvoor ze waarschijnlijk hebben aangevraagd, een certificeringsstandaard die hun grootste klant zojuist heeft aangekondigd, een coöperatieve investeringsronde in hun sector. Die specificiteit is wat een lezing verdient in een sector waar kopers veel generieke outreach ontvangen en die agressief filteren.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Gerelateerde gidsen</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/nl/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Alle branchegidsen</a>
          <a href="/nl/food-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Voeding en dranken</a>
          <a href="/nl/industrie-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrie en productie</a>
          <a href="/nl/avg-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">AVG-compliant prospecting</a>
          <a href="/nl/vergelijken" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool-vergelijkingen</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over agritech prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
