---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { ArrowRight, Clock } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";
import { livByCategory, comingSoonByCategory } from "@/data/guides";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Guides", path: "/nl/guides" },
  { name: "Branches", path: "/nl/industries" },
]);

const live       = livByCategory("vertical");
const comingSoon = comingSoonByCategory("vertical");
---

<DefaultLayout
  title="Branchespecifieke B2B-prospectinggidsen | Hooklyne"
  description="Prospectinggidsen afgestemd op hoe specifieke sectoren inkopen. SaaS, logistiek, bureaus, fintech, industrie — elk met een eigen aankoopproces, typische titels en relevante signalen."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Branchespecifieke B2B-prospectinggidsen",
    "description": "Sectorspecifieke prospectinggidsen voor Europese MKB-bedrijven. SaaS, logistiek, bureaus, fintech, industrie.",
    "url": "https://www.hooklyne.com/nl/industries",
    "inLanguage": "nl"
  })} />

  <Background>
    <section class="pt-24 sm:pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">
          <a href="/nl/guides" class="hover:underline">Guides</a> / Branches
        </p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Gebouwd voor jouw sector.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed">
          Elke sector heeft zijn eigen aankoopproces, beslisserstypes en signalen die echt iets zeggen over intentie. Deze gidsen laten zien hoe je per sector prospecting aanpakt zonder credits te verspillen aan de verkeerde mensen.
        </p>
      </div>
    </section>

    <section class="pb-24 lg:pb-32">
      <div class="container max-w-5xl space-y-16">
        {live.length > 0 && (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {live.map((item) => (
              <a
                href={item.nl.slug}
                class="group block rounded-2xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
                style="background: var(--card); border: 1px solid var(--border);"
              >
                <span class="inline-block text-[10px] font-semibold uppercase tracking-widest text-[var(--hooklyne-teal)] mb-3">Branche</span>
                <h3 class="text-base font-semibold text-[var(--heading)] mb-2 group-hover:text-[var(--hooklyne-blue)] transition-colors">{item.nl.label}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">{item.nl.description}</p>
                <span class="inline-flex items-center gap-1 text-sm font-medium text-[var(--hooklyne-blue)]">
                  {item.nl.cta}
                  <ArrowRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
                </span>
              </a>
            ))}
          </div>
        )}

        {comingSoon.length > 0 && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-6">Binnenkort</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {comingSoon.map((item) => (
                <div class="rounded-2xl p-6 opacity-50" style="background: var(--card); border: 1px solid var(--border);">
                  <span class="inline-block text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Branche</span>
                  <p class="text-sm font-medium text-[var(--heading)]">{item.nl.label}</p>
                  <span class="inline-flex items-center gap-1 text-xs text-[var(--muted-foreground)] mt-3">
                    <Clock className="size-3" /> In de maak
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  </Background>
</DefaultLayout>
