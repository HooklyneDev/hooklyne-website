---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const posts = (await getCollection('blog_nl')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DefaultLayout
	title="Blog | Hooklyne"
	description="Founder-notities, productupdates, vergelijkingen en praktijkgerichte inzichten over B2B prospect-onderzoek van het Hooklyne-team."
	image="/og/blog.jpg"
>
	<Background>
		<section class="pt-32 lg:pt-40 pb-10">
			<div class="container max-w-5xl">
				<p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Resources</p>
				<h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4">Blog.</h1>
				<p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl leading-relaxed">
					Productupdates, founder-notities, vergelijkingen en praktische gidsen over B2B-prospecting voor Nederlandse en Britse MKB-teams. Een feed.
				</p>
			</div>
		</section>

		<div class="pb-20">
			{posts.length === 0 ? (
				<div class="container max-w-5xl">
					<div
						class="rounded-2xl p-8 md:p-10 text-center"
						style="background: var(--card); border: 1px solid var(--border); box-shadow: var(--shadow-sm);"
					>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--hooklyne-blue)] mb-3">Eerste post komt eraan</p>
						<h2 class="text-xl md:text-2xl font-semibold text-[var(--heading)] tracking-tight mb-3">
							Waarom we onze data-stack niet bij naam noemen.
						</h2>
						<p class="text-sm text-[var(--muted-foreground)] max-w-lg mx-auto leading-relaxed">
							Onze eerste post komt zo. De korte versie: de workflow is het product, de leveranciers eronder zijn de keuken. Wij vinden dat kopers het bord moeten beoordelen, niet de voorraadkast.
						</p>
					</div>
				</div>
			) : (
				<BlogPosts posts={posts} lang="nl" client:only='react' />
			)}
		</div>
	</Background>
</DefaultLayout>
