---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { PortalShot } from '@/components/portal-shot';
import { SignalHeatTable } from '@/components/product/signal-heat-table';
import { FindCompaniesFlow } from '@/components/product/find-companies-flow';
import { EmailCompose } from '@/components/product/email-compose';
import { VerificationWaterfall } from '@/components/product/verification-waterfall';

const packageBlocks = [
  {
    step: "01",
    tag: "Het bedrijf",
    title: "Vandaag gelezen, niet vorig jaar gescraped.",
    body: "We trekken het bedrijf live van het web op de dag dat we versturen, en distilleren daaruit de ene zin waar je echt mee opent. Geen hergebruikte homepage-tekst, geen fundingronde uit 2023.",
  },
  {
    step: "02",
    tag: "De beslisser",
    title: "Bouncet niet, en dit is de juiste persoon.",
    body: "Per contact leveren we naam, functie, geverifieerd mailadres en bedrijfsnummer waar we die hebben. Vier deliverability-checks (SMTP, catch-all, role en deliverable) over 21 providers. Komt een contact er niet doorheen, dan houden we het tegen.",
  },
  {
    step: "03",
    tag: "De aanleiding",
    title: "Een echte reden om deze week te schrijven, geen los nieuws.",
    body: "We pikken funding, nieuwe aanstellingen, lanceringen, leiderschapswissels en uitbreidingen op uit de laatste 14 dagen, en scoren elke beweging tegen wat jij verkoopt. \"Series A aangekondigd\" landt alleen als het er voor jou ook echt toe doet.",
  },
  {
    step: "04",
    tag: "De mail",
    title: "Eén concept. Verstuur het of pas een regel aan.",
    body: "We stellen mail en LinkedIn-bericht op, in vier controlestappen, verankerd aan de aanleiding hierboven. Versturen zoals het is, of een regel aanpassen.",
  },
];

const prospectingModes = [
  {
    n: "01",
    title: "Vind bedrijven voor mij",
    body: "Beschrijf je ideaal klantprofiel en krijg gerangschikte matches met drie besluitvormers per bedrijf.",
  },
  {
    n: "02",
    title: "Ik ken het bedrijf",
    body: "Plak het domein en krijg drie passende besluitvormers, met de invalshoek per persoon.",
  },
  {
    n: "03",
    title: "Ik weet wie ik wil bereiken",
    body: "Plak een naam of LinkedIn-URL en krijg een geverifieerd mailadres, verse context en een opgestelde mail.",
  },
  {
    n: "04",
    title: "Vergelijkbare bedrijven",
    soon: true,
    body: "Upload je beste klanten en krijg de volgende vijftig die in vorm op ze lijken, niet alleen in label.",
  },
];

const signalSources = [
  "Funding",
  "Leiderschap",
  "Aanstellingen",
  "Lanceringen",
  "Pers",
  "Expansie",
  "Sectornieuws",
];

const profileTabs = [
  {
    n: "01",
    title: "Bedrijf & waardepropositie",
    body: "Wat je verkoopt, aan wie, en waarom jij. De feiten waar elke mail op rust.",
    fields: [
      "Bedrijfsnaam",
      "Jouw naam",
      "Wat we doen - de elevator pitch",
      "Onderscheidende kant - waarom jij boven de rest",
      "Ideale klant - omvang, rol, sector, regio",
      "Werkgebieden",
    ],
  },
  {
    n: "02",
    title: "Stem & toon",
    body: "Hoe jij klinkt op papier. Vastgelegd zoals je het aan een tekstschrijver zou uitleggen.",
    fields: [
      "Schrijfstijl - hoe jij eigenlijk schrijft",
      "Toon-keywords - 3 tot 5 woorden die jou definiëren",
      "Handtekening - naam, functie, telefoon, LinkedIn",
    ],
  },
  {
    n: "03",
    title: "Voorbeeldmails",
    body: "Tot vijf eerdere mails waar je trots op was. De brandstof voor de kalibratie.",
    fields: [
      "Voorbeeldmail 1 - vereist",
      "Voorbeeldmails 2 tot 5 - optioneel, Nederlands of Engels",
      "Onderwerpen, inhoud, afsluitingen - een-op-een bewaard",
    ],
  },
  {
    n: "04",
    title: "Producten & diensten",
    body: "Zodat het juiste product de juiste aanleiding raakt in de eerste alinea.",
    fields: [
      "Productnaam - wat het oplost",
      "Een per regel, geschreven als een sales-sheet",
      "Prijs, MOQ, doorlooptijden waar nuttig",
    ],
  },
  {
    n: "05",
    title: "Regels & context",
    body: "Huisstijl en wat we nooit zeggen. Toegepast op elk concept.",
    fields: [
      "Niet-doen-regels - harde no's, een per regel",
      "Woord-limit - per kanaal",
      "Extra context - sectorfocus, prioriteiten, kanttekeningen",
    ],
  },
];
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Product", path: "/nl/product" },
]);
---

<DefaultLayout
  title="Product | Hooklyne"
  description="Geverifieerde prospectpakketten, live signalen, meeting prep briefs en sector intelligence. Alles in een portaal."
  image="/og/product.jpg"
  ctaVariant="product"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Hooklyne",
    "description": "Geverifieerde prospectpakketten, live signalen, meeting prep briefs en sector intelligence. Alles in een portaal.",
    "inLanguage": "nl-NL",
    "brand": { "@type": "Brand", "name": "Hooklyne" },
    "url": "https://www.hooklyne.com/nl/product",
    "category": "B2B prospect research software",
    "audience": { "@type": "BusinessAudience", "audienceType": "B2B MKB-salesteams (10-100 personen)" },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": "39",
      "highPrice": "299",
      "offerCount": 4,
      "url": "https://www.hooklyne.com/nl/prijzen"
    }
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Hooklyne product walkthrough",
    "description": "A 30-second walkthrough of the Hooklyne portal: prospect packages with verified contacts, live signals, and a first message in your voice.",
    "thumbnailUrl": "https://www.hooklyne.com/home/hooklyne-research-layer-b2b-prospecting.webp",
    "contentUrl": "https://www.hooklyne.com/home/hooklyne-intro.mp4",
    "uploadDate": "2026-02-01",
    "duration": "PT30S",
    "publisher": {
      "@type": "Organization",
      "name": "Hooklyne",
      "logo": { "@type": "ImageObject", "url": "https://www.hooklyne.com/logo.svg" }
    }
  })} />
  <Background>
    <section class="pt-28 pb-12 md:pt-36 md:pb-14 lg:pt-44 lg:pb-16 relative">
      <HeroGlow lang="nl" client:idle />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4" data-fade>Product</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-[var(--heading)] leading-[1.1] mb-6" data-fade data-delay="1">
          Elke prospect, compleet samengesteld.
        </h1>
        <p class="text-lg text-[var(--muted-foreground)] max-w-xl mx-auto leading-relaxed" data-fade data-delay="2">
          Een geverifieerd contact, een actuele reden om contact te zoeken en een eerste mail in jouw stem. Elke keer opnieuw.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4" data-fade data-delay="3">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 h-11 px-6 rounded-lg text-sm font-semibold text-white transition-opacity hover:opacity-90 btn-shine group"
            style="background: var(--hooklyne-navy)"
          >
            Start je gratis pilot
            <svg class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/nl/how-it-works"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--muted-foreground)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk hoe het werkt
            <svg class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div id="hero-video" class="mt-16 lg:mt-20" data-fade data-delay="4">
          <div class="relative w-full rounded-2xl overflow-hidden" style="box-shadow: var(--shadow-xl);">
            <div class="flex items-center gap-2 px-4 border border-b-0 rounded-t-2xl" style="height: 44px; background: var(--card); border-color: var(--border);">
              <div class="flex items-center gap-1.5 mr-1">
                <div class="size-3 rounded-full" style="background: #ff5f57"></div>
                <div class="size-3 rounded-full" style="background: #febc2e"></div>
                <div class="size-3 rounded-full" style="background: #28c840"></div>
              </div>
              <div class="flex items-center gap-2 px-3 rounded-full text-xs flex-1 mx-3" style="height: 28px; background: var(--background); color: var(--heading);">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.6; flex-shrink: 0;"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="flex-1 text-center">portal.hooklyne.com</span>
              </div>
            </div>
            <div class="border border-t-0 rounded-b-2xl relative overflow-hidden" style="border-color: var(--border); padding-bottom: 56.7%;">
              <video
                id="product-hero-video"
                autoplay muted loop playsinline preload="auto"
                poster="/home/hooklyne-research-layer-b2b-prospecting.webp"
                style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; background: var(--card);"
              >
                <source src="/home/hooklyne-intro.webm" type="video/webm" />
                <source src="/home/hooklyne-intro.mp4" type="video/mp4" />
              </video>
              <script is:inline>
                (function () {
                  var v = document.getElementById('product-hero-video');
                  if (!v) return;
                  var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                  if (reduceMotion) { v.removeAttribute('autoplay'); v.pause(); return; }
                  var tryPlay = function () { v.play().catch(function () {}); };
                  if (v.readyState >= 3) tryPlay();
                  else v.addEventListener('canplay', tryPlay, { once: true });
                  if ('IntersectionObserver' in window) {
                    var io = new IntersectionObserver(function (entries) {
                      entries.forEach(function (e) {
                        if (e.isIntersecting) v.play().catch(function () {});
                        else v.pause();
                      });
                    }, { threshold: 0.15 });
                    io.observe(v);
                  }
                })();
              </script>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pt-10 pb-10 md:pt-12 md:pb-12 lg:pt-14 lg:pb-12" data-fade>
      <div class="container max-w-6xl">
        <div class="max-w-2xl mb-8 lg:mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Het pakket</p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
            Vier dingen moeten kloppen voor je op verzenden klikt.
          </h2>
          <p class="text-base text-[var(--muted-foreground)] leading-relaxed">
            Klopt een van de vier niet, dan strandt de mail. Dit zijn de vier checks die we doorlopen voor we leveren.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 md:gap-5">
          {packageBlocks.map((b) => (
            <div class="package-card rounded-2xl p-4 sm:p-5 md:p-6 flex flex-col min-w-0 overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
              <div class="flex items-center flex-wrap gap-x-2.5 gap-y-1 mb-2.5">
                <span class="text-[11px] font-mono tabular-nums text-[var(--muted-foreground)]">{b.step}</span>
                <span class="h-3 w-px bg-[var(--border)]"></span>
                <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--hooklyne-blue)]">{b.tag}</span>
              </div>
              <h3 class="text-base sm:text-lg md:text-xl font-semibold text-[var(--heading)] mb-1.5 leading-snug tracking-tight">{b.title}</h3>
              <p class="text-[14px] sm:text-[15px] text-[var(--muted-foreground)] leading-relaxed mb-4">{b.body}</p>

              {b.step === "01" && (
                <div class="mt-auto rounded-xl p-2.5 sm:p-3.5" style="background: var(--background); border: 1px solid var(--border);">
                  <div class="flex items-center gap-2 sm:gap-3 mb-3">
                    <div class="size-8 sm:size-9 rounded-lg flex items-center justify-center text-[11px] font-bold shrink-0" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">AL</div>
                    <div class="min-w-0 flex-1">
                      <p class="text-[13px] font-semibold text-[var(--heading)] truncate">Axiom Logistics</p>
                      <p class="text-[11px] text-[var(--muted-foreground)] truncate">Logistiek &middot; Venlo &middot; 240 FTE</p>
                    </div>
                    <span class="shrink-0 inline-flex items-center gap-1 text-[10px] font-semibold px-1.5 py-0.5 rounded" style="background: rgba(13,148,136,0.12); color: var(--hooklyne-teal);">
                      <span class="relative flex size-1.5"><span class="absolute inline-flex h-full w-full rounded-full opacity-70 animate-ping" style="background: var(--hooklyne-teal);"></span><span class="relative inline-flex rounded-full size-1.5" style="background: var(--hooklyne-teal);"></span></span>
                      Live
                    </span>
                  </div>
                  <div class="text-[12px] leading-relaxed text-[var(--heading)] border-l-2 pl-3" style="border-color: var(--hooklyne-blue);">
                    Groeit snel. Tweede DC open sinds vorig jaar, operationeel team 35% groter in 18 maanden.
                  </div>
                </div>
              )}

              {b.step === "02" && (
                <div class="mt-auto rounded-xl p-2.5 sm:p-3.5" style="background: var(--background); border: 1px solid var(--border);">
                  <div class="flex items-center gap-2 sm:gap-3 mb-3">
                    <div class="size-8 sm:size-9 rounded-full flex items-center justify-center text-[11px] font-bold shrink-0" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">MV</div>
                    <div class="min-w-0 flex-1">
                      <p class="text-[13px] font-semibold text-[var(--heading)] truncate">Marieke de Vries</p>
                      <p class="text-[11px] text-[var(--muted-foreground)] truncate">Head of Operations &middot; m.devries@axiom.nl</p>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-1.5">
                    {["SMTP", "Catch-all", "Role", "Deliverable"].map((v) => (
                      <div class="flex items-center gap-1.5 text-[11px] font-medium text-[var(--heading)]">
                        <svg class="size-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--hooklyne-teal);"><path d="M20 6 9 17l-5-5" /></svg>
                        {v}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {b.step === "03" && (
                <div class="mt-auto rounded-xl p-2.5 sm:p-3.5" style="background: var(--background); border: 1px solid var(--border);">
                  <div class="flex items-center justify-between gap-2 mb-3">
                    <div class="flex items-center gap-1.5 min-w-0">
                      <span class="relative flex size-1.5 shrink-0"><span class="absolute inline-flex h-full w-full rounded-full opacity-70 animate-ping" style="background: var(--hooklyne-orange);"></span><span class="relative inline-flex rounded-full size-1.5" style="background: var(--hooklyne-orange);"></span></span>
                      <span class="text-[10px] font-bold uppercase tracking-wider truncate" style="color: var(--hooklyne-orange);">Live signaal &middot; 3d geleden</span>
                    </div>
                    <span class="text-[10px] font-mono tabular-nums text-[var(--muted-foreground)] shrink-0">#SIG-0412</span>
                  </div>
                  <p class="text-[13px] font-semibold leading-snug text-[var(--heading)] mb-3">VP Operations ingestroomd vanuit DHL. Drie openstaande logistiek-manager vacatures.</p>
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--muted-foreground)]">Fit</span>
                    <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background: var(--border);">
                      <div class="h-full rounded-full" style="width: 92%; background: linear-gradient(to right, var(--hooklyne-blue), var(--hooklyne-teal));"></div>
                    </div>
                    <span class="text-[11px] font-bold tabular-nums" style="color: var(--hooklyne-teal);">92</span>
                  </div>
                </div>
              )}

              {b.step === "04" && (
                <div class="mt-auto rounded-xl p-2.5 sm:p-3.5" style="background: var(--background); border: 1px solid var(--border);">
                  <div class="flex items-baseline gap-2 pb-2 mb-2 border-b min-w-0" style="border-color: var(--border);">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--muted-foreground)] w-10 shrink-0">Aan</span>
                    <span class="text-[12px] font-medium text-[var(--heading)] truncate min-w-0 flex-1">m.devries@axiom.nl</span>
                  </div>
                  <div class="flex items-baseline gap-2 pb-2.5 mb-2.5 border-b min-w-0" style="border-color: var(--border);">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--muted-foreground)] w-10 shrink-0">Onderwerp</span>
                    <span class="text-[12px] font-semibold text-[var(--heading)] truncate min-w-0 flex-1">Jullie nieuwe VP Ops - het team dat je eromheen bouwt</span>
                  </div>
                  <p class="text-[12px] leading-relaxed text-[var(--muted-foreground)] line-clamp-2 mb-3">
                    Zag dat jullie nieuwe VP Ops net aan boord is. Met drie openstaande logistiek-manager vacatures groeit het team er snel omheen.
                  </p>
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-[10px] text-[var(--muted-foreground)] truncate min-w-0">NL &middot; EN auto &middot; binnen 60s</span>
                    <span class="shrink-0 inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-1 rounded" style="background: var(--hooklyne-navy); color: white;">
                      Verstuur
                      <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
                    </span>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 md:py-14 lg:py-16" data-fade>
      <div class="container max-w-6xl">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Het portaal</p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
            Open, bekijk, verstuur.
          </h2>
          <p class="text-base sm:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Gebouwd voor een moment: prospect erin, mail eruit, binnen een minuut.
          </p>
          <div class="inline-flex items-center gap-2 mt-5 px-3 py-1.5 rounded-full text-[11px] font-semibold" style="background: rgba(13,148,136,0.10); color: var(--hooklyne-teal); border: 1px solid rgba(13,148,136,0.25);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2 2"/><path d="M5 3 2 6"/><path d="m22 6-3-3"/></svg>
            De meeste prospects worden binnen een minuut bekeken
          </div>
        </div>

        <EmailCompose lang="nl" client:visible tabletRatio="3/2" mobileRatio="3/4" />

        <ul class="grid md:grid-cols-2 gap-3 mt-12 max-w-4xl mx-auto">
          {[
            "Elke prospect op een scherm, zonder graafwerk.",
            "Bewerk ter plekke of accepteer zoals opgesteld.",
            "Verstuur vanuit je inbox of plak in je sequencer.",
            "Nederlands of Engels, automatisch gekozen op de prospect.",
            "Eenmalig afgesteld en elke week scherper.",
          ].map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-[var(--foreground)]">
              <svg class="size-4 shrink-0 mt-0.5 text-[var(--hooklyne-teal)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-10 lg:py-14" data-fade>
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">Dashboard</p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight mb-3 sm:mb-4 leading-tight">
              Begin de dag met focus.
            </h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed mb-8">
              Geen muur van cijfers, maar een heldere lijst voor vandaag.
            </p>

            <div class="space-y-4">
              {[
                { t: "Focus van de dag", b: "Twee prioriteitsacties, gerangschikt en voorzien van invalshoek. Hier begin je." },
                { t: "Signaalwarmte", b: "Je vijf heetste prospects, met trend: stijgend, stabiel of koelend." },
                { t: "Marktinformatie", b: "Zes nieuwskoppen uit jouw markt die je vandaag kunt inzetten in het gesprek." },
              ].map((f) => (
                <div class="flex gap-3">
                  <div class="size-1.5 rounded-full bg-[var(--hooklyne-orange)] mt-2 shrink-0"></div>
                  <div>
                    <p class="text-sm font-semibold text-[var(--heading)]">{f.t}</p>
                    <p class="text-sm text-[var(--muted-foreground)] mt-0.5 leading-relaxed">{f.b}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:sticky lg:top-28">
            <PortalShot
              lang="nl"
              client:visible
              label="Dashboard detail"
              src="/product/dashboard.jpg"
