---
import { Background } from '@/components/background';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { breadcrumbList } from "@/lib/seo";

const sections = [
  {
    eyebrow: "Wat zit erin",
    title: "Elke prospect, volledig samengesteld.",
    body: "Eén kaart in het portaal. Geverifieerd contact, gescoord signaal, opgesteld bericht, klikbare bronnen. Klaar om te beoordelen en te versturen vanuit je eigen inbox.",
  },
  {
    eyebrow: "Geverifieerd contact",
    title: "20+ databronnen, één oordeel.",
    body: "Geen enkele provider dekt meer dan ~40% van een markt. We laten ze tegen elkaar werken, flaggen conflicten en versturen alleen wat door vier deliverability-checks komt. Bouncerate ruim onder de 2% industry safe zone.",
  },
  {
    eyebrow: "Live signaal",
    title: "Echte triggers, geen LLM-aannames.",
    body: "Funding, hiring, leiderschapswissels, tech-stack-updates, M&A, nieuwe rollen op de careers-pagina. Gestructureerde signalen die continu binnenkomen, dubbel gescoord (relevant voor hen, relevant voor jou) voordat ze in jouw inbox landen.",
  },
  {
    eyebrow: "In jouw stem",
    title: "Een eerste mail die als jou klinkt.",
    body: "Eenmalig 30 minuten Sender Profile invullen. Tot vijf voorbeeldmails uploaden. Vanaf dat moment erft elk concept jouw stijl via vier reasoning-passes. Geen template, geen herkenbare AI-stem.",
  },
  {
    eyebrow: "Onderzoek",
    title: "Citaten die je kunt openen.",
    body: "Elke claim is te herleiden naar een actuele URL. Geen verzonnen quotes, geen verzonnen cijfers, geen verzonnen klanten. Klik door, controleer, gebruik in je gesprek.",
  },
];

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Product", path: "/nl/product" },
]);
---
<DefaultLayout
  title="Product | Hooklyne"
  description="Geverifieerde prospect-pakketten, live signalen, meeting prep briefs en sector intelligence. Alles in één portaal."
  image="/og/product.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />

  <Background>
    <section class="pt-32 lg:pt-40 pb-16">
      <div class="container max-w-5xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4 text-center">Product</p>
        <h1 class="text-3xl md:text-5xl font-semibold text-[var(--heading)] tracking-tight mb-4 text-center">Elke prospect, volledig samengesteld.</h1>
        <p class="text-base md:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed text-center">
          Eén kaart per prospect. Geverifieerd contact, koopsignaal, opgestelde mail, klikbare bronnen. In minder dan een minuut bekijk en verstuur je 'm.
        </p>
      </div>
    </section>

    <section class="pb-20">
      <div class="container max-w-4xl space-y-5">
        {sections.map((s) => (
          <div class="rounded-2xl p-7 md:p-9" style="background: var(--card); border: 1px solid var(--border);">
            <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-3">{s.eyebrow}</p>
            <h2 class="text-xl md:text-2xl font-semibold text-[var(--heading)] tracking-tight mb-3">{s.title}</h2>
            <p class="text-base text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="pb-24">
      <div class="container max-w-4xl">
        <div class="rounded-2xl p-8 md:p-10 text-center" style="background: var(--card); border: 1px solid var(--border);">
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight mb-3">Zelf testen op tien echte prospects.</h2>
          <p class="text-base text-[var(--muted-foreground)] mb-6 max-w-xl mx-auto leading-relaxed">
            Tien volledig opgebouwde prospect-pakketten in de gratis pilot. Geen creditcard, geen verplichting. We vragen er een feedbackgesprek van 20 minuten voor terug.
          </p>
          <a
            href="/contact"
            class="h-11 px-6 inline-flex items-center justify-center text-sm font-semibold rounded-lg"
            style="background-color: var(--hooklyne-navy); color: #ffffff;"
          >
            Start je gratis pilot
          </a>
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
