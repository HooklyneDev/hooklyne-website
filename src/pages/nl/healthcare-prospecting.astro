---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, AlertCircle, Gift } from 'lucide-react';
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Zorg prospecting", path: "/nl/healthcare-prospecting" },
]);

const pains = [
  "Zorgkopers hebben strikte inkoopregels. Koude outreach die die negeert krijgt geen antwoord.",
  "De inkoopmanager is veranderd. Dat merkte je aan de bounce.",
  "Je bereikt clinici zonder aankoopbevoegdheid, niet de inkoop- of operationele leads die wel beslissen.",
  "Accreditatievernieuwingen en digitale transformatietijdlijnen zijn je beste signalen - en je houdt ze niet bij.",
];

const signals = [
  {
    title: "Digitale transformatie en EHR-implementatieprojecten.",
    body: "Een zorginstelling die een elektronisch patiëntendossier-implementatie, een digitaal patiëntenportaal of een klinisch beslissingsondersteunend project heeft aangekondigd of begonnen, bevindt zich in een uitgebreide inkoopvolgorde die meerdere aanverwante inkoopmomenten creëert. IT-infrastructuur, integratie-middleware, training, gegevensbeheer, cybersecurity - elk is een deelproject met zijn eigen inkoopvenster. Implementatieaankondigingen staan in jaarverslagen, openbare ziekenhuisraadsnotulen en vakbladen.",
  },
  {
    title: "Accreditatievernieuwingen en kwaliteitscertificering.",
    body: "NIAZ, JCI, NEN 7510 en ISO 27001 voor gezondheidsinformatiebeveiliging - elk creëert een inkoopbeoordelingscyclus. Een ziekenhuis of kliniek die accreditatievernieuwing nadert, beoordeelt of zijn huidige leveranciers en systemen voldoen aan de bijgewerkte criteria. Een kliniek die zojuist een nieuwe accreditatie heeft behaald, heeft zijn bereidheid aangetoond om te investeren in kwaliteitsinfrastructuur en heeft vaak doorlopende inkoop om de standaard te handhaven. Accreditatiecycli zijn gedocumenteerd en voorspelbaar.",
  },
  {
    title: "Fusie, overname en netwerkconsolidatie.",
    body: "Zorgconsolidatie - ziekenhuisfusies, kliniekacquisities, huisartsenpraktijknetwerkvorming - creëert inkoopbeoordelingen op het gecombineerde entiteitsniveau. De nieuwe gecombineerde organisatie moet leveranciers rationaliseren, systemen standaardiseren en vaak infrastructuur upgraden om de grotere patiëntenbasis te bedienen. Deze consolidaties worden geregistreerd bij zorgtoezichthouders en vaak in bedrijfsregisters. Het inkoopvenster bevindt zich in de 6-18 maanden na de fusie, niet ervoor.",
  },
  {
    title: "Nieuwe locatieopeningen en afdelingsuitbreidingen.",
    body: "Een nieuwe kliniek, een afdelingsuitbreiding of een satellietlocatieopening is een helder inkoop-trigger: apparatuur, IT, personeelssystemen, patiëntbeheersoftware. Vergunningsaanvragen voor zorginstellingen worden ingediend bij gemeentelijke overheden en worden vaak begeleid door persaankondigingen. Het inkoopvenster opent bij vergunningsverlening, niet op de openingsdag. De operationeel of inkoopmanager bereiken in de planningsfase is aanzienlijk makkelijker dan aankomen nadat de apparatuurbesluiten al zijn genomen.",
  },
];

const faq = [
  {
    q: "Zorginkoop is sterk gereguleerd. Kan Hooklyne in deze omgeving opereren?",
    a: "Ja - en het is een van de belangrijkste redenen om een AVG-natief instrument in deze sector te gebruiken. Elk Hooklyne-contact heeft een gedocumenteerde bron. Geen gescrapete contactgegevens, geen grijze-zonebestanden. Voor zorgkopers die nalevingscontroles uitvoeren op leveranciersrelaties is de herkomst van Hooklyne documenteerbaar en verdedigbaar.",
  },
  {
    q: "Ziekenhuisinkoop gaat vaak via formele aanbestedingen. Is outreach-gedreven prospecting nuttig?",
    a: "Formele aanbesteding is het einde van het proces, niet het begin. De organisaties die aanbestedingen winnen zijn doorgaans bij het inkoopteam bekend voordat de aanbesteding wordt gepubliceerd. Een bekende, geloofwaardige leverancier zijn in de pre-aanbestedingsfase is het doel. Hooklyne brengt je bij de juiste persoon op het juiste moment om die relatie op te bouwen.",
  },
  {
    q: "We verkopen aan privéklinieken, niet aan grote ziekenhuizen. Werkt de dekking op dat niveau?",
    a: "Ja. Privéklinieken en gespecialiseerde zorgaanbieders zijn goed gedekt in KVK-registraties, zorgregulatorische filings en sectorspecifieke databases. Het segment waar outreach-gedreven prospecting het meeste oplevert is vaak middelgrote privézorg - 20-200 fte - waar inkoop niet volledig is geformaliseerd en relaties zwaarder wegen dan raamovereenkomsten.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons zorg-ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte doellijst, volledig opgebouwd, zonder kaart. Zorg is een segment waar de accreditatie- en transformatietimingaanpak ofwel meteen resoneert of de koper nog niet in een inkoopvenster zit - de pilot maakt dat snel duidelijk.",
  },
];
---

<DefaultLayout
  title="Prospecting bij zorginstellingen | Hooklyne"
  description="Hoe je buyers in de zorg bereikt: digitale transformatiesignalen, accreditatietijdlijnen, nieuwe faciliteittriggers en hoe je inkoopregels navigeert om de juiste besluitvormer te bereiken."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Zorg prospecting-gids",
    "description": "Hoe je zorginstellingen prospecteert: signalen, contacten en koopvensters.",
    "url": "https://www.hooklyne.com/nl/healthcare-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Zorg prospecting</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Zorgkopers hebben strikte regels. De juiste zijn nog steeds bereikbaar.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Inkoop in de zorg wordt bepaald door accreditatievereisten, digitale transformatietijdlijnen en regelgevingskaders - niet door LinkedIn-activiteit. De signalen die een actief koopvenster aangeven staan in raadsnotulen, locatieaanvragen en accreditatiedatabases. Deze gids behandelt waar die signalen zijn en hoe je de juiste persoon bereikt voordat het formele proces begint.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <AlertCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte zorgprospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw zorg-ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe zorginstellingen kopen</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een zorgkoopvenster openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Zorginkoop volgt accreditatiecycli, digitale transformatieprojecten en organisatieveranderingen - niet sociale media. De signalen staan in publieke filings en regulatoire databases.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Waar Hooklyne past</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Gebouwd voor kopers die controleren waar jouw gegevens vandaan komen.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Zorgkopers zijn de meest databewuste in vrijwel elke sector. Elk Hooklyne-contact heeft een gedocumenteerde bron - openbaar register, bedrijfswebsite, accreditatiedatabase. Geen gescrapete contactgegevens, geen grijze-zone-sourcing. Voor zorginkoop-teams die nalevingscontroles uitvoeren op leveranciersrelaties is die herkomst documenteerbaar. Hooklyne is gebouwd en gehost in Nederland en watervalt over 21 geregistreerde providers.</p>
          <p>Het juiste contact in de zorg hangt af van wat je verkoopt en de omvang van de organisatie. Bij een privékliniek is de besluitvormer vaak de medisch directeur of praktijkmanager. Bij een groter ziekenhuis is het de inkoopmanager, CIO of operationeel directeur afhankelijk van de categorie. Hooklyne bepaalt de juiste rol bij elke instelling in plaats van een lijst van clinici te geven die geen aankoopbevoegdheid hebben.</p>
          <p>De eerste mail verwijst naar de specifieke trigger die deze instelling nu relevant maakt - een digitaal transformatieproject dat ze hebben aangekondigd, een accreditatievernieuwing die nadert, een nieuwe locatiefiling. Die specificiteit telt meer in de zorg dan in vrijwel elke andere sector, omdat inkoopmanagers veel outreach ontvangen en die filteren op aantoonbare relevantie.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Gerelateerde gidsen</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/nl/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Alle branchegidsen</a>
          <a href="/nl/fintech-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Fintech en financiële diensten</a>
          <a href="/nl/avg-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">AVG-compliant prospecting</a>
          <a href="/nl/vergelijken" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool-vergelijkingen</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over zorg prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
