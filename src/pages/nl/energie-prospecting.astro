---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import { HeroGlow } from '@/components/hero-glow';
import { HomePricing } from '@/components/blocks/home-pricing';
import { ArrowRight, WarningCircle, Gift } from "@phosphor-icons/react";
import { breadcrumbList } from "@/lib/seo";

const breadcrumb = breadcrumbList([
  { name: "Home", path: "/nl" },
  { name: "Branches", path: "/nl/industries" },
  { name: "Energie en nutsbedrijven prospecting", path: "/nl/energie-prospecting" },
]);

const pains = [
  "De duurzaamheidsmanager die je nodig hebt reageert niet op outreach die de regelgevingscontext negeert.",
  "Netaansluitingsaankondigingen zijn je beste signaal - je vindt ze in persberichten, weken nadat iedereen al gemaild heeft.",
  "Je bereikt het juiste bedrijf maar de verkeerde rol: inkoop, niet operations, heeft de beslissing.",
  "Hernieuwbare energieprojecten hebben strakke tijdlijnen. Je houdt ze niet systematisch bij.",
];

const signals = [
  {
    title: "Aankondigingen van hernieuwbare energieprojecten.",
    body: "Een aankondiging van een wind-, zonne- of waterstofproject is een van de schoonste inkoop-signalen in de energiesector. Projectontwikkelingstijdlijnen zijn openbaar - vergunningsaanvragen, netaansluitingsovereenkomsten en vergunningsstappen worden ingediend voordat de bouw begint. Elk mijlpaal is een inkoop-event: apparatuurleveranciers, netdiensten, monitoringtechnologie, O&M-contracten. Bedrijven die projectontwikkelaars in de planningsfase bereiken, staan op de shortlist. Bedrijven die bij inbedrijfstelling aankomen niet.",
  },
  {
    title: "Regelgevingsdeadlines: RED III, CSRD, ETS.",
    body: "De Richtlijn hernieuwbare energie III, de Richtlijn duurzaamheidsrapportage en het EU-emissiehandelssysteem creëren elk verplichte nalevingstijdlijnen met echte inkoop eraan vast. Een nutsbedrijf of industriële energiekoper die een RED III-rapporteringsdeadline nadert, koopt actief hernieuwbare energie-certificaten en energiemanagementsoftware. Een fabrikant boven de EU ETS-drempel koopt carbon management tools en energie-efficiëntiediensten. Deze deadlines zijn openbaar en bedrijfsspecifieke toepasselijkheid is vaak afleidbaar uit bedrijfsomvang en sector.",
  },
  {
    title: "Vacatures in energiemanagement en duurzaamheid.",
    body: "Een nieuwe Head of Sustainability, Energy Manager of Chief Sustainability Officer-hire signaleert dat een bedrijf voor het eerst een compliance-functie opbouwt of een bestaande die niet geschikt was upgradet. De eerste negentig dagen omvatten een leveranciers- en toolingbeoordeling. Dat beoordelingsvenster is toegankelijker dan de doorlopende beheerrelatie die erop volgt. Een duurzaamheidshire bij een bedrijf van 50-200 medewerkers is vaak de eerste toegewijde resource - die persoon heeft aanzienlijk aankoopgezag en een mandaat om leveranciersrelaties van scratch op te bouwen.",
  },
  {
    title: "Netaansluitingsgoedkeuringen en capaciteitsuitbreidingen.",
    body: "Een bedrijf dat zojuist een netaansluitingsgoedkeuring heeft ontvangen voor een nieuwe locatie of uitgebreide capaciteit, gaat een gedefinieerde inkoopvolgorde in: elektrische infrastructuur, energiemanagementsystemen, vraagresponscontracten en vaak opslagoplossingen. Netaansluitingsgoedkeuringen worden ingediend bij netwerkbeheerders en staan vaak in openbare planningsdatabases. De meeste verkopers missen dit signaal volledig omdat ze LinkedIn in de gaten houden, niet vergunningsportalen.",
  },
];

const faq = [
  {
    q: "Energie-inkoop kent lange inkooptrajecten. Is signaalgedreven outreach dan nog nuttig?",
    a: "De cyclus van eerste contact tot getekend contract in energie kan 12-24 maanden duren. Maar de bedrijven die vroeg in die cyclus komen - voordat de specificatie is geschreven, voordat de leverancierslijst is gevormd - zijn de bedrijven die hem winnen. Als onbekende bij de RFP-fase aankomen is erg moeilijk. Twaalf maanden eerder aankomen met een relevante gespreksreden is dat niet.",
  },
  {
    q: "We verkopen specifiek aan nutsbedrijven. Heeft Hooklyne dekking?",
    a: "Grote nutsbedrijven hebben gestructureerde inkoop met formele RFP-processen die moeilijk te betreden zijn zonder een bestaande relatie. Het productievere segment voor signaalgedreven outreach is middelgrote nutsbedrijven, gemeentelijke energiebedrijven en energie-intensieve fabrikanten. Hooklyne is gebouwd voor bedrijven van 10-200 fte - daar zit de meeste leverage.",
  },
  {
    q: "CSRD en energieregelgeving veranderen regelmatig. Houdt Hooklyne dat bij?",
    a: "Hooklyne monitort regelgevingstijdlijnen en scoort prospects op de toepasselijke deadlines voor hun sector en omvang. De compliance-kalender is ingebouwd in het scoringsmodel - je hoeft het niet apart bij te houden. Wanneer een deadline nadert voor een bedrijf dat past bij jouw ICP, is dat het signaal.",
  },
  {
    q: "Wat als Hooklyne niet werkt voor ons energie-ICP?",
    a: "Eerst een pilot, dan pas een contract. Tien prospects uit je echte energiedoellijst, volledig opgebouwd, zonder kaart. Energie is een sector waar de regelgevingstimingaanpak snel resoneert of de koper nog niet in het venster zit - de pilot maakt dat duidelijk.",
  },
];
---

<DefaultLayout
  title="Prospecting bij energie en nutsbedrijven | Hooklyne"
  description="Hoe je buyers in energie en utilities bereikt: regelgevingssignalen die koopvensters openen, hoe je projectinkoop-contacten vindt en hoe je er bent voordat de shortlist gesloten is."
  image="/og/home.jpg"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Energie en nutsbedrijven prospecting-gids",
    "description": "Hoe je energie- en nutsbedrijven prospecteert: signalen, contacten en koopvensters.",
    "url": "https://www.hooklyne.com/nl/energie-prospecting",
    "inLanguage": "nl"
  })} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map((f) => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <Background>
    <section class="pt-32 lg:pt-44 pb-12 lg:pb-16 relative" data-fade>
      <HeroGlow lang="nl" client:idle signals={false} />
      <div id="hero-content" class="container max-w-4xl text-center relative z-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--hooklyne-blue)] mb-4">Energie en nutsbedrijven prospecting</p>
        <h1 class="hero-headline text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--heading)] leading-[1.1] mb-5">
          Energiekopers zijn niet moeilijk te overtuigen. Ze zijn moeilijk op het juiste moment te bereiken.
        </h1>
        <p class="text-base sm:text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto leading-relaxed mb-8">
          Inkoop in energie en utilities clustert rond projectmijlpalen, regelgevingsdeadlines en capaciteitswijzigingen - niet LinkedIn-activiteit. De signalen die een actief koopvenster aangeven zitten in vergunningsaanvragen en compliance-kalenders. Deze gids behandelt waar die signalen zijn en hoe je de juiste persoon bereikt voordat de shortlist al is gevormd.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/nl/contact"
            class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--hooklyne-navy)] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity group btn-shine"
          >
            Start een gratis pilot
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="#signalen"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--heading)] hover:text-[var(--hooklyne-blue)] transition-colors group"
          >
            Bekijk de signalen
            <ArrowRight className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </section>

    <section class="pt-2 pb-6 lg:pt-4 lg:pb-10" data-fade>
      <div class="container max-w-4xl">
        <div class="grid md:grid-cols-[1.4fr_1fr] gap-4 md:gap-5 items-stretch">
          <div class="rounded-2xl p-5 sm:p-6" style="background: var(--card); border: 1px solid var(--border);">
            <div class="flex items-center gap-2 mb-4">
              <WarningCircle className="size-4" style={{ color: "var(--hooklyne-orange)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-orange);">Je bent hier waarschijnlijk omdat</p>
            </div>
            <ul class="space-y-2.5">
              {pains.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--heading)] leading-snug">
                  <span class="size-1.5 rounded-full mt-2 shrink-0" style="background: var(--hooklyne-orange);"></span>
                  {p}
                </li>
              ))}
            </ul>
            <p class="text-xs text-[var(--muted-foreground)] mt-4 leading-relaxed">Als een van deze punten herkenbaar is, is de rest van deze pagina voor jou.</p>
          </div>
          <div class="rounded-2xl p-5 sm:p-6 flex flex-col" style="background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.20);">
            <div class="flex items-center gap-2 mb-3">
              <Gift className="size-4" style={{ color: "var(--hooklyne-teal)" }} />
              <p class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--hooklyne-teal);">Gratis pilot, geen kaart</p>
            </div>
            <p class="text-sm font-semibold text-[var(--heading)] leading-snug mb-2">Probeer het eerst op 10 van je echte energieprospects.</p>
            <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4">Tien volledig opgebouwde prospectpakketten uit jouw energie-ICP. Geen betaling, geen contract. Daarna vragen we twintig minuten eerlijke feedback.</p>
            <a href="/nl/contact" class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity btn-shine self-start" style="background: var(--hooklyne-teal);">
              Vraag een pilot aan <ArrowRight className="size-3.5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="signalen" class="pt-6 pb-12 lg:pt-10 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-4">Hoe energiebedrijven kopen</p>
          <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] md:leading-[1.1] mb-4">
            Vier signalen die een energiekoopvenster openen.
          </h2>
          <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed">
            Energie-inkoop wordt gedreven door projecttijdlijnen, regelgevingsmijlpalen en capaciteitsevents - niet door sociale media. De signalen staan in publieke aanvragen en compliance-kalenders, niet op LinkedIn.
          </p>
        </div>
        <div class="space-y-8">
          {signals.map((s, i) => (
            <div class="flex gap-5 pb-8 border-b border-[var(--border)] last:pb-0 last:border-0">
              <span class="text-sm font-bold tabular-nums shrink-0 mt-0.5 w-5" style="color: var(--hooklyne-blue)">{i + 1}</span>
              <div>
                <h3 class="text-base sm:text-lg font-semibold text-[var(--heading)] tracking-tight leading-snug mb-2">{s.title}</h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pt-2 pb-12 lg:pt-4 lg:pb-20" data-fade>
      <div class="container max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-teal)] mb-4">Waar Hooklyne past</p>
        <h2 class="text-2xl md:text-4xl font-semibold text-[var(--heading)] tracking-tight leading-[1.15] mb-6">
          Gebouwd voor inkoop gestuurd door regelgeving en projectmijlpalen.
        </h2>
        <div class="space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p>Energie- en utilities-contacten zijn niet goed gedekt in op LinkedIn gebaseerde databases. Projectontwikkelaars, netbeheerders en duurzaamheidsmanagers bij middelgrote bedrijven hebben zelden profielen die gedetailleerd genoeg zijn om nuttig te zijn. Hooklyne watervalt over 21 providers - waaronder bedrijfsregisters, sectorspecifieke databases en geverifieerde Europese bronnen - om het juiste contact bij elk bedrijf te vinden in plaats van een generieke lijst te geven.</p>
          <p>De regelgevingskalender in energie is voorspelbaar. RED III, CSRD, ETS - elk heeft bedrijfsspecifieke toepasselijkheid op basis van omvang, sector en geografie. Hooklyne scoort prospects op deze tijdlijnen zodat jouw outreach arriveert wanneer de compliance-druk daadwerkelijk opbouwt, niet wanneer een sequentie toevallig dag zeven bereikt.</p>
          <p>De eerste mail wordt opgesteld in de schrijfstijl van jouw vertegenwoordiger en verwijst naar het specifieke event of de deadline die dit bedrijf nu relevant maakt. Een duurzaamheidsmanager die een bericht ontvangt dat zijn netaansluitingsgoedkeuring noemt en koppelt aan een concrete inkoopimplicatie, leest het. Eentje die zegt 'wij helpen energiebedrijven' niet.</p>
        </div>
      </div>
    </section>
  </Background>

  <Background variant="bottom">
    <HomePricing client:visible />

    <section class="pt-6 pb-4 lg:pt-10 lg:pb-6" data-fade>
      <div class="container max-w-3xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-3">Gerelateerde gidsen</p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/nl/industries" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Alle branchegidsen</a>
          <a href="/nl/industrie-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Industrie en productie</a>
          <a href="/nl/avg-prospecting" class="text-sm text-[var(--hooklyne-blue)] hover:underline">AVG-compliant prospecting</a>
          <a href="/nl/vergelijken" class="text-sm text-[var(--hooklyne-blue)] hover:underline">Tool-vergelijkingen</a>
        </div>
      </div>
    </section>

    <section class="pt-6 pb-20 lg:pt-10 lg:pb-28" data-fade>
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--hooklyne-blue)] mb-3">FAQ</p>
          <h2 class="text-2xl md:text-3xl font-semibold text-[var(--heading)] tracking-tight">
            Vragen over energie prospecting, beantwoord.
          </h2>
        </div>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="group rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                <span class="text-[15px] font-semibold text-[var(--heading)] leading-snug">{f.q}</span>
                <span class="size-6 rounded-full flex items-center justify-center shrink-0 transition-transform group-open:rotate-45" style="background: rgba(52,76,163,0.10); color: var(--hooklyne-blue);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </Background>
</DefaultLayout>
